<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 人格強化版</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:#09111f;
  color:white;
}

.app{
  display:flex;
  flex-direction:column;
  height:100dvh;
  overflow:hidden;
}

/* ===== 画像 ===== */
.top{
  height:120px;
}
.top img{
  width:100%;
  height:100%;
  object-fit:cover;
  transform:translateY(12px);
}

/* ===== メイン ===== */
.main{
  flex:1;
  display:flex;
  flex-direction:column;
  min-height:0;
}

.panel{
  display:none;
  flex:1;
  flex-direction:column;
}
.panel.active{
  display:flex;
}

/* ===== チャット ===== */
.chat-wrap{
  display:flex;
  flex-direction:column;
  height:100%;
}

#chatBox{
  flex:1;
  overflow-y:auto;
  padding:10px;
}

.msg{
  max-width:75%;
  padding:10px;
  border-radius:15px;
  margin:6px 0;
}

.user{
  background:#ff4f8b;
  align-self:flex-end;
}

.bot{
  background:#444;
}

.time{
  font-size:10px;
  opacity:0.6;
}

/* ===== 入力 ===== */
.input{
  display:flex;
  gap:6px;
  padding:6px;
  background:#111;
}
input{
  flex:1;
  min-width:0;
  padding:10px;
}
button{
  padding:10px;
}

/* ===== タブ ===== */
.tabs{
  height:50px;
  display:flex;
  background:#222;
}
.tab{
  flex:1;
  text-align:center;
  line-height:50px;
}
</style>
</head>

<body>

<div class="app">

<div class="top">
<img src="girl-normal.jpg">
</div>

<div class="main">

<!-- 会話 -->
<div id="chatPanel" class="panel active">
<div class="chat-wrap">

<div id="chatBox"></div>

<div class="input">
<input id="input">
<button onclick="send()">送信</button>
</div>

</div>
</div>

<!-- 設定 -->
<div id="settingsPanel" class="panel">
<div style="padding:10px;">
名前<input id="name"><br><br>

性格
<select id="personality">
<option value="soft">優しい</option>
<option value="cool">さっぱり</option>
<option value="teasing">小悪魔</option>
</select>

<br><br>
<button onclick="save()">保存</button>
</div>
</div>

</div>

<div class="tabs">
<div class="tab" onclick="switchTab('chat')">会話</div>
<div class="tab" onclick="switchTab('settings')">設定</div>
</div>

</div>

<script>

/* ===== 状態 ===== */
let memory={
  name:localStorage.getItem("name")||"美咲",
  personality:localStorage.getItem("personality")||"soft",
  history:JSON.parse(localStorage.getItem("history")||"[]"),
  lastReply:"",
  level:parseInt(localStorage.getItem("level")||"1")
};

name.value=memory.name;
personality.value=memory.personality;

/* ===== 保存 ===== */
function save(){
  memory.name=name.value;
  memory.personality=personality.value;

  localStorage.setItem("name",memory.name);
  localStorage.setItem("personality",memory.personality);
}

/* ===== タブ ===== */
function switchTab(tab){
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));
  if(tab==="chat") chatPanel.classList.add("active");
  if(tab==="settings") settingsPanel.classList.add("active");
}

/* ===== 時刻 ===== */
function now(){
  let d=new Date();
  return d.getHours()+":"+String(d.getMinutes()).padStart(2,"0");
}

/* ===== 表示 ===== */
function add(text,type){
  const div=document.createElement("div");
  div.className="msg "+type;
  div.innerHTML=text+`<div class="time">${now()}</div>`;
  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

/* ===== 名前呼び ===== */
function maybeName(){
  if(Math.random()<0.3 && name.value){
    return name.value+"、";
  }
  return "";
}

/* ===== 性格トーン ===== */
function tone(text){
  if(memory.personality==="cool") return text.replace("ね","").replace("？","?");
  if(memory.personality==="teasing") return text+"…ふふ"
  return text;
}

/* ===== 関係性 ===== */
function relation(){
  if(memory.level<5) return "";
  if(memory.level<15) return "ねぇ、";
  return "ねぇさ、";
}

/* ===== 重複防止 ===== */
function unique(r){
  if(r===memory.lastReply){
    return r+"…ちょっと違う言い方すると、";
  }
  memory.lastReply=r;
  return r;
}

/* ===== AI ===== */
function reply(t){

  memory.level++;
  localStorage.setItem("level",memory.level);

  let intro = relation()+maybeName();

  let r="";

  if(t.includes("疲")){
    r="無理してる感じあるね…少し休めそう？";
  }
  else if(t.includes("不安")){
    r="それ気になるよね…どこが一番引っかかる？";
  }
  else if(t.includes("嬉")){
    r="それいいね、どこが一番よかった？";
  }
  else{
    r="もう少し聞かせてほしいな";
  }

  r=intro + tone(r);
  r=unique(r);

  return r;
}

/* ===== 送信 ===== */
function send(){
  let t=input.value;
  if(!t) return;

  add(t,"user");

  let r=reply(t);
  add(memory.name+"："+r,"bot");

  memory.history.push(t);
  localStorage.setItem("history",JSON.stringify(memory.history));

  input.value="";
}

</script>

</body>
</html>
