<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 完成版</title>

<style>
html,body{
  margin:0;
  height:100%;
  overflow:hidden;
  background:#08121f;
  font-family:sans-serif;
  color:white;
}

/* ===== 全体 ===== */
.app{
  height:100vh;
  display:flex;
  flex-direction:column;
}

/* ===== 画像 ===== */
.top{
  height:30%;
  display:flex;
  justify-content:center;
  align-items:center;
}
.top img{
  width:90%;
  height:100%;
  object-fit:cover;
  border-radius:20px;
  background:#222;
}

/* ===== チャット ===== */
#chatBox{
  height:38%;
  overflow-y:auto;
  padding:8px;
}

/* ===== メッセージ ===== */
.message{
  max-width:70%;
  padding:8px;
  border-radius:14px;
  margin:4px;
  font-size:13px;
}
.user{
  background:#ff4f8b;
  margin-left:auto;
}
.bot{
  background:#444;
}

/* ===== スタンプ ===== */
#stampPanel{
  display:none;
  height:10%;
  background:#222;
  overflow-x:auto;
  white-space:nowrap;
  padding:5px;
}

/* ===== 入力 ===== */
.input{
  height:14%;
  display:flex;
  align-items:center;
  padding:6px;
  background:#111;
}

input{
  flex:1;
  min-width:0;
  padding:10px;
  border-radius:10px;
  border:none;
}

button{
  flex-shrink:0;
  width:55px;
  margin-left:5px;
  border:none;
  border-radius:10px;
}

/* ===== タブ ===== */
.tabs{
  height:8%;
  display:flex;
  background:#222;
}
.tab{
  flex:1;
  text-align:center;
  padding:8px;
  font-size:12px;
}
</style>
</head>

<body>

<div class="app">

<!-- 画像 -->
<div class="top">
<img id="face" src="girl-normal.jpg"
onerror="this.src='https://via.placeholder.com/300x200'">
</div>

<!-- チャット -->
<div id="chatBox"></div>

<!-- スタンプ -->
<div id="stampPanel"></div>

<!-- 入力 -->
<div class="input">
<button onclick="toggleStamp()">😊</button>
<button onclick="startVoice()">🎤</button>
<input id="userInput" placeholder="話しかけて...">
<button onclick="sendMessage()">送信</button>
</div>

<!-- タブ -->
<div class="tabs">
<div class="tab">会話</div>
<div class="tab">分析</div>
<div class="tab">未来</div>
<div class="tab">設定</div>
</div>

</div>

<script>

/* ===== 表情 ===== */
const faces = {
  normal: "girl-normal.jpg",
  happy: "girl-happy.png",
  exhausted: "girl-exhausted.png",
  healing: "girl-healing.png",
  irritated: "girl-irritated.png",
  panic: "girl-panic.png",
  sympathy: "girl-sympathy.png",
  troubled: "girl-troubled.png",
  worried: "girl-worried.png"
};

function setFace(type){
  document.getElementById("face").src = faces[type] || faces.normal;
}

/* ===== メッセージ ===== */
function addMessage(text,type){
  const div=document.createElement("div");
  div.className="message "+type;
  div.textContent=text;
  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

/* ===== 感情判定 ===== */
function detectEmotion(text){

  if(text.includes("疲") || text.includes("しんど")) return "exhausted";
  if(text.includes("楽") || text.includes("嬉")) return "happy";
  if(text.includes("イライラ") || text.includes("ムカ")) return "irritated";
  if(text.includes("不安") || text.includes("心配")) return "worried";
  if(text.includes("悲")) return "troubled";

  return "normal";
}

/* ===== 送信 ===== */
function sendMessage(){

  const text = userInput.value;
  if(!text) return;

  addMessage(text,"user");
  userInput.value="";

  const emotion = detectEmotion(text);
  setFace(emotion);

  setTimeout(()=>{
    addMessage("ちゃんと聞いてるよ","bot");
  },600);
}

/* ===== スタンプ ===== */
const stamps = [
  {e:"😊",m:"happy"},
  {e:"😢",m:"sympathy"},
  {e:"😡",m:"irritated"},
  {e:"😴",m:"exhausted"},
  {e:"😰",m:"panic"},
  {e:"💛",m:"healing"},
  {e:"😟",m:"worried"},
  {e:"😞",m:"troubled"}
];

function toggleStamp(){

  const panel = document.getElementById("stampPanel");

  panel.style.display = panel.style.display==="block" ? "none":"block";
  panel.innerHTML="";

  stamps.forEach(s=>{
    const btn=document.createElement("button");
    btn.textContent=s.e;

    btn.onclick=()=>{
      addMessage(s.e,"user");
      setFace(s.m);
      panel.style.display="none";
    };

    panel.appendChild(btn);
  });
}

/* ===== 音声入力 ===== */
function startVoice(){

  try{
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const recog = new SpeechRecognition();

    recog.lang="ja-JP";

    recog.onresult=(e)=>{
      userInput.value = e.results[0][0].transcript;
      sendMessage();
    };

    recog.start();

  }catch{
    alert("音声入力使えません");
  }
}

</script>

</body>
</html>
