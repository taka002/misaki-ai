<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 完全安定版</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:#09111f;
  color:white;
}

/* ===== 全体 ===== */
.app{
  display:flex;
  flex-direction:column;
  height:100dvh;
  overflow:hidden;
}

/* ===== 画像 ===== */
.top{
  height:110px;
  flex-shrink:0;
}
.top img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* ===== メイン ===== */
.main{
  flex:1;
  display:flex;
  flex-direction:column;
  min-height:0;
}

/* ===== パネル ===== */
.panel{
  display:none;
  flex:1;
  flex-direction:column;
  min-height:0;
}
.panel.active{
  display:flex;
}

/* ===== チャット ===== */
#chatBox{
  flex:1;
  overflow-y:auto;
  padding:10px;
  display:flex;
  flex-direction:column;
}

.msg{
  max-width:75%;
  padding:10px;
  border-radius:15px;
  margin:6px 0;
}

.user{
  background:#ff4f8b;
  align-self:flex-end;
}

.bot{
  background:#444;
}

.time{
  font-size:10px;
  opacity:0.6;
}

/* ===== 入力 ===== */
.input{
  flex-shrink:0;
  display:flex;
  padding:6px;
  gap:6px;
  background:#111;
}

input{
  flex:1;
  min-width:0;
  padding:10px;
}

button{
  flex-shrink:0;
  padding:10px;
}

/* ===== タブ ===== */
.tabs{
  height:50px;
  display:flex;
  flex-shrink:0;
  background:#222;
}

.tab{
  flex:1;
  text-align:center;
  line-height:50px;
}

/* ===== 分析・未来 ===== */
.box{
  padding:15px;
}
</style>
</head>

<body>

<div class="app">

<!-- 上：画像 -->
<div class="top">
<img src="girl-normal.jpg">
</div>

<!-- 中央 -->
<div class="main">

<!-- 会話 -->
<div id="chatPanel" class="panel active">
<div id="chatBox"></div>

<div class="input">
<input id="input">
<button onclick="send()">送信</button>
</div>
</div>

<!-- 分析 -->
<div id="analysisPanel" class="panel">
<div class="box" id="analysisContent">まだデータなし</div>
</div>

<!-- 未来 -->
<div id="futurePanel" class="panel">
<div class="box" id="futureContent">未来予測はここに表示</div>
</div>

<!-- 設定 -->
<div id="settingsPanel" class="panel">
<div class="box">
名前<input id="name"><br><br>
<button onclick="save()">保存</button>
</div>
</div>

</div>

<!-- 下タブ -->
<div class="tabs">
<div class="tab" onclick="switchTab('chat')">会話</div>
<div class="tab" onclick="switchTab('analysis')">分析</div>
<div class="tab" onclick="switchTab('future')">未来</div>
<div class="tab" onclick="switchTab('settings')">設定</div>
</div>

</div>

<script>

/* ===== 状態 ===== */
let memory={
  name:localStorage.getItem("name")||"美咲",
  history:JSON.parse(localStorage.getItem("history")||"[]")
};

name.value=memory.name;

/* ===== タブ ===== */
function switchTab(tab){
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));

  if(tab==="chat") chatPanel.classList.add("active");
  if(tab==="analysis") analysisPanel.classList.add("active");
  if(tab==="future") futurePanel.classList.add("active");
  if(tab==="settings") settingsPanel.classList.add("active");
}

/* ===== 保存 ===== */
function save(){
  memory.name=name.value;
  localStorage.setItem("name",memory.name);
}

/* ===== 時刻 ===== */
function now(){
  let d=new Date();
  return d.getHours()+":"+String(d.getMinutes()).padStart(2,"0");
}

/* ===== 表示 ===== */
function add(text,type){
  const div=document.createElement("div");
  div.className="msg "+type;
  div.innerHTML=text+`<div class="time">${now()}</div>`;
  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

/* ===== AI返答 ===== */
function reply(t){

  if(t.includes("疲")){
    return "ちょっと無理してる感じあるね…少し休めそう？";
  }

  if(t.includes("不安")){
    return "それ気になるよね…どこが一番引っかかる？";
  }

  return "ちゃんと聞いてるよ、もう少し教えて？";
}

/* ===== 分析 ===== */
function analyze(){
  let text=memory.history.join(" ");

  let fatigue=text.includes("疲")?80:20;

  analysisContent.innerHTML=`
    疲労度：${fatigue}
  `;
}

/* ===== 未来 ===== */
function future(){
  let text=memory.history.join(" ");

  if(text.includes("疲")){
    futureContent.innerHTML=`
    A：休む → 回復<br>
    B：続ける → 悪化
    `;
  }else{
    futureContent.innerHTML="まだ予測できません";
  }
}

/* ===== 送信 ===== */
function send(){
  let t=input.value;
  if(!t) return;

  add(t,"user");

  let r=reply(t);
  add(memory.name+"："+r,"bot");

  memory.history.push(t);
  localStorage.setItem("history",JSON.stringify(memory.history));

  analyze();
  future();

  input.value="";
}

</script>

</body>
</html>
