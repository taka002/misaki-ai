<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI</title>

<style>
*{box-sizing:border-box;}
body{
  margin:0;
  font-family:"Hiragino Sans","Yu Gothic",sans-serif;
  background:linear-gradient(to bottom,#2b314d,#111827);
  color:white;
  display:flex;
  flex-direction:column;
  height:100vh;
  overflow:hidden;
}

.top{
  flex:0 0 34%;
  display:flex;
  justify-content:center;
  align-items:center;
  padding:16px 12px 8px;
  position:relative;
}

.top img{
  width:88%;
  max-width:430px;
  max-height:100%;
  object-fit:cover;
  border-radius:30px;
  border:3px solid rgba(255,255,255,0.14);
  box-shadow:0 14px 30px rgba(0,0,0,0.35);
  background:rgba(255,255,255,0.03);
}

.settings-open{
  position:absolute;
  top:18px;
  right:18px;
  border:none;
  background:rgba(255,255,255,0.16);
  color:white;
  font-size:24px;
  width:60px;
  height:60px;
  border-radius:50%;
  cursor:pointer;
  backdrop-filter:blur(8px);
}

.chat{
  flex:1;
  overflow-y:auto;
  padding:10px 14px 20px;
  display:flex;
  flex-direction:column;
  gap:12px;
}

.msg{
  max-width:84%;
  padding:16px 18px;
  border-radius:24px;
  font-size:18px;
  line-height:1.8;
  white-space:pre-wrap;
  word-break:break-word;
}

.bot{
  align-self:flex-start;
  background:rgba(255,255,255,0.12);
  border-bottom-left-radius:8px;
}

.user{
  align-self:flex-end;
  background:linear-gradient(135deg,#ff7eb3,#ff4f8b);
  border-bottom-right-radius:8px;
}

.status{
  font-size:13px;
  opacity:0.8;
  padding:0 16px 8px;
}

.input{
  display:flex;
  gap:10px;
  padding:12px;
  background:rgba(0,0,0,0.25);
  border-top:1px solid rgba(255,255,255,0.08);
}

.input input{
  flex:1;
  padding:16px 18px;
  border-radius:18px;
  border:none;
  font-size:18px;
  outline:none;
  background:rgba(255,255,255,0.96);
  color:#222;
}

.btn{
  width:72px;
  height:72px;
  border:none;
  border-radius:22px;
  background:rgba(255,255,255,0.12);
  color:white;
  font-size:30px;
}

.send{
  width:120px;
  background:linear-gradient(135deg,#ff7eb3,#ff4f8b);
  font-size:28px;
  font-weight:bold;
}

.speaking{
  animation:pulseTalk 0.75s infinite ease-in-out;
}

@keyframes pulseTalk{
  0%{transform:scale(1) translateY(0px);}
  25%{transform:scale(1.01) translateY(-1px);}
  50%{transform:scale(1.02) translateY(0px);}
  75%{transform:scale(1.01) translateY(-1px);}
  100%{transform:scale(1) translateY(0);}
}
</style>
</head>

<body>

<div class="top">
  <img id="girl" src="girl-normal.jpg" alt="美咲">
  <button class="settings-open" onclick="unlockVoice()">⚙</button>
</div>

<div class="chat" id="chat"></div>
<div class="status" id="status">🔇 最初に右上⚙を1回押すと音声が有効になります</div>

<div class="input">
  <input id="text" placeholder="何か話してみて…">
  <button class="btn" onclick="mic()">🎤</button>
  <button class="btn" onclick="unlockVoice()">🎧</button>
  <button class="btn send" onclick="send()">送信</button>
</div>

<script>
const chat = document.getElementById("chat");
const text = document.getElementById("text");
const girl = document.getElementById("girl");
const statusBar = document.getElementById("status");

let voiceReady = false;
let availableVoices = [];

const faces = {
  normal: "girl-normal.jpg",
  worried: "girl-worried.png",
  sympathy: "girl-sympathy.png",
  troubled: "girl-troubled.png",
  healing: "girl-healing.png",
  happy: "girl-happy.png",
  irritated: "girl-irritated.png",
  panic: "girl-panic.png",
  exhausted: "girl-exhausted.png"
};

function setFace(name="normal"){
  girl.src = faces[name] || faces.normal;
}

function add(text, type="bot"){
  const d = document.createElement("div");
  d.className = "msg " + type;
  d.innerText = text;
  chat.appendChild(d);
  chat.scrollTop = chat.scrollHeight;
}

function setStatus(t){
  statusBar.innerText = t;
}

function loadVoices(){
  if(!("speechSynthesis" in window)) return;
  availableVoices = speechSynthesis.getVoices();
}
if("speechSynthesis" in window){
  loadVoices();
  speechSynthesis.onvoiceschanged = loadVoices;
}

function pickJapaneseVoice(){
  if(!availableVoices.length) return null;
  return availableVoices.find(v => v.lang && v.lang.includes("ja")) || null;
}

function unlockVoice(){
  try{
    speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance("音声の準備ができたよ");
    u.lang = "ja-JP";
    const v = pickJapaneseVoice();
    if(v) u.voice = v;
    u.onstart = ()=> setStatus("🔊 音声ON");
    u.onend = ()=> setStatus("準備OK");
    speechSynthesis.speak(u);
    voiceReady = true;
  }catch(e){
    setStatus("音声の開始に失敗");
  }
}

function speak(t){
  if(!voiceReady){
    setStatus("⚠ 右上⚙か🎧を1回押して音声を有効化してね");
    return;
  }

  try{
    speechSynthesis.cancel();

    const clean = t.replace(/\n/g,"。").replace(/😊|😢|😌|🥺|✨|💦|♡/g,"");
    const u = new SpeechSynthesisUtterance(clean);
    u.lang = "ja-JP";
    u.rate = 0.95;
    u.pitch = 1.08;
    u.volume = 1;

    const v = pickJapaneseVoice();
    if(v) u.voice = v;

    u.onstart = ()=>{
      girl.classList.add("speaking");
      setStatus("話してるよ…");
    };
    u.onend = ()=>{
      girl.classList.remove("speaking");
      setStatus("準備OK");
    };
    u.onerror = ()=>{
      girl.classList.remove("speaking");
      setStatus("音声再生できませんでした");
    };

    speechSynthesis.speak(u);
  }catch(e){
    girl.classList.remove("speaking");
    setStatus("音声エラー");
  }
}

function replyGen(t){
  if(t.includes("疲れ") || t.includes("つかれ") || t.includes("しんど")) {
    setFace("worried");
    return "大丈夫？かなり頑張ってきた感じするよ。\n今日は何が一番しんどかった？";
  }
  if(t.includes("寂しい") || t.includes("さみしい") || t.includes("悲しい")) {
    setFace("sympathy");
    return "そっか…つらかったね。\nここでちゃんと受け止めるよ。";
  }
  if(t.includes("イライラ") || t.includes("ムカつく") || t.includes("腹立つ")) {
    setFace("irritated");
    return "それはかなりイラッとしたよね。\n何が一番ひっかかった？";
  }
  if(t.includes("焦る") || t.includes("やばい") || t.includes("どうしよう")) {
    setFace("panic");
    return "かなり焦ってる感じあるね。\nまず一番急いでることだけ教えて？";
  }
  if(t.includes("癒して") || t.includes("甘えたい")) {
    setFace("healing");
    return "いいよ😊\n今日は少し力を抜いていい日だよ。";
  }
  if(t.includes("好き") || t.includes("嬉しい") || t.includes("うれしい")) {
    setFace("happy");
    return "ふふ😊\nそういうの嬉しいな。";
  }

  setFace("normal");
  return "うん、ちゃんと聞いてるよ。\nもう少し詳しく話せそう？";
}

function send(){
  const v = text.value.trim();
  if(!v) return;

  add(v, "user");
  text.value = "";

  const reply = replyGen(v);
  add(reply, "bot");
  speak(reply);
}

text.addEventListener("keypress", e=>{
  if(e.key === "Enter") send();
});

function mic(){
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

  if(!SpeechRecognition){
    alert("このブラウザではマイク入力が使えません。\nChromeで開くと動きやすいです。");
    return;
  }

  const rec = new SpeechRecognition();
  rec.lang = "ja-JP";
  rec.interimResults = false;
  rec.maxAlternatives = 1;

  setStatus("聞き取り中…");

  rec.onresult = e=>{
    text.value = e.results[0][0].transcript;
    setStatus("音声入力OK");
  };

  rec.onerror = ()=>{
    setStatus("マイク入力失敗");
  };

  rec.onend = ()=>{
    setStatus("準備OK");
  };

  rec.start();
}

add("美咲だよ😊\n今日はどんな感じだった？");
</script>

</body>
</html>
