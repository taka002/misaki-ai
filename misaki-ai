        },
        body: JSON.stringify({
          model: "gpt-4o-mini",
          messages,
          temperature: 0.9
        })
      });

      if (!res.ok) {
        throw new Error("GPT API error");
      }

      const data = await res.json();
      const raw = data.choices?.[0]?.message?.content?.trim() || "うまく言葉が出なかったけど、ちゃんとここにいるよ。";
      return applyEmotionFromReply(raw);
    }

    function applyEmotionFromReply(text) {
      let mood = "normal";
      let cleaned = text;

      const tags = ["happy", "healing", "worried", "sympathy", "troubled", "irritated", "panic", "exhausted", "normal"];

      for (const tag of tags) {
        const pattern = new RegExp(`^\\[${tag}\\]\\s*`, "i");
        if (pattern.test(cleaned)) {
          mood = tag;
          cleaned = cleaned.replace(pattern, "");
          break;
        }
      }

      memory.mood = mood;
      saveMemory();
      setFace(mood);

      return cleaned;
    }

    function getVoiceStyleByMood(mood) {
      switch (mood) {
        case "happy":
          return { rate: 0.97, pitch: 1.18 };
        case "healing":
          return { rate: 0.87, pitch: 1.12 };
        case "sympathy":
          return { rate: 0.86, pitch: 1.06 };
        case "exhausted":
          return { rate: 0.84, pitch: 1.02 };
        case "panic":
          return { rate: 0.91, pitch: 1.10 };
        case "irritated":
          return { rate: 0.90, pitch: 0.98 };
        case "troubled":
          return { rate: 0.88, pitch: 1.03 };
        default:
          return { rate: 0.92, pitch: 1.08 };
      }
    }

    function speakText(text, isWelcome = false) {
      if (!voiceEnabled) return;

      if (!("speechSynthesis" in window)) {
        setStatus("この環境では音声非対応");
        return;
      }

      try {
        const synth = window.speechSynthesis;
        synth.cancel();

        const cleanText = text
          .replace(/\n/g, "。")
          .replace(/😊|♡|✨|😌|😢|🥺|😳|💦|💭/g, "")
          .replace(/…/g, "、")
          .trim();

        if (!cleanText) return;

        const delay = isWelcome ? 600 : 220;

        setTimeout(() => {
          try {
            const utterance = new SpeechSynthesisUtterance(cleanText);
            utterance.lang = "ja-JP";

            const voiceStyle = getVoiceStyleByMood(memory.mood);
            utterance.rate = voiceStyle.rate;
            utterance.pitch = voiceStyle.pitch;
            utterance.volume = 1.0;

            const voices = synth.getVoices();
            let preferredVoice =
              voices.find(v => v.lang && v.lang.includes("ja") && v.name.includes("Google")) ||
              voices.find(v => v.lang && v.lang.includes("ja"));

            if (preferredVoice) {
              utterance.voice = preferredVoice;
            }

            utterance.onstart = () => {
              startSpeakingAnimation();
              setStatus("話してるよ…");
            };

            utterance.onend = () => {
              stopSpeakingAnimation();
              setStatus("準備OK");
            };

            utterance.onerror = () => {
              stopSpeakingAnimation();
              setStatus("音声再生できませんでした");
            };

            synth.speak(utterance);
          } catch (err) {
            stopSpeakingAnimation();
            setStatus("音声エラー");
          }
        }, delay);

      } catch (e) {
        stopSpeakingAnimation();
        setStatus("音声エラー");
      }
    }

    function stopVoiceInput() {
      try {
        if (recognition) recognition.stop();
      } catch (e) {}
      isListening = false;
      micBtn.classList.remove("listening");
      setStatus("マイク停止");
    }

    function startVoiceInput() {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

      if (!SpeechRecognition) {
        alert("この環境ではマイク入力が使えません。\n\nおすすめ:\n・Chromeで開く\n・GitHub Pagesで開く\n・HTTPSで開く");
        return;
      }

      if (isListening) {
        stopVoiceInput();
        return;
      }

      try {
        recognition = new SpeechRecognition();
        recognition.lang = "ja-JP";
        recognition.interimResults = false;
        recognition.continuous = false;
        recognition.maxAlternatives = 1;

        isListening = true;
        micBtn.classList.add("listening");
        setStatus("🎤 聞き取り中…話してください");

        recognition.onresult = (event) => {
          const transcript = event.results[0][0].transcript || "";
          userInput.value = transcript.trim();
          setStatus("音声入力OK → 送信中");
          setTimeout(() => {
            sendMessage();
          }, 350);
        };

        recognition.onerror = (event) => {
          if (event.error === "not-allowed") {
            setStatus("マイク許可が必要です");
            alert("マイクが拒否されています。\n\nChromeの設定でこのページのマイクを許可してください。");
          } else if (event.error === "no-speech") {
            setStatus("声が聞こえなかったみたい");
          } else if (event.error === "audio-capture") {
            setStatus("マイクが使えません");
          } else if (event.error === "network") {
            setStatus("音声認識ネットワークエラー");
          } else {
            setStatus("マイク入力失敗");
          }

          isListening = false;
          micBtn.classList.remove("listening");
        };

        recognition.onend = () => {
          isListening = false;
          micBtn.classList.remove("listening");
          if (statusBar.textContent.includes("聞き取り中")) {
            setStatus("準備OK");
          }
        };

        recognition.start();
      } catch (e) {
        isListening = false;
        micBtn.classList.remove("listening");
        setStatus("マイク起動失敗");
      }
    }

    settingsModal.addEventListener("click", (e) => {
      if (e.target === settingsModal) {
        closeSettings();
      }
    });
  </script>
</body>
