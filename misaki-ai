<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>美咲AI 完全版</title>

  <style>
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      width: 100%;
      overflow: hidden;
      font-family: "Hiragino Sans", "Yu Gothic", sans-serif;
      transition: background 0.45s ease;
    }

    body {
      background: linear-gradient(to bottom, #2b314d, #09111f);
      color: white;
      display: flex;
      flex-direction: column;
    }

    .app {
      width: 100%;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ===== 上画像 ===== */
    .top-character {
      flex: 0 0 34vh;
      min-height: 240px;
      max-height: 360px;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 14px 14px 8px;
      position: relative;
    }

    .top-character img {
      width: min(92vw, 520px);
      height: 100%;
      object-fit: cover;
      border-radius: 28px;
      border: 3px solid rgba(255,255,255,0.14);
      box-shadow: 0 16px 34px rgba(0,0,0,0.38);
      background: rgba(255,255,255,0.03);
      transition: all 0.28s ease;
      display: block;
    }

    .settings-open {
      position: absolute;
      top: 18px;
      right: 18px;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      border: none;
      font-size: 32px;
      background: rgba(255,255,255,0.16);
      color: white;
      backdrop-filter: blur(8px);
      box-shadow: 0 10px 26px rgba(0,0,0,0.22);
      cursor: pointer;
      z-index: 5;
    }

    /* ===== 会話エリア ===== */
    .chat-section {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      padding: 0 12px;
      overflow: hidden;
    }

    #chatBox {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 6px 2px 12px;
      scroll-behavior: smooth;
    }

    .message {
      max-width: 86%;
      padding: 16px 18px;
      border-radius: 24px;
      font-size: clamp(16px, 2.4vw, 18px);
      line-height: 1.95;
      white-space: pre-wrap;
      word-break: break-word;
      animation: fadeIn 0.22s ease;
    }

    .bot {
      align-self: flex-start;
      background: rgba(255,255,255,0.11);
      border-bottom-left-radius: 10px;
      color: #fff;
      box-shadow: 0 8px 18px rgba(0,0,0,0.12);
    }

    .user {
      align-self: flex-end;
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      border-bottom-right-radius: 10px;
      color: white;
      box-shadow: 0 8px 18px rgba(255,93,151,0.25);
    }

    .typing {
      opacity: 0.72;
      font-style: italic;
    }

    /* ===== ステータス ===== */
    .status-bar {
      flex-shrink: 0;
      font-size: 13px;
      opacity: 0.82;
      padding: 0 16px 8px;
      min-height: 22px;
    }

    /* ===== 入力エリア ===== */
    .input-area {
      flex-shrink: 0;
      display: grid;
      grid-template-columns: 1fr 88px 112px;
      gap: 10px;
      padding: 12px;
      background: rgba(0,0,0,0.24);
      border-top: 1px solid rgba(255,255,255,0.08);
      align-items: center;
    }

    input[type="text"], input[type="password"] {
      width: 100%;
      min-width: 0;
      padding: 16px 18px;
      border-radius: 20px;
      border: none;
      outline: none;
      font-size: 18px;
      background: rgba(255,255,255,0.96);
      color: #222;
    }

    .mic-btn, .send-btn {
      border: none;
      border-radius: 24px;
      color: white;
      cursor: pointer;
      font-weight: bold;
      box-shadow: 0 12px 24px rgba(0,0,0,0.16);
    }

    .mic-btn {
      width: 88px;
      height: 84px;
      font-size: 34px;
      background: rgba(255,255,255,0.12);
    }

    .mic-btn.listening {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
      box-shadow: 0 0 0 8px rgba(122,105,255,0.18);
    }

    .send-btn {
      width: 112px;
      height: 84px;
      font-size: 22px;
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      box-shadow: 0 14px 28px rgba(255,79,139,0.28);
    }

    .send-btn:active,
    .mic-btn:active,
    .settings-open:active {
      transform: scale(0.97);
    }

    #chatBox::-webkit-scrollbar {
      width: 6px;
    }

    #chatBox::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.18);
      border-radius: 999px;
    }

    /* ===== アニメ ===== */
    .speaking {
      animation: pulseTalk 0.75s infinite ease-in-out;
    }

    .face-change {
      animation: facePop 0.25s ease;
    }

    @keyframes pulseTalk {
      0%   { transform: scale(1) translateY(0px); }
      25%  { transform: scale(1.01) translateY(-1px); }
      50%  { transform: scale(1.02) translateY(0px); }
      75%  { transform: scale(1.01) translateY(-1px); }
      100% { transform: scale(1) translateY(0); }
    }

    @keyframes facePop {
      0%   { transform: scale(0.97); opacity: 0.75; }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ===== 設定モーダル ===== */
    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 999;
      padding: 18px;
    }

    .modal.show {
      display: flex;
    }

    .modal-box {
      width: 100%;
      max-width: 420px;
      max-height: 88vh;
      overflow-y: auto;
      background: #2a2236;
      border-radius: 28px;
      padding: 22px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.45);
    }

    .modal-title {
      font-size: 26px;
      font-weight: bold;
      color: #ffd1e6;
      margin-bottom: 18px;
    }

    .setting-row {
      margin-bottom: 16px;
    }

    .setting-label {
      font-size: 16px;
      opacity: 0.95;
      margin-bottom: 8px;
      display: block;
      line-height: 1.6;
    }

    .setting-input {
      width: 100%;
      padding: 16px;
      border-radius: 18px;
      border: none;
      font-size: 18px;
      outline: none;
    }

    .toggle-btn, .danger-btn, .close-btn, .save-btn {
      width: 100%;
      padding: 16px;
      border: none;
      border-radius: 18px;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 10px;
    }

    .toggle-btn {
      background: #5f5470;
      color: white;
    }

    .danger-btn {
      background: #8a3d57;
      color: white;
    }

    .save-btn {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
      color: white;
    }

    .close-btn {
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      color: white;
    }

    .hint {
      font-size: 13px;
      opacity: 0.72;
      margin-top: 6px;
      line-height: 1.6;
    }

    @media (max-width: 430px) {
      .top-character {
        flex: 0 0 32vh;
        min-height: 220px;
      }

      .settings-open {
        width: 68px;
        height: 68px;
        font-size: 28px;
      }

      .input-area {
        grid-template-columns: 1fr 84px 106px;
      }

      .mic-btn {
        width: 84px;
        height: 80px;
      }

      .send-btn {
        width: 106px;
        height: 80px;
      }
    }
  </style>
</head>
<body>
  <div class="app">

    <!-- 上 -->
    <div class="top-character">
      <img id="mainGirl" src="girl-normal.jpg" alt="美咲">
      <button class="settings-open" onclick="openSettings()">⚙</button>
    </div>

    <!-- 会話 -->
    <div class="chat-section">
      <div id="chatBox"></div>
    </div>

    <!-- 状態 -->
    <div class="status-bar" id="statusBar">準備OK</div>

    <!-- 下入力 -->
    <div class="input-area">
      <input type="text" id="userInput" placeholder="何か話してみて…" />
      <button class="mic-btn" id="micBtn" onclick="startVoiceInput()">🎤</button>
      <button class="send-btn" onclick="sendMessage()">送信</button>
    </div>
  </div>

  <!-- 設定 -->
  <div class="modal" id="settingsModal">
    <div class="modal-box">
      <div class="modal-title">設定</div>

      <div class="setting-row">
        <label class="setting-label">あなたの呼び名（時々呼ぶ）</label>
        <input class="setting-input" id="userNameInput" placeholder="だいすけ">
      </div>

      <div class="setting-row">
        <label class="setting-label">キャラ名</label>
        <input class="setting-input" id="nameInput" placeholder="美咲">
      </div>

      <div class="setting-row">
        <label class="setting-label">OpenAI APIキー</label>
        <input class="setting-input" id="apiKeyInput" type="password" placeholder="sk-..." />
        <div class="hint">GPTを使う時だけ必要。使わないなら空でもOK。</div>
      </div>

      <button class="save-btn" onclick="saveSettings()">💾 保存する</button>
      <button class="toggle-btn" id="gptToggle" onclick="toggleGPT()">🤖 GPT OFF</button>
      <button class="toggle-btn" id="voiceToggle" onclick="toggleVoice()">🔊 音声ON</button>
      <button class="danger-btn" onclick="resetMemory()">記憶をリセット</button>
      <button class="close-btn" onclick="closeSettings()">閉じる</button>
    </div>
  </div>

  <script>
    const chatBox = document.getElementById("chatBox");
    const userInput = document.getElementById("userInput");
    const mainGirl = document.getElementById("mainGirl");
    const settingsModal = document.getElementById("settingsModal");
    const voiceToggleBtn = document.getElementById("voiceToggle");
    const gptToggleBtn = document.getElementById("gptToggle");
    const nameInput = document.getElementById("nameInput");
    const userNameInput = document.getElementById("userNameInput");
    const apiKeyInput = document.getElementById("apiKeyInput");
    const statusBar = document.getElementById("statusBar");
    const micBtn = document.getElementById("micBtn");

    let voiceEnabled = localStorage.getItem("voiceEnabled") !== "false";
    let gptEnabled = localStorage.getItem("gptEnabled") === "true";
    let availableVoices = [];
    let recognition = null;
    let isListening = false;
    let isSpeaking = false;
    let lastBotReply = "";

    let memory = {
      characterName: localStorage.getItem("characterName") || "美咲",
      userName: localStorage.getItem("userNickName") || "",
      apiKey: localStorage.getItem("openai_api_key") || "",
      mood: localStorage.getItem("hostess_mood") || "",
      topic: localStorage.getItem("hostess_topic") || "",
      lastMessage: localStorage.getItem("hostess_lastMessage") || "",
      visitCount: parseInt(localStorage.getItem("hostess_visitCount") || "0", 10),
      chatHistory: JSON.parse(localStorage.getItem("hostess_chatHistory") || "[]"),

      currentFeeling: localStorage.getItem("hostess_currentFeeling") || "",
      currentNeed: localStorage.getItem("hostess_currentNeed") || "",
      unresolvedTopic: localStorage.getItem("hostess_unresolvedTopic") || "",
      lastBotQuestion: localStorage.getItem("hostess_lastBotQuestion") || "",

      // 強化メモリ
      conversationMode: localStorage.getItem("hostess_conversationMode") || "normal",
      silenceCount: parseInt(localStorage.getItem("hostess_silenceCount") || "0", 10),
      lastSummary: localStorage.getItem("hostess_lastSummary") || "",
      lastQuestionType: localStorage.getItem("hostess_lastQuestionType") || "",
      speakingStyle: localStorage.getItem("hostess_speakingStyle") || "neutral",
      emotionalTrend: localStorage.getItem("hostess_emotionalTrend") || "",

      personalityProfile: JSON.parse(localStorage.getItem("hostess_personalityProfile") || `{
        "talkStyle":"neutral",
        "replyPace":"soft",
        "warmth":"gentle",
        "questionDepth":"light",
        "preferredLength":"medium"
      }`)
    };

    memory.visitCount += 1;
    localStorage.setItem("hostess_visitCount", memory.visitCount);

    nameInput.value = memory.characterName;
    userNameInput.value = memory.userName;
    apiKeyInput.value = memory.apiKey;

    updateVoiceButton();
    updateGPTButton();

    const faceImages = {
      normal: "girl-normal.jpg",
      worried: "girl-worried.png",
      sympathy: "girl-sympathy.png",
      troubled: "girl-troubled.png",
      healing: "girl-healing.png",
      happy: "girl-happy.png",
      irritated: "girl-irritated.png",
      panic: "girl-panic.png",
      exhausted: "girl-exhausted.png"
    };

    const moodBackgrounds = {
      normal: "linear-gradient(to bottom, #2b314d, #09111f)",
      worried: "linear-gradient(to bottom, #3f4c6b, #151d2b)",
      sympathy: "linear-gradient(to bottom, #4a3b60, #161626)",
      troubled: "linear-gradient(to bottom, #4c4b67, #151b28)",
      healing: "linear-gradient(to bottom, #5b4767, #171629)",
      happy: "linear-gradient(to bottom, #485f8b, #12203b)",
      irritated: "linear-gradient(to bottom, #5f3a4f, #1a111b)",
      panic: "linear-gradient(to bottom, #5a5068, #181724)",
      exhausted: "linear-gradient(to bottom, #4b5165, #121926)"
    };

    function setStatus(text) {
      statusBar.textContent = text;
    }

    function setFace(type = "normal") {
      const src = faceImages[type] || faceImages.normal;
      mainGirl.src = src;
      document.body.style.background = moodBackgrounds[type] || moodBackgrounds.normal;

      mainGirl.classList.remove("face-change");
      void mainGirl.offsetWidth;
      mainGirl.classList.add("face-change");
    }

    function startSpeakingAnimation() {
      mainGirl.classList.add("speaking");
      isSpeaking = true;
    }

    function stopSpeakingAnimation() {
      mainGirl.classList.remove("speaking");
      isSpeaking = false;
    }

    function openSettings() {
      nameInput.value = memory.characterName || "美咲";
      userNameInput.value = memory.userName || "";
      apiKeyInput.value = memory.apiKey || "";
      settingsModal.classList.add("show");
    }

    function closeSettings() {
      settingsModal.classList.remove("show");
    }

    function saveSettings() {
      memory.characterName = nameInput.value.trim() || "美咲";
      memory.userName = userNameInput.value.trim();
      memory.apiKey = apiKeyInput.value.trim();

      localStorage.setItem("characterName", memory.characterName);
      localStorage.setItem("userNickName", memory.userName);
      localStorage.setItem("openai_api_key", memory.apiKey);

      addMessage("設定を保存したよ😊", "bot");
      setStatus("設定を保存しました");
      closeSettings();
    }

    function toggleVoice() {
      voiceEnabled = !voiceEnabled;
      localStorage.setItem("voiceEnabled", voiceEnabled);
      updateVoiceButton();

      if (!voiceEnabled && ("speechSynthesis" in window)) {
        window.speechSynthesis.cancel();
        stopSpeakingAnimation();
      }
    }

    function toggleGPT() {
      gptEnabled = !gptEnabled;
      localStorage.setItem("gptEnabled", gptEnabled);
      updateGPTButton();
      setStatus(gptEnabled ? "GPT接続ON" : "GPT接続OFF");
    }

    function updateVoiceButton() {
      voiceToggleBtn.textContent = voiceEnabled ? "🔊 音声ON" : "🔇 音声OFF";
    }

    function updateGPTButton() {
      gptToggleBtn.textContent = gptEnabled ? "🤖 GPT ON" : "🤖 GPT OFF";
    }

    function resetMemory() {
      [
        "hostess_mood",
        "hostess_topic",
        "hostess_lastMessage",
        "hostess_visitCount",
        "hostess_chatHistory",
        "hostess_currentFeeling",
        "hostess_currentNeed",
        "hostess_unresolvedTopic",
        "hostess_lastBotQuestion",
        "hostess_conversationMode",
        "hostess_silenceCount",
        "hostess_lastSummary",
        "hostess_lastQuestionType",
        "hostess_speakingStyle",
        "hostess_emotionalTrend",
        "hostess_personalityProfile"
      ].forEach(k => localStorage.removeItem(k));

      memory.mood = "";
      memory.topic = "";
      memory.lastMessage = "";
      memory.visitCount = 1;
      memory.chatHistory = [];
      memory.currentFeeling = "";
      memory.currentNeed = "";
      memory.unresolvedTopic = "";
      memory.lastBotQuestion = "";
      memory.conversationMode = "normal";
      memory.silenceCount = 0;
      memory.lastSummary = "";
      memory.lastQuestionType = "";
      memory.speakingStyle = "neutral";
      memory.emotionalTrend = "";
      memory.personalityProfile = {
        talkStyle: "neutral",
        replyPace: "soft",
        warmth: "gentle",
        questionDepth: "light",
        preferredLength: "medium"
      };

      addMessage("記憶をリセットしたよ😊\nまた最初からゆっくり話そう。", "bot");
      setFace("healing");
      setStatus("記憶をリセットしました");
      closeSettings();
    }

    function loadVoices() {
      if (!("speechSynthesis" in window)) return;
      availableVoices = window.speechSynthesis.getVoices();
    }

    if ("speechSynthesis" in window) {
      loadVoices();
      window.speechSynthesis.onvoiceschanged = loadVoices;
    }

    document.body.addEventListener("click", unlockSpeech, { once: false });
    document.body.addEventListener("touchstart", unlockSpeech, { once: false });

    function unlockSpeech() {
      try {
        if (!("speechSynthesis" in window)) return;
        const synth = window.speechSynthesis;
        const u = new SpeechSynthesisUtterance(" ");
        u.volume = 0;
        synth.speak(u);
      } catch (e) {}
    }

    setTimeout(() => {
      setFace("normal");
      botReply(getWelcomeMessage(), true);
    }, 700);

    function getWelcomeMessage() {
      const name = memory.characterName || "美咲";
      const user = memory.userName ? `${memory.userName}さん、` : "";

      if (memory.visitCount >= 2 && memory.currentFeeling === "tired") {
        return `${user}${name}だよ😊\n前もちょっとしんどそうだったよね。\n今日は昨日よりきつい感じある？`;
      }

      if (memory.visitCount >= 2 && memory.currentFeeling === "anxious") {
        return `${user}${name}だよ😊\n前もちょっと不安そうだったよね。\n今日は少し落ち着いてる？`;
      }

      if (memory.visitCount >= 2 && memory.currentFeeling === "sad") {
        return `${user}${name}だよ😊\n前もちょっと心が沈んでる感じあったよね。\n今日はどんな感じ？`;
      }

      return `${user}${name}だよ😊\n今日はどんな感じだった？`;
    }

    function addMessage(text, sender, extraClass = "") {
      const msg = document.createElement("div");
      msg.className = `message ${sender} ${extraClass}`;
      msg.textContent = text;
      chatBox.appendChild(msg);
      chatBox.scrollTop = chatBox.scrollHeight;
      return msg;
    }

    function botReply(text, isWelcome = false) {
      lastBotReply = text;
      addMessage(text, "bot");
      saveChat("assistant", text);
      speakText(text, isWelcome);
    }

    async function sendMessage() {
      const text = userInput.value.trim();
      if (!text) return;

      if (window.speechSynthesis) {
        window.speechSynthesis.cancel();
      }
      stopSpeakingAnimation();

      addMessage(text, "user");
      saveChat("user", text);
      userInput.value = "";

      const typingMsg = addMessage("…入力中", "bot", "typing");

      try {
        let reply = "";

        if (gptEnabled && memory.apiKey) {
          setStatus("GPTで考え中…");
          reply = await generateGPTReply(text);
        } else {
          setStatus("寄り添い返答中…");
          reply = generateLocalReply(text);
        }

        typingMsg.remove();
        botReply(reply);
        setStatus("準備OK");
      } catch (e) {
        console.error(e);
        typingMsg.remove();
        const fallback = generateLocalReply(text);
        botReply(fallback);
        setStatus("GPT失敗 → ローカル返答");
      }
    }

    userInput.addEventListener("keypress", e => {
      if (e.key === "Enter") sendMessage();
    });

    function saveChat(role, content) {
      memory.chatHistory.push({ role, content });
      if (memory.chatHistory.length > 24) {
        memory.chatHistory = memory.chatHistory.slice(-24);
      }
      localStorage.setItem("hostess_chatHistory", JSON.stringify(memory.chatHistory));
    }

    function rememberUserInfo(text, lower) {
      memory.lastMessage = text;

      if (containsAny(lower, ["仕事", "会社", "上司", "職場", "残業"])) {
        memory.topic = "work";
      } else if (containsAny(lower, ["家族", "子ども", "娘", "息子"])) {
        memory.topic = "family";
      } else if (containsAny(lower, ["不安", "眠れない", "寝れない"])) {
        memory.topic = "anxiety";
      } else if (containsAny(lower, ["体調", "病院", "不調"])) {
        memory.topic = "health";
      }

      saveMemory();
    }

    function saveMemory() {
      localStorage.setItem("hostess_mood", memory.mood || "");
      localStorage.setItem("hostess_topic", memory.topic || "");
      localStorage.setItem("hostess_lastMessage", memory.lastMessage || "");
      localStorage.setItem("hostess_currentFeeling", memory.currentFeeling || "");
      localStorage.setItem("hostess_currentNeed", memory.currentNeed || "");
      localStorage.setItem("hostess_unresolvedTopic", memory.unresolvedTopic || "");
      localStorage.setItem("hostess_lastBotQuestion", memory.lastBotQuestion || "");
      localStorage.setItem("hostess_conversationMode", memory.conversationMode || "normal");
      localStorage.setItem("hostess_silenceCount", memory.silenceCount || 0);
      localStorage.setItem("hostess_lastSummary", memory.lastSummary || "");
      localStorage.setItem("hostess_lastQuestionType", memory.lastQuestionType || "");
      localStorage.setItem("hostess_speakingStyle", memory.speakingStyle || "neutral");
      localStorage.setItem("hostess_emotionalTrend", memory.emotionalTrend || "");
      localStorage.setItem("hostess_personalityProfile", JSON.stringify(memory.personalityProfile));
    }

    function containsAny(text, words) {
      return words.some(word => text.includes(word.toLowerCase()));
    }

    function shorten(text) {
      return text.length > 18 ? text.slice(0, 18) + "…" : text;
    }

    function pick(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function maybeCallUserName() {
      if (!memory.userName) return "";
      return Math.random() < 0.35 ? `${memory.userName}さん、` : "";
    }

    function updateSummary(userText, replyText) {
      const shortUser = userText.length > 40 ? userText.slice(0, 40) + "…" : userText;
      const shortReply = replyText.length > 55 ? replyText.slice(0, 55) + "…" : replyText;
      memory.lastSummary = `前は「${shortUser}」って感じで、そこに対して「${shortReply}」って流れだったね。`;
      saveMemory();
    }

    function analyzeContext(text) {
      const lower = text.toLowerCase();

      if (
        text.trim() === "" ||
        containsAny(lower, ["…", "...", "うーん", "んー", "はぁ", "はー", "特に", "別に", "わからない"])
      ) {
        memory.silenceCount = (memory.silenceCount || 0) + 1;
      } else {
        memory.silenceCount = 0;
      }

      if (containsAny(lower, ["昨日の続き", "続き", "前の続き", "この前の続き", "昨日", "きのう"])) {
        memory.conversationMode = "continuation";
      } else if (containsAny(lower, [
        "聞いて",
        "聞いてほしい",
        "ただ話したい",
        "答えいらない",
        "アドバイスいらない",
        "わかってほしい"
      ])) {
        memory.conversationMode = "just_listen";
      } else if (containsAny(lower, [
        "整理したい",
        "ちゃんと考えたい",
        "原因",
        "どうして",
        "なんで",
        "深く"
      ])) {
        memory.conversationMode = "deep_talk";
      } else {
        memory.conversationMode = "normal";
      }

      if (text.length <= 8) {
        memory.speakingStyle = "short";
      } else if (text.length >= 45) {
        memory.speakingStyle = "long";
      } else {
        memory.speakingStyle = "neutral";
      }

      if (containsAny(lower, ["悲しい", "泣きたい", "寂しい", "つらい", "苦しい"])) {
        memory.currentFeeling = "sad";
        memory.emotionalTrend = "sad";
      } else if (containsAny(lower, ["不安", "こわい", "怖い", "心配"])) {
        memory.currentFeeling = "anxious";
        memory.emotionalTrend = "anxious";
      } else if (containsAny(lower, ["イライラ", "むかつく", "腹立つ"])) {
        memory.currentFeeling = "angry";
        memory.emotionalTrend = "angry";
      } else if (containsAny(lower, ["疲れた", "しんどい", "無理", "限界"])) {
        memory.currentFeeling = "tired";
        memory.emotionalTrend = "tired";
      }

      if (containsAny(lower, ["聞いて", "つらい", "悲しい", "しんどい"])) {
        memory.currentNeed = "empathy";
      } else if (containsAny(lower, ["どうしたら", "どうすれば", "わからない", "困る"])) {
        memory.currentNeed = "guidance";
      } else if (containsAny(lower, ["寂しい", "ひとり", "会いたい"])) {
        memory.currentNeed = "connection";
      }

      if (containsAny(lower, ["仕事", "会社", "上司", "職場"])) {
        memory.unresolvedTopic = "work";
      } else if (containsAny(lower, ["家族", "娘", "息子", "子ども"])) {
        memory.unresolvedTopic = "family";
      } else if (containsAny(lower, ["体調", "病院", "不調"])) {
        memory.unresolvedTopic = "health";
      } else if (containsAny(lower, ["人間関係", "友達", "恋愛"])) {
        memory.unresolvedTopic = "relationship";
      }

      saveMemory();
    }

    function learnUserPreference(text) {
      const lower = text.toLowerCase();
      const p = memory.personalityProfile;

      if (containsAny(lower, ["だる", "まじ", "やば", "ほんと", "しんど"])) {
        p.talkStyle = "casual";
      }
      if (containsAny(lower, ["です", "ます", "でしょうか", "ありがとうございます"])) {
        p.talkStyle = "polite";
      }

      if (containsAny(lower, ["うん", "そう", "まあ", "たぶん", "…", "..."])) {
        p.replyPace = "soft";
      }
      if (text.length > 60) {
        p.replyPace = "deep";
      }

      if (containsAny(lower, ["癒して", "安心したい", "甘えたい"])) {
        p.warmth = "warm";
      }
      if (containsAny(lower, ["整理したい", "冷静に", "ちゃんと考えたい"])) {
        p.warmth = "calm";
      }

      if (containsAny(lower, ["聞いてほしいだけ", "ただ話したい", "答えはいらない"])) {
        p.questionDepth = "light";
      }
      if (containsAny(lower, ["深く", "ちゃんと整理したい", "原因", "どうして"])) {
        p.questionDepth = "deep";
      }

      if (text.length < 12) {
        p.preferredLength = "short";
      } else if (text.length > 70) {
        p.preferredLength = "long";
      } else {
        p.preferredLength = "medium";
      }

      saveMemory();
    }

    function buildSoftContinuation(text) {
      const lower = text.toLowerCase();

      if (memory.conversationMode === "continuation") {
        if (memory.lastSummary) {
          return `昨日の流れも少し残ってる感じだよね。\n`;
        }
        return "昨日から少し続いてる感じなんだね。\n";
      }

      if (containsAny(lower, ["うん", "そう", "たしかに", "まあ", "少し", "たぶん"])) {
        return "うん、ちゃんと続きとして受け取ってるよ。\n";
      }

      if (memory.lastSummary && Math.random() < 0.18) {
        return "さっきの流れも少しつながってる感じするね。\n";
      }

      return "";
    }

    function avoidRepeatedQuestion(candidates, type = "") {
      const filtered = candidates.filter(q => q !== memory.lastQuestionType);
      const selected = filtered.length ? pick(filtered) : pick(candidates);
      memory.lastQuestionType = selected;
      saveMemory();
      return selected;
    }

    function getNaturalTail() {
      const mode = memory.conversationMode || "normal";
      const silence = memory.silenceCount || 0;

      const noQuestionTails = [
        "今はそれだけでも十分だよ。",
