<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 完成形</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:#09111f;
  color:white;
}

/* ===== 全体固定 ===== */
.app{
  height:100vh;
  display:flex;
  flex-direction:column;
  overflow:hidden;
}

/* ===== 画像（大きく＆固定） ===== */
.top{
  height:220px; /* ← 大きくした */
  flex-shrink:0;
  display:flex;
  justify-content:center;
  align-items:center;
  background:#000;
}

.top img{
  width:100%;
  height:100%;
  object-fit:contain; /* ← 顔切れない */
  object-position:top;
}

/* ===== メイン ===== */
.main{
  flex:1;
  display:flex;
  flex-direction:column;
  min-height:0;
}

/* ===== チャットだけスクロール ===== */
#chatBox{
  flex:1;
  overflow-y:auto;
  padding:10px;
}

/* ===== メッセージ ===== */
.message{
  max-width:80%;
  padding:12px;
  border-radius:16px;
  margin:6px 0;
}

.user{
  background:#ff4f8b;
  margin-left:auto;
}

.bot{
  background:#444;
}

.time{
  font-size:10px;
  opacity:0.6;
  margin-top:4px;
}

/* ===== 入力固定 ===== */
.input{
  display:flex;
  gap:6px;
  padding:8px;
  background:#111;
  flex-shrink:0;
}

input{
  flex:1;
  padding:12px;
  border-radius:10px;
  border:none;
}

button{
  padding:12px;
  border-radius:10px;
  border:none;
}

/* ===== タブ固定 ===== */
.tabs{
  display:flex;
  background:#222;
  flex-shrink:0;
}

.tab{
  flex:1;
  text-align:center;
  padding:12px;
}
</style>
</head>

<body>

<div class="app">

<!-- ===== 画像 ===== -->
<div class="top">
<img id="mainGirl" src="girl-normal.jpg">
</div>

<!-- ===== チャット ===== -->
<div class="main">
  <div id="chatBox"></div>

  <div class="input">
    <input id="userInput" placeholder="話しかけて…">
    <button onclick="sendMessage()">送信</button>
  </div>
</div>

<!-- ===== タブ ===== -->
<div class="tabs">
  <div class="tab">会話</div>
  <div class="tab">分析</div>
  <div class="tab">未来</div>
  <div class="tab">設定</div>
</div>

</div>

<script>

/* ===== 表情9枚 ===== */
const faces = {
  normal:"girl-normal.jpg",
  happy:"girl-happy.png",
  worried:"girl-worried.png",
  sympathy:"girl-sympathy.png",
  troubled:"girl-troubled.png",
  healing:"girl-healing.png",
  irritated:"girl-irritated.png",
  panic:"girl-panic.png",
  exhausted:"girl-exhausted.png"
};

function setFace(type){
  mainGirl.src = faces[type] || faces.normal;
}

/* ===== 状態 ===== */
let memory={
  lastReply:""
};

/* ===== 時間 ===== */
function getTime(){
  const d=new Date();
  return d.getHours()+":"+String(d.getMinutes()).padStart(2,"0");
}

/* ===== メッセージ ===== */
function addMessage(text,type){

  const div=document.createElement("div");
  div.className="message "+type;

  div.innerHTML=`
    ${text}
    <div class="time">${getTime()}</div>
  `;

  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

/* ===== 送信 ===== */
function sendMessage(){
  const text=userInput.value;
  if(!text) return;

  addMessage(text,"user");

  const reply = generateReply(text);

  setTimeout(()=>{
    addMessage(reply,"bot");
  },300);

  userInput.value="";
}

/* ===== AI（繰り返し防止・人格強化） ===== */
function generateReply(text){

  const t=text.toLowerCase();

  function has(arr){
    return arr.some(w=>t.includes(w));
  }

  let r="";

  if(has(["疲れ","しんど","無理"])){
    setFace("exhausted");
    r="ちょっと無理してる感じあるね…今日は少し力抜けそう？";
  }

  else if(has(["不安","怖い"])){
    setFace("worried");
    r="それ気になるよね…どこが一番引っかかってる？";
  }

  else if(has(["寂しい","つらい"])){
    setFace("sympathy");
    r="そっか…それはしんどいね。今ひとりで抱えてる感じ？";
  }

  else if(has(["イライラ"])){
    setFace("irritated");
    r="それはイラッとするね…何が一番嫌だった？";
  }

  else if(has(["嬉しい","楽しい"])){
    setFace("happy");
    r="いいね、それ。どの瞬間が一番よかった？";
  }

  else{
    setFace("normal");
    r="ちゃんと聞いてるよ。もう少し教えてくれる？";
  }

  if(r===memory.lastReply){
    r+=" 少し違う言い方するとどう感じてる？";
  }

  memory.lastReply=r;

  return r;
}

</script>

</body>
</html>
