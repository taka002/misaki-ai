<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI</title>

<style>
body{
  margin:0;
  background:#09111f;
  font-family:sans-serif;
  color:white;
  height:100vh;
  overflow:hidden;
}

/* ===== 画像 ===== */
.top{
  position:fixed;
  top:0;
  width:100%;
  height:180px;
}
.top img{
  width:100%;
  height:100%;
  object-fit:cover;
  border-bottom-left-radius:20px;
  border-bottom-right-radius:20px;
}

/* ===== チャット ===== */
#chatBox{
  position:fixed;
  top:180px;
  bottom:110px;
  width:100%;
  overflow-y:auto;
  padding:10px;
}

/* ===== 吹き出し ===== */
.message{
  max-width:75%;
  padding:10px;
  border-radius:16px;
  margin:6px 0;
  font-size:14px;
}

.user{
  background:#ff4f8b;
  margin-left:auto;
}

.bot{
  background:#444;
}

.time{
  font-size:10px;
  opacity:.6;
}

.name{
  font-size:11px;
  opacity:.7;
}

/* ===== 入力 ===== */
.input{
  position:fixed;
  bottom:60px;
  width:100%;
  display:flex;
  gap:6px;
  padding:6px;
  background:#111;
}

.stamp-btn{
  width:42px;
  height:42px;
  flex-shrink:0;
}

#userInput{
  flex:1;
  min-width:0;
  padding:10px;
}

.send-btn{
  width:60px;
  flex-shrink:0;
}

/* ===== タブ ===== */
.tabs{
  position:fixed;
  bottom:0;
  width:100%;
  height:50px;
  display:flex;
  background:#222;
}

.tab{
  flex:1;
  text-align:center;
  line-height:50px;
}

/* ===== スタンプ ===== */
#stampPanel{
  position:fixed;
  bottom:110px;
  width:100%;
  background:#222;
  display:none;
  flex-wrap:wrap;
  gap:10px;
  padding:10px;
  justify-content:center;
}
</style>
</head>

<body>

<div class="top">
  <img id="mainGirl" src="girl-normal.jpg">
</div>

<div id="chatBox"></div>

<div class="input">
  <button class="stamp-btn" onclick="toggleStamp()">😊</button>
  <input id="userInput" placeholder="話しかけて…">
  <button class="send-btn" onclick="sendMessage()">送信</button>
</div>

<div id="stampPanel"></div>

<div class="tabs">
  <div class="tab">会話</div>
  <div class="tab">分析</div>
  <div class="tab">未来</div>
  <div class="tab">設定</div>
</div>

<script>

/* ===== 記憶 ===== */
let memory = JSON.parse(localStorage.getItem("memory")||"{}");

if(!memory.history) memory.history=[];
if(!memory.stamps) memory.stamps=[];
if(!memory.personality) memory.personality={
  type:"normal",
  trust:0
};

/* ===== 表情 ===== */
const faces={
  normal:"girl-normal.jpg",
  happy:"girl-happy.png",
  worried:"girl-worried.png",
  sympathy:"girl-sympathy.png",
  troubled:"girl-troubled.png",
  healing:"girl-healing.png",
  irritated:"girl-irritated.png",
  panic:"girl-panic.png",
  exhausted:"girl-exhausted.png"
};

function setFace(t){
  mainGirl.src=faces[t]||faces.normal;
}

/* ===== スタンプ ===== */
const stampList=[
  {emoji:"😊", mood:"happy"},
  {emoji:"😢", mood:"sympathy"},
  {emoji:"😡", mood:"irritated"},
  {emoji:"🥺", mood:"troubled"},
  {emoji:"😴", mood:"exhausted"},
  {emoji:"😰", mood:"panic"},
  {emoji:"😟", mood:"worried"},
  {emoji:"😌", mood:"healing"},
  {emoji:"🙂", mood:"normal"}
];

function toggleStamp(){
  const p=stampPanel;
  p.style.display=p.style.display==="flex"?"none":"flex";

  if(p.innerHTML===""){
    stampList.forEach(s=>{
      const b=document.createElement("button");
      b.textContent=s.emoji;
      b.style.fontSize="24px";
      b.onclick=()=>sendStamp(s);
      p.appendChild(b);
    });
  }
}

/* ===== 時間 ===== */
function now(){
  const d=new Date();
  return d.getHours()+":"+String(d.getMinutes()).padStart(2,"0");
}

/* ===== メッセージ ===== */
function addMessage(t,type){
  const div=document.createElement("div");
  div.className="message "+type;

  if(type==="bot"){
    div.innerHTML=`<div class="name">美咲</div>${t}<div class="time">${now()}</div>`;
  }else{
    div.innerHTML=`${t}<div class="time">${now()}</div>`;
  }

  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

/* ===== スタンプ送信 ===== */
function sendStamp(s){
  addMessage(s.emoji,"user");

  setFace(s.mood);

  memory.stamps.push(s.mood);
  memory.personality.trust++;

  const reply=generateEmotionReply(s.mood);

  setTimeout(()=>addMessage(reply,"bot"),300);

  save();
}

/* ===== 性格変化ロジック ===== */
function analyzePersonality(){

  const counts={};

  memory.stamps.slice(-10).forEach(m=>{
    counts[m]=(counts[m]||0)+1;
  });

  const maxMood = Object.keys(counts).sort((a,b)=>counts[b]-counts[a])[0];

  return maxMood || "normal";
}

/* ===== AI返答 ===== */
function generateEmotionReply(mood){

  const dominant = analyzePersonality();
  let r="";

  // 基本
  switch(mood){
    case "happy": r="いいね、その感じ"; break;
    case "sympathy": r="そっか…ちょっとつらいね"; break;
    case "irritated": r="それイラっとするよね"; break;
    case "exhausted": r="かなり疲れてる感じあるね"; break;
    default: r="ちゃんと聞いてるよ";
  }

  // 性格変化（ここが核心）
  if(dominant==="sympathy"){
    r += "…無理しなくていいよ";
  }

  if(dominant==="irritated"){
    r += " 無理に抑えなくてもいいと思う";
  }

  if(dominant==="happy"){
    r += " いい流れだね";
  }

  if(memory.personality.trust>10){
    r="ねえ、"+r;
  }

  return r+"。少し話せそう？";
}

/* ===== テキスト送信 ===== */
function sendMessage(){
  const t=userInput.value;
  if(!t) return;

  addMessage(t,"user");

  memory.history.push(t);
  memory.personality.trust++;

  const r=generateEmotionReply("normal");

  setTimeout(()=>addMessage(r,"bot"),300);

  userInput.value="";
  save();
}

/* ===== 保存 ===== */
function save(){
  localStorage.setItem("memory",JSON.stringify(memory));
}

</script>

</body>
</html>
