    }

    function startWakeListening() {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

      if (!SpeechRecognition) {
        alert("この環境ではウェイクワードが使えません。\n\nおすすめ:\n・Chromeで開く\n・GitHub Pagesで開く\n・HTTPSで開く");
        return;
      }

      if (isListening || isSpeaking) return;

      stopWakeListening();

      try {
        wakeRecognition = new SpeechRecognition();
        wakeRecognition.lang = "ja-JP";
        wakeRecognition.interimResults = false;
        wakeRecognition.continuous = false;
        wakeRecognition.maxAlternatives = 1;

        isWakeListening = true;
        updateMicButtonUI();
        setStatus(`「${wakeWord}」を待機中…`);

        wakeRecognition.onresult = (event) => {
          const transcript = event.results?.[0]?.[0]?.transcript || "";
          const heard = normalizeJapanese(transcript);
          const target = normalizeJapanese(wakeWord);

          console.log("Wake heard:", transcript);

          if (heard.includes(target)) {
            stopWakeListening();
            setStatus(`「${wakeWord}」に反応したよ`);
            addMessage(`${memory.characterName || "美咲"}「呼んだ？」`, "bot");

            setTimeout(() => {
              startVoiceInput(true);
            }, 600);
          } else {
            if (wakeModeEnabled) {
              setTimeout(() => {
                startWakeListening();
              }, 700);
            }
          }
        };

        wakeRecognition.onerror = (event) => {
          console.log("Wake error:", event.error);

          isWakeListening = false;
          updateMicButtonUI();

          if (event.error === "not-allowed") {
            setStatus("マイク許可が必要です");
          } else if (event.error === "no-speech") {
            if (wakeModeEnabled) {
              setTimeout(() => startWakeListening(), 700);
            }
          } else {
            if (wakeModeEnabled) {
              setTimeout(() => startWakeListening(), 1200);
            }
          }
        };

        wakeRecognition.onend = () => {
          isWakeListening = false;
          updateMicButtonUI();

          if (wakeModeEnabled && !isListening && !isSpeaking) {
            setTimeout(() => {
              startWakeListening();
            }, 900);
          }
        };

        wakeRecognition.start();
      } catch (e) {
        console.error("Wake start error:", e);
        isWakeListening = false;
        updateMicButtonUI();
        setStatus("ウェイク待機開始失敗");
      }
    }

    function startVoiceInput(fromWake = false) {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

      if (!SpeechRecognition) {
        alert("この環境ではマイク入力が使えません。\n\nおすすめ:\n・Chromeで開く\n・GitHub Pagesで開く\n・HTTPSで開く");
        return;
      }

      if (isListening) {
        stopVoiceInput();
        return;
      }

      stopWakeListening();

      try {
        recognition = new SpeechRecognition();
        recognition.lang = "ja-JP";
        recognition.interimResults = false;
        recognition.continuous = false;
        recognition.maxAlternatives = 1;

        isListening = true;
        updateMicButtonUI();
        setStatus(fromWake ? "🎤 聞いてるよ…話してね" : "🎤 聞き取り中…話してください");

        recognition.onresult = (event) => {
          const transcript = event.results[0][0].transcript || "";
          userInput.value = transcript.trim();
          setStatus("音声入力OK → 送信中");
          setTimeout(() => {
            sendMessage();
          }, 350);
        };

        recognition.onerror = (event) => {
          if (event.error === "not-allowed") {
            setStatus("マイク許可が必要です");
            alert("マイクが拒否されています。\n\nChromeの設定でこのページのマイクを許可してください。");
          } else if (event.error === "no-speech") {
            setStatus("声が聞こえなかったみたい");
          } else if (event.error === "audio-capture") {
            setStatus("マイクが使えません");
          } else if (event.error === "network") {
            setStatus("音声認識ネットワークエラー");
          } else {
            setStatus("マイク入力失敗");
          }

          isListening = false;
          updateMicButtonUI();
          resumeWakeIfNeeded();
        };

        recognition.onend = () => {
          isListening = false;
          updateMicButtonUI();

          if (statusBar.textContent.includes("聞き取り中") || statusBar.textContent.includes("聞いてるよ")) {
            setStatus("準備OK");
          }

          resumeWakeIfNeeded();
        };

        recognition.start();
      } catch (e) {
        console.error("Voice input start error:", e);
        isListening = false;
        updateMicButtonUI();
        setStatus("マイク起動失敗");
        resumeWakeIfNeeded();
      }
    }

    settingsModal.addEventListener("click", (e) => {
      if (e.target === settingsModal) {
        closeSettings();
      }
    });
  </script>
</body>
</html>
