<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:#09111f;
  color:white;
}

/* ===== 全体 ===== */
.app{
  display:flex;
  flex-direction:column;
  height:100dvh;
}

/* ===== 画像（完全固定） ===== */
.top-character{
  height:160px; /* ←ここが重要 */
  flex-shrink:0;
  padding:6px;
}
.top-character img{
  width:100%;
  height:100%;
  object-fit:cover;
  border-radius:20px;
}

/* ===== チャットエリア ===== */
.chat-area{
  flex:1;
  display:flex;
  flex-direction:column;
  min-height:0; /* ←超重要（崩れ防止） */
}

/* ===== メッセージだけスクロール ===== */
#chatBox{
  flex:1;
  overflow-y:auto;
  padding:10px;
  display:flex;
  flex-direction:column;
}

/* ===== 吹き出し ===== */
.message{
  padding:12px;
  border-radius:18px;
  margin:6px 0;
  max-width:75%;
  font-size:16px;
}

.user{
  background:#ff4f8b;
  align-self:flex-end;
}

.bot{
  background:#444;
}

/* ===== 入力固定 ===== */
.input-area{
  display:flex;
  padding:8px;
  background:#09111f;
  flex-shrink:0;
}
input{
  flex:1;
  padding:12px;
  border-radius:12px;
  border:none;
}
button{
  padding:12px;
  margin-left:6px;
}

/* ===== タブ固定 ===== */
.tabs{
  display:flex;
  background:#222;
  flex-shrink:0;
}
.tab{
  flex:1;
  padding:12px;
  text-align:center;
  font-size:14px;
}
</style>
</head>

<body>

<div class="app">

<!-- 画像 -->
<div class="top-character">
  <img src="girl-normal.jpg">
</div>

<!-- チャット -->
<div class="chat-area">

  <div id="chatBox"></div>

  <div class="input-area">
    <input id="userInput">
    <button onclick="sendMessage()">送信</button>
  </div>

</div>

<!-- タブ -->
<div class="tabs">
  <div class="tab">会話</div>
  <div class="tab">分析</div>
  <div class="tab">未来</div>
  <div class="tab">設定</div>
</div>

</div>

<script>

function addMessage(text,type){
  const div=document.createElement("div");
  div.className="message "+type;
  div.textContent=text;
  chatBox.appendChild(div);

  // ↓ 常に一番下へ
  chatBox.scrollTop = chatBox.scrollHeight;
}

function sendMessage(){
  const text=userInput.value;
  if(!text) return;

  addMessage(text,"user");

  let reply="ちゃんと聞いてるよ";

  if(text.includes("疲")){
    reply="ちょっと無理してる感じあるね…";
  }

  addMessage(reply,"bot");

  userInput.value="";
}

</script>

</body>
</html>
