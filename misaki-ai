<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>ピピAI 完全版</title>

  <style>
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      width: 100%;
      overflow: hidden;
      font-family: "Hiragino Sans", "Yu Gothic", sans-serif;
      transition: background 0.45s ease;
    }

    body {
      background: linear-gradient(to bottom, #2b314d, #09111f);
      color: white;
      display: flex;
      flex-direction: column;
    }

    .app {
      width: 100%;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ===== 上画像 ===== */
    .top-character {
      flex: 0 0 34vh;
      min-height: 240px;
      max-height: 360px;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 14px 14px 8px;
      position: relative;
    }

    .top-character img {
      width: min(92vw, 520px);
      height: 100%;
      object-fit: cover;
      border-radius: 28px;
      border: 3px solid rgba(255,255,255,0.14);
      box-shadow: 0 16px 34px rgba(0,0,0,0.38);
      background: rgba(255,255,255,0.03);
      transition: all 0.28s ease;
      display: block;
    }

    .settings-open {
      position: absolute;
      top: 18px;
      right: 18px;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      border: none;
      font-size: 32px;
      background: rgba(255,255,255,0.16);
      color: white;
      backdrop-filter: blur(8px);
      box-shadow: 0 10px 26px rgba(0,0,0,0.22);
      cursor: pointer;
      z-index: 5;
    }

    /* ===== 会話エリア ===== */
    .chat-section {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      padding: 0 12px;
      overflow: hidden;
    }

    #chatBox {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 6px 2px 12px;
      scroll-behavior: smooth;
    }

    .message {
      max-width: 86%;
      padding: 16px 18px;
      border-radius: 24px;
      font-size: clamp(16px, 2.4vw, 18px);
      line-height: 1.95;
      white-space: pre-wrap;
      word-break: break-word;
      animation: fadeIn 0.22s ease;
    }

    .bot {
      align-self: flex-start;
      background: rgba(255,255,255,0.11);
      border-bottom-left-radius: 10px;
      color: #fff;
      box-shadow: 0 8px 18px rgba(0,0,0,0.12);
    }

    .user {
      align-self: flex-end;
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      border-bottom-right-radius: 10px;
      color: white;
      box-shadow: 0 8px 18px rgba(255,93,151,0.25);
    }

    .typing {
      opacity: 0.72;
      font-style: italic;
    }

    /* ===== ステータス ===== */
    .status-bar {
      flex-shrink: 0;
      font-size: 13px;
      opacity: 0.82;
      padding: 0 16px 8px;
      min-height: 22px;
    }

    /* ===== ウェイクボタン ===== */
    .wake-row {
      flex-shrink: 0;
      padding: 0 12px 10px;
    }

    .wake-btn {
      width: 100%;
      border: none;
      border-radius: 24px;
      padding: 18px 16px;
      font-size: 28px;
      font-weight: bold;
      color: white;
      background: rgba(255,255,255,0.22);
      box-shadow: 0 12px 24px rgba(0,0,0,0.18);
      cursor: pointer;
    }

    .wake-btn.active {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
      box-shadow: 0 0 0 8px rgba(122,105,255,0.16);
    }

    /* ===== 入力エリア ===== */
    .input-area {
      flex-shrink: 0;
      display: grid;
      grid-template-columns: 1fr 88px 112px;
      gap: 10px;
      padding: 12px;
      background: rgba(0,0,0,0.24);
      border-top: 1px solid rgba(255,255,255,0.08);
      align-items: center;
    }

    input[type="text"], input[type="password"], select {
      width: 100%;
      min-width: 0;
      padding: 16px 18px;
      border-radius: 20px;
      border: none;
      outline: none;
      font-size: 18px;
      background: rgba(255,255,255,0.96);
      color: #222;
    }

    .mic-btn, .send-btn {
      border: none;
      border-radius: 24px;
      color: white;
      cursor: pointer;
      font-weight: bold;
      box-shadow: 0 12px 24px rgba(0,0,0,0.16);
    }

    .mic-btn {
      width: 88px;
      height: 84px;
      font-size: 34px;
      background: rgba(255,255,255,0.12);
    }

    .mic-btn.listening {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
      box-shadow: 0 0 0 8px rgba(122,105,255,0.18);
    }

    .send-btn {
      width: 112px;
      height: 84px;
      font-size: 22px;
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      box-shadow: 0 14px 28px rgba(255,79,139,0.28);
    }

    .send-btn:active,
    .mic-btn:active,
    .settings-open:active,
    .wake-btn:active {
      transform: scale(0.97);
    }

    #chatBox::-webkit-scrollbar {
      width: 6px;
    }

    #chatBox::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.18);
      border-radius: 999px;
    }

    /* ===== アニメ ===== */
    .speaking {
      animation: pulseTalk 0.75s infinite ease-in-out;
    }

    .face-change {
      animation: facePop 0.25s ease;
    }

    @keyframes pulseTalk {
      0%   { transform: scale(1) translateY(0px); }
      25%  { transform: scale(1.01) translateY(-1px); }
      50%  { transform: scale(1.02) translateY(0px); }
      75%  { transform: scale(1.01) translateY(-1px); }
      100% { transform: scale(1) translateY(0); }
    }

    @keyframes facePop {
      0%   { transform: scale(0.97); opacity: 0.75; }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ===== 設定モーダル ===== */
    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 999;
      padding: 18px;
    }

    .modal.show {
      display: flex;
    }

    .modal-box {
      width: 100%;
      max-width: 420px;
      max-height: 88vh;
      overflow-y: auto;
      background: #2a2236;
      border-radius: 28px;
      padding: 22px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.45);
    }

    .modal-title {
      font-size: 26px;
      font-weight: bold;
      color: #ffd1e6;
      margin-bottom: 18px;
    }

    .setting-row {
      margin-bottom: 16px;
    }

    .setting-label {
      font-size: 16px;
      opacity: 0.95;
      margin-bottom: 8px;
      display: block;
      line-height: 1.6;
    }

    .setting-input {
      width: 100%;
      padding: 16px;
      border-radius: 18px;
      border: none;
      font-size: 18px;
      outline: none;
    }

    .toggle-btn, .danger-btn, .close-btn, .save-btn {
      width: 100%;
      padding: 16px;
      border: none;
      border-radius: 18px;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 10px;
    }

    .toggle-btn {
      background: #5f5470;
      color: white;
    }

    .danger-btn {
      background: #8a3d57;
      color: white;
    }

    .save-btn {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
      color: white;
    }

    .close-btn {
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      color: white;
    }

    .hint {
      font-size: 13px;
      opacity: 0.72;
      margin-top: 6px;
      line-height: 1.6;
    }

    @media (max-width: 430px) {
      .top-character {
        flex: 0 0 32vh;
        min-height: 220px;
      }

      .settings-open {
        width: 68px;
        height: 68px;
        font-size: 28px;
      }

      .input-area {
        grid-template-columns: 1fr 84px 106px;
      }

      .mic-btn {
        width: 84px;
        height: 80px;
      }

      .send-btn {
        width: 106px;
        height: 80px;
      }

      .wake-btn {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <div class="app">

    <!-- 上 -->
    <div class="top-character">
      <img id="mainGirl" src="girl-normal.jpg" alt="ピピ">
      <button class="settings-open" onclick="openSettings()">⚙</button>
    </div>

    <!-- 会話 -->
    <div class="chat-section">
      <div id="chatBox"></div>
    </div>

    <!-- 状態 -->
    <div class="status-bar" id="statusBar">準備OK</div>

    <!-- ウェイク待機ボタン -->
    <div class="wake-row">
      <button class="wake-btn" id="wakeBtn" onclick="enableWakeMode()">👂 ピピ待機</button>
    </div>

    <!-- 下入力 -->
    <div class="input-area">
      <input type="text" id="userInput" placeholder="話してみて…" />
      <button class="mic-btn" id="micBtn" onclick="startVoiceInput()">🎤</button>
      <button class="send-btn" onclick="sendMessage()">送信</button>
    </div>
  </div>

  <!-- 設定 -->
  <div class="modal" id="settingsModal">
    <div class="modal-box">
      <div class="modal-title">設定</div>

      <div class="setting-row">
        <label class="setting-label">あなたの呼び名（時々呼ぶ）</label>
        <input class="setting-input" id="userNameInput" placeholder="だいすけ">
      </div>

      <div class="setting-row">
        <label class="setting-label">キャラ名</label>
        <input class="setting-input" id="nameInput" placeholder="ピピ">
      </div>

      <div class="setting-row">
        <label class="setting-label">OpenAI APIキー（※保存しません）</label>
        <input class="setting-input" id="apiKeyInput" type="password" placeholder="sk-..." />
        <div class="hint">再起動すると空になります。会話履歴は残ります。</div>
      </div>

      <div class="setting-row">
        <label class="setting-label">ElevenLabs APIキー（※保存しません）</label>
        <input class="setting-input" id="elevenApiKeyInput" type="password" placeholder="sk_..." />
        <div class="hint">自然音声を使う時だけ入力します。再起動で消えます。</div>
      </div>

      <div class="setting-row">
        <label class="setting-label">Voice ID（※保存しません）</label>
        <input class="setting-input" id="voiceIdInput" type="text" placeholder="wcs09USXSN5Bl7FXohVZ" />
        <div class="hint">ElevenLabsの声ID。再起動で消えます。</div>
      </div>

      <div class="setting-row">
        <label class="setting-label">音声エンジン</label>
        <select class="setting-input" id="voiceEngineSelect">
          <option value="standard">スマホ標準音声</option>
          <option value="eleven">ElevenLabs音声</option>
        </select>
      </div>

      <button class="save-btn" onclick="saveSettings()">💾 保存する</button>
      <button class="toggle-btn" id="gptToggle" onclick="toggleGPT()">🤖 GPT OFF</button>
      <button class="toggle-btn" id="voiceToggle" onclick="toggleVoice()">🔊 音声ON</button>
      <button class="toggle-btn" id="elevenToggle" onclick="toggleElevenVoice()">🎙 Eleven音声OFF</button>
      <button class="toggle-btn" id="wakeToggle" onclick="toggleWake()">👂 ウェイク待機ON</button>
      <button class="danger-btn" onclick="resetApiOnly()">APIキー類だけリセット</button>
      <button class="danger-btn" onclick="resetMemory()">記憶をリセット</button>
      <button class="close-btn" onclick="closeSettings()">閉じる</button>
    </div>
  </div>

  <script>
    const chatBox = document.getElementById("chatBox");
    const userInput = document.getElementById("userInput");
    const mainGirl = document.getElementById("mainGirl");
    const settingsModal = document.getElementById("settingsModal");
    const voiceToggleBtn = document.getElementById("voiceToggle");
    const gptToggleBtn = document.getElementById("gptToggle");
    const wakeToggleBtn = document.getElementById("wakeToggle");
    const nameInput = document.getElementById("nameInput");
    const userNameInput = document.getElementById("userNameInput");
    const apiKeyInput = document.getElementById("apiKeyInput");
    const elevenApiKeyInput = document.getElementById("elevenApiKeyInput");
    const voiceIdInput = document.getElementById("voiceIdInput");
    const voiceEngineSelect = document.getElementById("voiceEngineSelect");
    const statusBar = document.getElementById("statusBar");
    const micBtn = document.getElementById("micBtn");
    const wakeBtn = document.getElementById("wakeBtn");

    let voiceEnabled = localStorage.getItem("voiceEnabled") !== "false";
    let gptEnabled = localStorage.getItem("gptEnabled") === "true";
    let elevenVoiceEnabled = localStorage.getItem("elevenVoiceEnabled") === "true";
    let voiceEngine = localStorage.getItem("voiceEngine") || "standard";
    let wakeEnabled = localStorage.getItem("wakeEnabled") !== "false";

    let availableVoices = [];
    let recognition = null;
    let wakeRecognition = null;
    let isListening = false;
    let isSpeaking = false;
    let wakeLocked = false;
    let wakePermissionGranted = false;
    let wakeStartedOnce = false;
    let lastBotReply = "";

    // ===== APIキーは保存しない =====
    let sessionSecrets = {
      apiKey: "",
      elevenApiKey: "",
      voiceId: ""
    };

    let memory = {
      characterName: localStorage.getItem("characterName") || "ピピ",
      userName: localStorage.getItem("userNickName") || "",
      mood: localStorage.getItem("hostess_mood") || "",
      topic: localStorage.getItem("hostess_topic") || "",
      lastMessage: localStorage.getItem("hostess_lastMessage") || "",
      visitCount: parseInt(localStorage.getItem("hostess_visitCount") || "0", 10),
      chatHistory: JSON.parse(localStorage.getItem("hostess_chatHistory") || "[]"),

      currentFeeling: localStorage.getItem("hostess_currentFeeling") || "",
      currentNeed: localStorage.getItem("hostess_currentNeed") || "",
      unresolvedTopic: localStorage.getItem("hostess_unresolvedTopic") || "",
      lastBotQuestion: localStorage.getItem("hostess_lastBotQuestion") || ""
    };

    memory.visitCount += 1;
    localStorage.setItem("hostess_visitCount", memory.visitCount);

    nameInput.value = memory.characterName;
    userNameInput.value = memory.userName;
    apiKeyInput.value = "";
    elevenApiKeyInput.value = "";
    voiceIdInput.value = "";
    voiceEngineSelect.value = voiceEngine;

    updateVoiceButton();
    updateGPTButton();
    updateElevenButton();
    updateWakeButton();

    const faceImages = {
      normal: "girl-normal.jpg",
      worried: "girl-worried.png",
      sympathy: "girl-sympathy.png",
      troubled: "girl-troubled.png",
      healing: "girl-healing.png",
      happy: "girl-happy.png",
      irritated: "girl-irritated.png",
      panic: "girl-panic.png",
      exhausted: "girl-exhausted.png"
    };

    const moodBackgrounds = {
      normal: "linear-gradient(to bottom, #2b314d, #09111f)",
      worried: "linear-gradient(to bottom, #3f4c6b, #151d2b)",
      sympathy: "linear-gradient(to bottom, #4a3b60, #161626)",
      troubled: "linear-gradient(to bottom, #4c4b67, #151b28)",
      healing: "linear-gradient(to bottom, #5b4767, #171629)",
      happy: "linear-gradient(to bottom, #485f8b, #12203b)",
      irritated: "linear-gradient(to bottom, #5f3a4f, #1a111b)",
      panic: "linear-gradient(to bottom, #5a5068, #181724)",
      exhausted: "linear-gradient(to bottom, #4b5165, #121926)"
    };

    function setStatus(text) {
      statusBar.textContent = text;
    }

    function setFace(type = "normal") {
      const src = faceImages[type] || faceImages.normal;
      mainGirl.src = src;
      document.body.style.background = moodBackgrounds[type] || moodBackgrounds.normal;

      mainGirl.classList.remove("face-change");
      void mainGirl.offsetWidth;
      mainGirl.classList.add("face-change");
    }

    function startSpeakingAnimation() {
      mainGirl.classList.add("speaking");
      isSpeaking = true;
    }

    function stopSpeakingAnimation() {
      mainGirl.classList.remove("speaking");
      isSpeaking = false;
    }

    function openSettings() {
      nameInput.value = memory.characterName || "ピピ";
      userNameInput.value = memory.userName || "";
      apiKeyInput.value = "";
      elevenApiKeyInput.value = "";
      voiceIdInput.value = "";
      voiceEngineSelect.value = voiceEngine;
      settingsModal.classList.add("show");
    }

    function closeSettings() {
      settingsModal.classList.remove("show");
    }

    function saveSettings() {
      memory.characterName = nameInput.value.trim() || "ピピ";
      memory.userName = userNameInput.value.trim();

      sessionSecrets.apiKey = apiKeyInput.value.trim();
      sessionSecrets.elevenApiKey = elevenApiKeyInput.value.trim();
      sessionSecrets.voiceId = voiceIdInput.value.trim();

      voiceEngine = voiceEngineSelect.value;
      localStorage.setItem("voiceEngine", voiceEngine);
      localStorage.setItem("characterName", memory.characterName);
      localStorage.setItem("userNickName", memory.userName);

      addMessage("設定を保存したよ😊", "bot");
      setStatus("設定を保存しました（APIキーは今回だけ有効）");
      closeSettings();
    }

    function resetApiOnly() {
      sessionSecrets.apiKey = "";
      sessionSecrets.elevenApiKey = "";
      sessionSecrets.voiceId = "";
      apiKeyInput.value = "";
      elevenApiKeyInput.value = "";
      voiceIdInput.value = "";
      addMessage("APIキー類だけリセットしたよ😊", "bot");
