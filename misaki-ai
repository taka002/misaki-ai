<!DOCTYPE html><html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 完全版</title><style>
body{margin:0;font-family:sans-serif;background:#09111f;color:white;}
.app{display:flex;flex-direction:column;height:100vh;}
.top-character{height:30vh;display:flex;justify-content:center;align-items:center;}
.top-character img{width:90%;border-radius:20px;}
#chatBox{flex:1;overflow:auto;padding:10px;display:flex;flex-direction:column;}
.message{padding:10px;border-radius:15px;margin:5px 0;max-width:80%;}
.user{background:#ff4f8b;align-self:flex-end;}
.bot{background:#444;align-self:flex-start;}
.input-area{display:flex;}
input{flex:1;padding:10px;}
button{padding:10px;}
.tabs{display:flex;}
.tab{flex:1;padding:10px;background:#222;text-align:center;}
.panel{display:none;flex:1;}
.panel.active{display:flex;flex-direction:column;}
</style></head>
<body><div class="app"><div class="top-character">
<img id="mainGirl" src="girl-normal.jpg">
</div><div id="chatPanel" class="panel active">
<div id="chatBox"></div>
<div class="input-area">
<input id="userInput">
<button onclick="sendMessage()">送信</button>
</div>
</div><div id="analysisPanel" class="panel">
<div id="analysisContent"></div>
</div><div id="futurePanel" class="panel">
<div id="futureContent"></div>
</div><div class="tabs">
<div class="tab" onclick="switchTab('chat')">会話</div>
<div class="tab" onclick="switchTab('analysis')">分析</div>
<div class="tab" onclick="switchTab('future')">未来</div>
</div></div><script>

// ===== 状態 =====
let memory={
  chatHistory:[],
  mood:"normal"
};

let isPremium = localStorage.getItem("isPremium") === "true";

// ===== 表情 =====
const faceImages = {
  normal:"girl-normal.jpg",
  happy:"girl-happy.png",
  sympathy:"girl-sympathy.png",
  worried:"girl-worried.png",
  troubled:"girl-troubled.png",
  healing:"girl-healing.png",
  irritated:"girl-irritated.png",
  panic:"girl-panic.png",
  exhausted:"girl-exhausted.png"
};

function setFace(type){
  const img=document.getElementById("mainGirl");
  img.src=(faceImages[type]||faceImages.normal)+"?t="+Date.now();
  memory.mood=type;
}

// ===== タブ =====
function switchTab(tab){
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));
  if(tab==='chat') chatPanel.classList.add("active");
  if(tab==='analysis') analysisPanel.classList.add("active");
  if(tab==='future') futurePanel.classList.add("active");
}

// ===== チャット =====
function addMessage(text,type){
  const div=document.createElement("div");
  div.className="message "+type;
  div.textContent=text;
  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

function sendMessage(){
  const text=userInput.value.trim();
  if(!text) return;

  addMessage(text,"user");
  memory.chatHistory.push(text);

  const reply=generateReply(text);
  addMessage(reply,"bot");

  userInput.value="";
}

userInput.addEventListener("keypress",e=>{
  if(e.key==="Enter") sendMessage();
});

function generateReply(text){

  const lower=text.toLowerCase();
  const contains=(arr)=>arr.some(w=>lower.includes(w));

  if(contains(["疲れ","しんど","無理","限界"])){
    setFace("exhausted");
    return "かなり無理してる感じあるね…\n今日は少し力抜けそう？";
  }

  if(contains(["不安","怖い","こわい","心配"])){
    setFace("worried");
    return "それ気になるよね…\n今いちばん引っかかってるのどこ？";
  }

  if(contains(["悲しい","つらい","寂しい"])){
    setFace("sympathy");
    return "そっか…それはしんどいね\n無理に元気にならなくていいよ";
  }

  if(contains(["イライラ","むかつく","腹立つ"])){
    setFace("irritated");
    return "それはイラッとするね\n何が一番引っかかった？";
  }

  if(contains(["嬉しい","楽しい","よかった"])){
    setFace("happy");
    return "それいいね😊\nどんなところが一番よかった？";
  }

  setFace("normal");
  return "ちゃんと聞いてるよ\nもう少し教えてくれる？";
}

// ===== 分析 =====
function analyze(){
  const text=memory.chatHistory.join(" ");

  let fatigue=text.includes("疲")?80:30;
  let anxiety=text.includes("不安")?70:30;

  analysisContent.innerHTML=`
    <div>疲労:${fatigue}</div>
    <div>不安:${anxiety}</div>
  `;
}

// ===== 未来 =====
function openFuture(){

  if(!isPremium){
    alert("プレミアム限定");
    return;
  }

  const mood=memory.mood;

  let resultA="回復ルート（少し楽になる）";
  let resultB="消耗ルート（悪化しやすい）";

  if(mood==="exhausted"){
    resultA="休めばかなり回復";
    resultB="続けると限界近い";
  }

  futureContent.innerHTML=`
    <div>A: ${resultA}</div>
    <div>B: ${resultB}</div>
  `;
}

// ===== 課金 =====
function unlockPremium(){
  isPremium=true;
  localStorage.setItem("isPremium","true");
}

</script></body>
</html>
