<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 最終版</title>

<style>
html,body{
  margin:0;
  height:100%;
  overflow:hidden;
  font-family:sans-serif;
  color:white;
}

/* ===== 上画像 ===== */
.top{
  position:fixed;
  top:0;
  width:100%;
  height:28%;
  display:flex;
  justify-content:center;
}
.top img{
  width:90%;
  height:100%;
  object-fit:cover;
  border-radius:20px;
}

/* ===== チャット ===== */
#chatBox{
  position:fixed;
  top:28%;
  bottom:110px;
  width:100%;
  overflow-y:auto;
  padding:8px;
}

/* ===== メッセージ ===== */
.message{
  max-width:75%;
  padding:10px;
  border-radius:14px;
  margin:6px;
  font-size:13px;
}
.user{
  background:#ff4f8b;
  margin-left:auto;
}
.bot{
  background:#444;
}

/* ===== 入力 ===== */
.input{
  position:fixed;
  bottom:50px;
  width:100%;
  height:60px;
  display:flex;
  padding:6px;
  background:#111;
}
input{
  flex:1;
  padding:10px;
  border-radius:10px;
  border:none;
}
button{
  width:50px;
  margin-left:5px;
  border:none;
  border-radius:10px;
}

/* ===== タブ ===== */
.tabs{
  position:fixed;
  bottom:0;
  width:100%;
  height:50px;
  display:flex;
  background:#222;
}
.tab{
  flex:1;
  text-align:center;
  padding:8px;
  font-size:12px;
}
</style>
</head>

<body>

<div class="top">
<img id="face" src="girl-normal.jpg">
</div>

<div id="chatBox"></div>

<div class="input">
<button onclick="startVoice()">🎤</button>
<input id="userInput" placeholder="話しかけて...">
<button onclick="sendMessage()">送信</button>
</div>

<div class="tabs">
<div class="tab">会話</div>
<div class="tab">分析</div>
<div class="tab">未来</div>
<div class="tab">設定</div>
</div>

<script>

/* ===== 名前 ===== */
let userName = localStorage.getItem("userName") || "";
if(!userName){
  userName = prompt("名前教えて？");
  localStorage.setItem("userName", userName);
}

/* ===== 親密度 ===== */
let love = Number(localStorage.getItem("love")) || 0;

function addLove(){
  love++;
  localStorage.setItem("love", love);
}

/* ===== 記憶 ===== */
let memory = JSON.parse(localStorage.getItem("memory")) || [];

function saveMemory(text){
  memory.push(text);
  if(memory.length > 10) memory.shift();
  localStorage.setItem("memory", JSON.stringify(memory));
}

function getMemoryHint(){
  const text = memory.join(" ");
  if(text.includes("東京")) return "東京の話してたよね";
  if(text.includes("仕事")) return "仕事のこと気になってる";
  if(text.includes("疲")) return "さっき疲れてる感じだったよね";
  return "";
}

/* ===== 表情 ===== */
const faces={
normal:"girl-normal.jpg",
happy:"girl-happy.png",
exhausted:"girl-exhausted.png",
worried:"girl-worried.png",
healing:"girl-healing.png",
irritated:"girl-irritated.png",
panic:"girl-panic.png",
sympathy:"girl-sympathy.png",
troubled:"girl-troubled.png"
};

function setFace(type){
  document.getElementById("face").src=faces[type]||faces.normal;
}

/* ===== 時間 ===== */
function time(){
  const d=new Date();
  return d.getHours().toString().padStart(2,"0")+":"+
         d.getMinutes().toString().padStart(2,"0");
}

/* ===== メッセージ ===== */
function addMessage(text,type){
  const div=document.createElement("div");
  div.className="message "+type;

  if(type==="user"){
    div.innerHTML = text +
    `<div style="font-size:10px;color:#ddd;text-align:right">${time()} ✔✔</div>`;
  }else{
    div.innerHTML =
    `<div style="font-size:11px;color:#aaa">美咲</div>`+
    text+
    `<div style="font-size:10px;color:#aaa">${time()}</div>`;
  }

  chatBox.appendChild(div);
  chatBox.scrollTop = chatBox.scrollHeight;
}

/* ===== 夜モード ===== */
function updateTheme(){
  const hour = new Date().getHours();
  if(hour < 18){
    document.body.style.background="#08121f";
  }else{
    document.body.style.background="#050814";
  }
}
setInterval(updateTheme,1000);

/* ===== 音声 ===== */
function speak(text){
  const msg=new SpeechSynthesisUtterance(text);
  msg.lang="ja-JP";

  if(love > 20){
    msg.pitch=1.4;
  }else{
    msg.pitch=1.1;
  }

  speechSynthesis.speak(msg);
}

/* ===== AI ===== */
function replyAI(text){

  addLove();

  let mood="normal";

  if(text.includes("疲")) mood="exhausted";
  else if(text.includes("楽")) mood="happy";
  else if(text.includes("不安")) mood="worried";

  setFace(mood);

  // GPT風
  let empathy="ちゃんと聞いてるよ";
  let expand="少し気になってる";
  let question="どうだった？";

  if(mood==="exhausted"){
    empathy="そっか、ちょっと疲れてる感じあるね";
    expand="頑張ってるからこそだよ";
    question="少し休めそう？";
  }

  if(mood==="happy"){
    empathy="いいね、その感じ好き";
    expand="こっちまで嬉しくなる";
    question="何が一番よかった？";
  }

  if(mood==="worried"){
    empathy="そっか、不安あるよね";
    expand="一人で抱えなくていいよ";
    question="少し話せる？";
  }

  let reply = empathy + "。" + expand + "。" + question;

  // 記憶
  let hint = getMemoryHint();
  if(hint) reply = hint + "。" + reply;

  // 親密度で変化
  if(love > 30){
    reply = userName + "、" + reply + " そばにいるよ";
  }else if(love > 10){
    reply = userName + "、" + reply;
  }

  // 既読
  const read=document.createElement("div");
  read.style.fontSize="10px";
  read.textContent="既読";
  chatBox.appendChild(read);

  // タイピング
  const typing=document.createElement("div");
  typing.className="message bot";
  typing.textContent="…";
  chatBox.appendChild(typing);

  setTimeout(()=>{
    typing.remove();
    addMessage(reply,"bot");
    speak(reply);
  },800 + Math.random()*1200);
}

/* ===== 送信 ===== */
function sendMessage(){
  const text=userInput.value;
  if(!text) return;

  addMessage(text,"user");
  saveMemory(text);
  userInput.value="";
  replyAI(text);
}

/* ===== 音声入力 ===== */
function startVoice(){
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if(!SpeechRecognition){
    alert("Chromeで開いてね");
    return;
  }

  const r = new SpeechRecognition();
  r.lang="ja-JP";

  r.onresult=(e)=>{
    const text=e.results[0][0].transcript;
    userInput.value=text;
    sendMessage();
  };

  r.start();
}

/* ===== 初回 ===== */
window.onload=()=>{
  updateTheme();

  let greet="おかえり";
  if(love > 20) greet="おかえり、待ってた";

  if(userName) greet=userName+"、"+greet;

  addMessage(greet,"bot");
};

</script>

</body>
</html>
