<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ピピAI</title>

<style>
body {
  margin:0;
  font-family:sans-serif;
  background:linear-gradient(#2b314d,#09111f);
  color:white;
}

.app {
  display:flex;
  flex-direction:column;
  height:100vh;
}

.top-character {
  height:34vh;
  display:flex;
  justify-content:center;
  align-items:center;
}

.top-character img {
  width:92%;
  border-radius:24px;
}

.chat {
  flex:1;
  overflow:auto;
  padding:10px;
}

.message {
  margin:8px;
  padding:14px;
  border-radius:20px;
  max-width:85%;
  line-height:1.8;
}

.bot { background:rgba(255,255,255,0.1); }
.user { background:#ff4f8b; margin-left:auto; }

.input {
  display:flex;
  gap:8px;
  padding:10px;
}

input {
  flex:1;
  padding:14px;
  border-radius:16px;
  border:none;
}

button {
  border:none;
  border-radius:16px;
  padding:12px 18px;
  background:#ff4f8b;
  color:white;
}

.status {
  font-size:12px;
  padding:6px 10px;
}
</style>
</head>

<body>

<div class="app">

<div class="top-character">
<img id="face" src="girl-normal.jpg">
</div>

<div id="chat" class="chat"></div>

<div id="status" class="status">準備OK</div>

<div class="input">
<input id="text" placeholder="話してみて…">
<button onclick="send()">送信</button>
</div>

</div>

<script>
const chat = document.getElementById("chat");
const input = document.getElementById("text");
const status = document.getElementById("status");
const face = document.getElementById("face");

let apiKey = "";
let gptOn = false;
let voiceOn = true;

function add(text,type){
  const d = document.createElement("div");
  d.className = "message "+type;
  d.textContent = text;
  chat.appendChild(d);
  chat.scrollTop = chat.scrollHeight;
}

function setFace(type){
  const map = {
    normal:"girl-normal.jpg",
    happy:"girl-happy.png",
    tired:"girl-exhausted.png",
    sad:"girl-sympathy.png"
  };
  face.src = map[type] || map.normal;
}

function speak(text){
  if(!voiceOn) return;
  if(!window.speechSynthesis) return;

  const u = new SpeechSynthesisUtterance(text);
  u.lang="ja-JP";
  speechSynthesis.cancel();
  speechSynthesis.speak(u);
}

function localReply(t){
  if(t.includes("疲れ")){
    setFace("tired");
    return "それ、かなり消耗するよね。今少し休めそう？";
  }
  if(t.includes("嬉しい")){
    setFace("happy");
    return "それいいね😊 少し気持ち軽くなった？";
  }
  setFace("normal");
  return "ちゃんと聞いてるよ。もう少し話せそう？";
}

async function send(){
  const text = input.value.trim();
  if(!text) return;

  add(text,"user");
  input.value="";
  status.textContent="考え中…";

  let reply;

  if(gptOn && apiKey){
    reply = await gpt(text);
  }else{
    reply = localReply(text);
  }

  add(reply,"bot");
  speak(reply);
  status.textContent="準備OK";
}

async function gpt(text){
  try{
    const res = await fetch("https://api.openai.com/v1/chat/completions",{
      method:"POST",
      headers:{
        "Content-Type":"application/json",
        "Authorization":"Bearer "+apiKey
      },
      body:JSON.stringify({
        model:"gpt-4o-mini",
        messages:[
          {
            role:"system",
            content:`
自然な会話をする女性。

ルール:
- オウム返し禁止
- 同じ言い回し禁止
- 毎回違う返答
- 自然に寄り添う
`
          },
          {role:"user",content:text}
        ],
        temperature:1.1
      })
    });

    const data = await res.json();
    return data.choices[0].message.content;

  }catch(e){
    return localReply(text);
  }
}
</script>

</body>
</html>
