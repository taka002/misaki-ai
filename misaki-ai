<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>美咲AI 完全版</title>

  <style>
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      width: 100%;
      overflow: hidden;
      font-family: "Hiragino Sans", "Yu Gothic", sans-serif;
      transition: background 0.45s ease;
    }

    body {
      background: linear-gradient(to bottom, #2b314d, #09111f);
      color: white;
      display: flex;
      flex-direction: column;
    }

    .app {
      width: 100%;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .top-character {
      flex: 0 0 34vh;
      min-height: 240px;
      max-height: 360px;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 14px 14px 8px;
      position: relative;
    }

    .top-character img {
      width: min(92vw, 520px);
      height: 100%;
      object-fit: cover;
      border-radius: 28px;
      border: 3px solid rgba(255,255,255,0.14);
      box-shadow: 0 16px 34px rgba(0,0,0,0.38);
      background: rgba(255,255,255,0.03);
      transition: all 0.28s ease;
      display: block;
    }

    .settings-open {
      position: absolute;
      top: 18px;
      right: 18px;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      border: none;
      font-size: 32px;
      background: rgba(255,255,255,0.16);
      color: white;
      backdrop-filter: blur(8px);
      box-shadow: 0 10px 26px rgba(0,0,0,0.22);
      cursor: pointer;
      z-index: 5;
    }

    .chat-section {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      padding: 0 12px;
      overflow: hidden;
    }

    #chatBox {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 6px 2px 12px;
      scroll-behavior: smooth;
    }

    .message {
      max-width: 86%;
      padding: 16px 18px;
      border-radius: 24px;
      font-size: clamp(16px, 2.4vw, 18px);
      line-height: 1.95;
      white-space: pre-wrap;
      word-break: break-word;
      animation: fadeIn 0.22s ease;
    }

    .bot {
      align-self: flex-start;
      background: rgba(255,255,255,0.11);
      border-bottom-left-radius: 10px;
      color: #fff;
      box-shadow: 0 8px 18px rgba(0,0,0,0.12);
    }

    .user {
      align-self: flex-end;
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      border-bottom-right-radius: 10px;
      color: white;
      box-shadow: 0 8px 18px rgba(255,93,151,0.25);
    }

    .typing {
      opacity: 0.72;
      font-style: italic;
    }

    .status-bar {
      flex-shrink: 0;
      font-size: 13px;
      opacity: 0.82;
      padding: 0 16px 8px;
      min-height: 22px;
    }

    .input-area {
      flex-shrink: 0;
      display: grid;
      grid-template-columns: 1fr 88px 112px;
      gap: 10px;
      padding: 12px;
      background: rgba(0,0,0,0.24);
      border-top: 1px solid rgba(255,255,255,0.08);
      align-items: center;
    }

    input[type="text"], input[type="password"], select {
      width: 100%;
      min-width: 0;
      padding: 16px 18px;
      border-radius: 20px;
      border: none;
      outline: none;
      font-size: 18px;
      background: rgba(255,255,255,0.96);
      color: #222;
    }

    .mic-btn, .send-btn {
      border: none;
      border-radius: 24px;
      color: white;
      cursor: pointer;
      font-weight: bold;
      box-shadow: 0 12px 24px rgba(0,0,0,0.16);
    }

    .mic-btn {
      width: 88px;
      height: 84px;
      font-size: 34px;
      background: rgba(255,255,255,0.12);
    }

    .mic-btn.listening {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
      box-shadow: 0 0 0 8px rgba(122,105,255,0.18);
    }

    .send-btn {
      width: 112px;
      height: 84px;
      font-size: 22px;
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      box-shadow: 0 14px 28px rgba(255,79,139,0.28);
    }

    .send-btn:active,
    .mic-btn:active,
    .settings-open:active {
      transform: scale(0.97);
    }

    #chatBox::-webkit-scrollbar {
      width: 6px;
    }

    #chatBox::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.18);
      border-radius: 999px;
    }

    .speaking {
      animation: pulseTalk 0.75s infinite ease-in-out;
    }

    .face-change {
      animation: facePop 0.25s ease;
    }

    @keyframes pulseTalk {
      0%   { transform: scale(1) translateY(0px); }
      25%  { transform: scale(1.01) translateY(-1px); }
      50%  { transform: scale(1.02) translateY(0px); }
      75%  { transform: scale(1.01) translateY(-1px); }
      100% { transform: scale(1) translateY(0); }
    }

    @keyframes facePop {
      0%   { transform: scale(0.97); opacity: 0.75; }
      100% { transform: scale(1); opacity: 1; }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 999;
      padding: 18px;
    }

    .modal.show {
      display: flex;
    }

    .modal-box {
      width: 100%;
      max-width: 420px;
      max-height: 88vh;
      overflow-y: auto;
      background: #2a2236;
      border-radius: 28px;
      padding: 22px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.45);
    }

    .modal-title {
      font-size: 26px;
      font-weight: bold;
      color: #ffd1e6;
      margin-bottom: 18px;
    }

    .setting-row {
      margin-bottom: 16px;
    }

    .setting-label {
      font-size: 16px;
      opacity: 0.95;
      margin-bottom: 8px;
      display: block;
      line-height: 1.6;
    }

    .setting-input {
      width: 100%;
      padding: 16px;
      border-radius: 18px;
      border: none;
      font-size: 18px;
      outline: none;
    }

    .toggle-btn, .danger-btn, .close-btn, .save-btn, .voice-chip {
      width: 100%;
      padding: 16px;
      border: none;
      border-radius: 18px;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 10px;
    }

    .toggle-btn {
      background: #5f5470;
      color: white;
    }

    .danger-btn {
      background: #8a3d57;
      color: white;
    }

    .save-btn {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
      color: white;
    }

    .close-btn {
      background: linear-gradient(135deg, #ff7eb3, #ff4f8b);
      color: white;
    }

    .hint {
      font-size: 13px;
      opacity: 0.72;
      margin-top: 6px;
      line-height: 1.6;
    }

    .voice-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    .voice-chip {
      padding: 14px 10px;
      font-size: 15px;
      background: rgba(255,255,255,0.1);
      color: white;
      margin-top: 0;
    }

    .voice-chip.active {
      background: linear-gradient(135deg, #7a69ff, #5f9bff);
    }

    @media (max-width: 430px) {
      .top-character {
        flex: 0 0 32vh;
        min-height: 220px;
      }

      .settings-open {
        width: 68px;
        height: 68px;
        font-size: 28px;
      }

      .input-area {
        grid-template-columns: 1fr 84px 106px;
      }

      .mic-btn {
        width: 84px;
        height: 80px;
      }

      .send-btn {
        width: 106px;
        height: 80px;
      }

      .voice-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="app">

    <div class="top-character">
      <img id="mainGirl" src="girl-normal.jpg" alt="美咲">
      <button class="settings-open" onclick="openSettings()">⚙</button>
    </div>

    <div class="chat-section">
      <div id="chatBox"></div>
    </div>

    <div class="status-bar" id="statusBar">準備OK</div>

    <div class="input-area">
      <input type="text" id="userInput" placeholder="何か話してみて…" />
      <button class="mic-btn" id="micBtn" onclick="startVoiceInput()">🎤</button>
      <button class="send-btn" onclick="sendMessage()">送信</button>
    </div>
  </div>

  <div class="modal" id="settingsModal">
    <div class="modal-box">
      <div class="modal-title">設定</div>

      <div class="setting-row">
        <label class="setting-label">あなたの呼び名（時々呼ぶ）</label>
        <input class="setting-input" id="userNameInput" placeholder="だいすけ">
      </div>

      <div class="setting-row">
        <label class="setting-label">キャラ名</label>
        <input class="setting-input" id="nameInput" placeholder="美咲">
      </div>

      <div class="setting-row">
        <label class="setting-label">OpenAI APIキー（保存ON / 後でリセット可）</label>
        <input class="setting-input" id="apiKeyInput" type="password" placeholder="sk-..." />
        <div class="hint">保存して使えます。使い終わったら「APIキーを消す」で削除できます。</div>
      </div>

      <div class="setting-row">
        <label class="setting-label">ElevenLabs APIキー（保存ON / 後でリセット可）</label>
        <input class="setting-input" id="elevenApiKeyInput" type="password" placeholder="sk_..." />
        <div class="hint">自然音声を使う時だけ保存して使えます。</div>
      </div>

      <div class="setting-row">
        <label class="setting-label">Voice ID（保存ON / 後でリセット可）</label>
        <input class="setting-input" id="voiceIdInput" type="text" placeholder="wcs09USXSN5Bl7FXohVZ" />
        <div class="hint">ElevenLabsの声IDです。</div>
      </div>

      <div class="setting-row">
        <label class="setting-label">音声エンジン</label>
        <select class="setting-input" id="voiceEngineSelect">
          <option value="standard">スマホ標準音声</option>
          <option value="eleven">ElevenLabs音声</option>
        </select>
      </div>

      <div class="setting-row">
        <label class="setting-label">声の簡単切り替え（ボタン）</label>
        <div class="voice-grid">
          <button class="voice-chip" id="voiceChipGentle" onclick="setVoicePreset('gentle')">優しい</button>
          <button class="voice-chip" id="voiceChipBright" onclick="setVoicePreset('bright')">明るい</button>
          <button class="voice-chip" id="voiceChipCalm" onclick="setVoicePreset('calm')">落ち着き</button>
        </div>
        <div class="hint">押すと Voice ID 欄に反映されます。必要なら上書きしてOK。</div>
      </div>

      <button class="save-btn" onclick="saveSettings()">💾 保存する</button>
      <button class="toggle-btn" id="gptToggle" onclick="toggleGPT()">🤖 GPT OFF</button>
      <button class="toggle-btn" id="voiceToggle" onclick="toggleVoice()">🔊 音声ON</button>
      <button class="toggle-btn" id="elevenToggle" onclick="toggleElevenVoice()">🎙 Eleven音声OFF</button>
      <button class="toggle-btn" id="wakeToggle" onclick="toggleWakeWord()">👂 ウェイクON</button>
      <button class="danger-btn" onclick="resetApiKeys()">APIキーを消す</button>
      <button class="danger-btn" onclick="resetMemory()">記憶をリセット</button>
      <button class="close-btn" onclick="closeSettings()">閉じる</button>
    </div>
  </div>

  <script>
    const chatBox = document.getElementById("chatBox");
    const userInput = document.getElementById("userInput");
    const mainGirl = document.getElementById("mainGirl");
    const settingsModal = document.getElementById("settingsModal");
    const voiceToggleBtn = document.getElementById("voiceToggle");
    const gptToggleBtn = document.getElementById("gptToggle");
    const nameInput = document.getElementById("nameInput");
    const userNameInput = document.getElementById("userNameInput");
    const apiKeyInput = document.getElementById("apiKeyInput");
    const elevenApiKeyInput = document.getElementById("elevenApiKeyInput");
    const voiceIdInput = document.getElementById("voiceIdInput");
    const voiceEngineSelect = document.getElementById("voiceEngineSelect");
    const statusBar = document.getElementById("statusBar");
    const micBtn = document.getElementById("micBtn");
    const wakeToggleBtn = document.getElementById("wakeToggle");

    let voiceEnabled = localStorage.getItem("voiceEnabled") !== "false";
    let gptEnabled = localStorage.getItem("gptEnabled") === "true";
    let elevenVoiceEnabled = localStorage.getItem("elevenVoiceEnabled") === "true";
    let voiceEngine = localStorage.getItem("voiceEngine") || "standard";
    let selectedVoicePreset = localStorage.getItem("selectedVoicePreset") || "";
    let wakeWordEnabled = localStorage.getItem("wakeWordEnabled") !== "false";

    let availableVoices = [];
    let recognition = null;
    let wakeRecognition = null;

    let isListening = false;
    let isSpeaking = false;
    let justWokeUp = false;
    let wakeCooldown = false;
    let lastBotReply = "";

    let sessionSecrets = {
      apiKey: localStorage.getItem("saved_apiKey") || "",
      elevenApiKey: localStorage.getItem("saved_elevenApiKey") || "",
      voiceId: localStorage.getItem("saved_voiceId") || ""
    };

    let memory = {
      characterName: localStorage.getItem("characterName") || "美咲",
      userName: localStorage.getItem("userNickName") || "",
      mood: localStorage.getItem("hostess_mood") || "",
      topic: localStorage.getItem("hostess_topic") || "",
      lastMessage: localStorage.getItem("hostess_lastMessage") || "",
      visitCount: parseInt(localStorage.getItem("hostess_visitCount") || "0", 10),
      chatHistory: JSON.parse(localStorage.getItem("hostess_chatHistory") || "[]"),

      currentFeeling: localStorage.getItem("hostess_currentFeeling") || "",
      currentNeed: localStorage.getItem("hostess_currentNeed") || "",
      unresolvedTopic: localStorage.getItem("hostess_unresolvedTopic") || "",
      lastBotQuestion: localStorage.getItem("hostess_lastBotQuestion") || ""
    };

    memory.visitCount += 1;
    localStorage.setItem("hostess_visitCount", memory.visitCount);

    nameInput.value = memory.characterName;
    userNameInput.value = memory.userName;
    apiKeyInput.value = sessionSecrets.apiKey;
    elevenApiKeyInput.value = sessionSecrets.elevenApiKey;
    voiceIdInput.value = sessionSecrets.voiceId;
    voiceEngineSelect.value = voiceEngine;

    updateVoiceButton();
    updateGPTButton();
    updateElevenButton();
    updateWakeButton();
    updateVoicePresetButtons();

    const faceImages = {
      normal: "girl-normal.jpg",
      worried: "girl-worried.png",
      sympathy: "girl-sympathy.png",
      troubled: "girl-troubled.png",
      healing: "girl-healing.png",
      happy: "girl-happy.png",
      irritated: "girl-irritated.png",
      panic: "girl-panic.png",
      exhausted: "girl-exhausted.png"
    };

    const moodBackgrounds = {
      normal: "linear-gradient(to bottom, #2b314d, #09111f)",
      worried: "linear-gradient(to bottom, #3f4c6b, #151d2b)",
      sympathy: "linear-gradient(to bottom, #4a3b60, #161626)",
      troubled: "linear-gradient(to bottom, #4c4b67, #151b28)",
      healing: "linear-gradient(to bottom, #5b4767, #171629)",
      happy: "linear-gradient(to bottom, #485f8b, #12203b)",
      irritated: "linear-gradient(to bottom, #5f3a4f, #1a111b)",
      panic: "linear-gradient(to bottom, #5a5068, #181724)",
      exhausted: "linear-gradient(to bottom, #4b5165, #121926)"
    };

    const voicePresets = {
      gentle: "wcs09USXSN5Bl7FXohVZ",
      bright: "21m00Tcm4TlvDq8ikWAM",
      calm: "AZnzlk1XvdvUeBnXmlld"
    };

    const wakeWords = ["みさき", "美咲", "ミサキ"];

    function getNaturalWakeReply() {
      const replies = [
        "ん、どうした？",
        "うん、なに？",
        "呼んだ？",
        "どうしたの？",
        "聞いてるよ",
        "うん、いるよ"
      ];
      return replies[Math.floor(Math.random() * replies.length)];
    }

    function getAutoVoiceIdByMood() {
      if (memory.mood === "happy") return voicePresets.bright;
      if (memory.mood === "sympathy" || memory.mood === "healing" || memory.mood === "exhausted") return voicePresets.gentle;
      if (memory.mood === "worried" || memory.mood === "panic" || memory.mood === "troubled") return voicePresets.calm;
      return voiceIdInput.value.trim() || sessionSecrets.voiceId || voicePresets.gentle;
    }

    function setStatus(text) {
      statusBar.textContent = text;
    }

    function setFace(type = "normal") {
      const src = faceImages[type] || faceImages.normal;
      mainGirl.src = src;
      document.body.style.background = moodBackgrounds[type] || moodBackgrounds.normal;

      mainGirl.classList.remove("face-change");
      void mainGirl.offsetWidth;
      mainGirl.classList.add("face-change");
    }

    function flashWakeFace() {
      const beforeMood = memory.mood || "normal";
      setFace("happy");
      setTimeout(() => {
        setFace(beforeMood);
      }, 1200);
    }

    function startSpeakingAnimation() {
      mainGirl.classList.add("speaking");
      isSpeaking = true;
    }

    function stopSpeakingAnimation() {
      mainGirl.classList.remove("speaking");
      isSpeaking = false;
    }

    function openSettings() {
      nameInput.value = memory.characterName || "美咲";
      userNameInput.value = memory.userName || "";
      apiKeyInput.value = sessionSecrets.apiKey || "";
      elevenApiKeyInput.value = sessionSecrets.elevenApiKey || "";
      voiceIdInput.value = sessionSecrets.voiceId || "";
      voiceEngineSelect.value = voiceEngine;
      settingsModal.classList.add("show");
    }

    function closeSettings() {
      settingsModal.classList.remove("show");
    }

    function saveSettings() {
      memory.characterName = nameInput.value.trim() || "美咲";
      memory.userName = userNameInput.value.trim();

      sessionSecrets.apiKey = apiKeyInput.value.trim();
      sessionSecrets.elevenApiKey = elevenApiKeyInput.value.trim();
      sessionSecrets.voiceId = voiceIdInput.value.trim();

      voiceEngine = voiceEngineSelect.value;
      localStorage.setItem("voiceEngine", voiceEngine);
      localStorage.setItem("characterName", memory.characterName);
      localStorage.setItem("userNickName", memory.userName);
      localStorage.setItem("saved_apiKey", sessionSecrets.apiKey);
      localStorage.setItem("saved_elevenApiKey", sessionSecrets.elevenApiKey);
      localStorage.setItem("saved_voiceId", sessionSecrets.voiceId);

      addMessage("設定を保存したよ😊", "bot");
      setStatus("設定を保存しました");
      closeSettings();
    }

    function resetApiKeys() {
      sessionSecrets.apiKey = "";
      sessionSecrets.elevenApiKey = "";
      sessionSecrets.voiceId = "";

      localStorage.removeItem("saved_apiKey");
      localStorage.removeItem("saved_elevenApiKey");
      localStorage.removeItem("saved_voiceId");

      apiKeyInput.value = "";
      elevenApiKeyInput.value = "";
      voiceIdInput.value = "";

      addMessage("APIキーを消したよ😊", "bot");
      setStatus("APIキーを削除しました");
    }

    function toggleVoice() {
      voiceEnabled = !voiceEnabled;
      localStorage.setItem("voiceEnabled", voiceEnabled);
      updateVoiceButton();

      if (!voiceEnabled && ("speechSynthesis" in window)) {
        window.speechSynthesis.cancel();
        stopSpeakingAnimation();
      }
    }

    function toggleGPT() {
      gptEnabled = !gptEnabled;
      localStorage.setItem("gptEnabled", gptEnabled);
      updateGPTButton();
      setStatus(gptEnabled ? "GPT接続ON" : "GPT接続OFF");
    }

    function toggleElevenVoice() {
      elevenVoiceEnabled = !elevenVoiceEnabled;
      localStorage.setItem("elevenVoiceEnabled", elevenVoiceEnabled);
      updateElevenButton();
      setStatus(elevenVoiceEnabled ? "Eleven音声ON" : "Eleven音声OFF");
    }

    function toggleWakeWord() {
      wakeWordEnabled = !wakeWordEnabled;
      localStorage.setItem("wakeWordEnabled", wakeWordEnabled);
      updateWakeButton();
      setStatus(wakeWordEnabled ? "ウェイクワードON" : "ウェイクワードOFF");
      stopWakeWordListening();
    }

    function updateVoiceButton() {
      voiceToggleBtn.textContent = voiceEnabled ? "🔊 音声ON" : "🔇 音声OFF";
    }

    function updateGPTButton() {
      gptToggleBtn.textContent = gptEnabled ? "🤖 GPT ON" : "🤖 GPT OFF";
    }

    function updateElevenButton() {
      const btn = document.getElementById("elevenToggle");
      if (btn) {
        btn.textContent = elevenVoiceEnabled ? "🎙 Eleven音声ON" : "🎙 Eleven音声OFF";
      }
    }

    function updateWakeButton() {
      if (wakeToggleBtn) {
        wakeToggleBtn.textContent = wakeWordEnabled ? "👂 ウェイクON" : "👂 ウェイクOFF";
      }
    }

    function setVoicePreset(type) {
      selectedVoicePreset = type;
      localStorage.setItem("selectedVoicePreset", selectedVoicePreset);

      if (voicePresets[type]) {
        voiceIdInput.value = voicePresets[type];
        sessionSecrets.voiceId = voicePresets[type];
        localStorage.setItem("saved_voiceId", sessionSecrets.voiceId);
        setStatus("Voice ID を切り替えました");
      }

      updateVoicePresetButtons();
    }

    function updateVoicePresetButtons() {
      ["gentle", "bright", "calm"].forEach(type => {
        const idMap = {
          gentle: "voiceChipGentle",
          bright: "voiceChipBright",
          calm: "voiceChipCalm"
        };
        const btn = document.getElementById(idMap[type]);
        if (!btn) return;
        btn.classList.toggle("active", selectedVoicePreset === type);
      });
    }

    function resetMemory() {
      localStorage.removeItem("hostess_mood");
      localStorage.removeItem("hostess_topic");
      localStorage.removeItem("hostess_lastMessage");
      localStorage.removeItem("hostess_visitCount");
      localStorage.removeItem("hostess_chatHistory");
      localStorage.removeItem("hostess_currentFeeling");
      localStorage.removeItem("hostess_currentNeed");
      localStorage.removeItem("hostess_unresolvedTopic");
      localStorage.removeItem("hostess_lastBotQuestion");

      memory.mood = "";
      memory.topic = "";
      memory.lastMessage = "";
      memory.visitCount = 1;
      memory.chatHistory = [];
      memory.currentFeeling = "";
      memory.currentNeed = "";
      memory.unresolvedTopic = "";
      memory.lastBotQuestion = "";

      addMessage("記憶をリセットしたよ😊\nまた最初からゆっくり話そう。", "bot");
      setFace("healing");
      setStatus("記憶をリセットしました");
      closeSettings();
    }

    function loadVoices() {
      if (!("speechSynthesis" in window)) return;
      availableVoices = window.speechSynthesis.getVoices();
    }

    if ("speechSynthesis" in window) {
      loadVoices();
      window.speechSynthesis.onvoiceschanged = loadVoices;
    }

    document.body.addEventListener("click", unlockSpeech, { once: false });
    document.body.addEventListener("touchstart", unlockSpeech, { once: false });

    function unlockSpeech() {
      try {
        if (!("speechSynthesis" in window)) return;
        const synth = window.speechSynthesis;
        const u = new SpeechSynthesisUtterance(" ");
        u.volume = 0;
        synth.speak(u);
      } catch (e) {}
    }

    setTimeout(() => {
      setFace("normal");
      botReply(getWelcomeMessage(), true);
    }, 700);

    function getWelcomeMessage() {
      const name = memory.characterName || "美咲";
      const user = memory.userName ? `${memory.userName}さん、` : "";

      if (memory.visitCount >= 2 && memory.currentFeeling === "tired") {
        return `${user}${name}だよ😊\n前もちょっとしんどそうだったよね。\n今日は昨日よりきつい感じある？`;
      }

      if (memory.visitCount >= 2 && memory.currentFeeling === "anxious") {
        return `${user}${name}だよ😊\n前もちょっと不安そうだったよね。\n今日は少し落ち着いてる？`;
      }

      if (memory.visitCount >= 2 && memory.currentFeeling === "sad") {
        return `${user}${name}だよ😊\n前もちょっと心が沈んでる感じあったよね。\n今日はどんな感じ？`;
      }

      return `${user}${name}だよ😊\n今日はどんな感じだった？`;
    }

    function addMessage(text, sender, extraClass = "") {
      const msg = document.createElement("div");
      msg.className = `message ${sender} ${extraClass}`;
      msg.textContent = text;
      chatBox.appendChild(msg);
      chatBox.scrollTop = chatBox.scrollHeight;
      return msg;
    }

    function botReply(text, isWelcome = false) {
      lastBotReply = text;
      addMessage(text, "bot");
      saveChat("assistant", text);
      speakText(text, isWelcome);
    }

    async function sendMessage() {
      const text = userInput.value.trim();
      if (!text) return;

      if (window.speechSynthesis) {
        window.speechSynthesis.cancel();
      }
      stopSpeakingAnimation();
      stopWakeWordListening();

      addMessage(text, "user");
      saveChat("user", text);
      userInput.value = "";

      const typingMsg = addMessage("…入力中", "bot", "typing");

      try {
        let reply = "";

        if (gptEnabled && sessionSecrets.apiKey) {
          setStatus("GPTで考え中…");
          reply = await generateGPTReply(text);
        } else {
          setStatus("寄り添い返答中…");
          reply = generateLocalReply(text);
        }

        typingMsg.remove();
        botReply(reply);
        setStatus("準備OK");
      } catch (e) {
        console.error(e);
        typingMsg.remove();
        const fallback = generateLocalReply(text);
        botReply(fallback);
        setStatus("GPT失敗 → ローカル返答");
      }
    }

    userInput.addEventListener("keypress", e => {
      if (e.key === "Enter") sendMessage();
    });

    function saveChat(role, content) {
      memory.chatHistory.push({ role, content });
      if (memory.chatHistory.length > 24) {
        memory.chatHistory = memory.chatHistory.slice(-24);
      }
      localStorage.setItem("hostess_chatHistory", JSON.stringify(memory.chatHistory));
    }

    function rememberUserInfo(text, lower) {
      memory.lastMessage = text;

      if (containsAny(lower, ["仕事", "会社", "上司", "職場", "残業"])) {
        memory.topic = "work";
      } else if (containsAny(lower, ["家族", "子ども", "娘", "息子"])) {
        memory.topic = "family";
      } else if (containsAny(lower, ["不安", "眠れない", "寝れない"])) {
        memory.topic = "anxiety";
      } else if (containsAny(lower, ["体調", "病院", "不調"])) {
        memory.topic = "health";
      }

      saveMemory();
    }

    function saveMemory() {
      localStorage.setItem("hostess_mood", memory.mood || "");
      localStorage.setItem("hostess_topic", memory.topic || "");
      localStorage.setItem("hostess_lastMessage", memory.lastMessage || "");
      localStorage.setItem("hostess_currentFeeling", memory.currentFeeling || "");
      localStorage.setItem("hostess_currentNeed", memory.currentNeed || "");
      localStorage.setItem("hostess_unresolvedTopic", memory.unresolvedTopic || "");
      localStorage.setItem("hostess_lastBotQuestion", memory.lastBotQuestion || "");
    }

    function containsAny(text, words) {
      return words.some(word => text.includes(word.toLowerCase()));
    }

    function pick(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function maybeCallUserName() {
      if (!memory.userName) return "";
      return Math.random() < 0.35 ? `${memory.userName}さん、` : "";
    }

    function analyzeContext(text) {
      const lower = text.toLowerCase();

      if (containsAny(lower, ["悲しい", "泣きたい", "寂しい", "つらい", "苦しい"])) {
        memory.currentFeeling = "sad";
      } else if (containsAny(lower, ["不安", "こわい", "怖い", "心配"])) {
        memory.currentFeeling = "anxious";
      } else if (containsAny(lower, ["イライラ", "むかつく", "腹立つ"])) {
        memory.currentFeeling = "angry";
      } else if (containsAny(lower, ["疲れた", "しんどい", "無理", "限界"])) {
        memory.currentFeeling = "tired";
      }

      if (containsAny(lower, ["聞いて", "つらい", "悲しい", "しんどい"])) {
        memory.currentNeed = "empathy";
      } else if (containsAny(lower, ["どうしたら", "どうすれば", "わからない", "困る"])) {
        memory.currentNeed = "guidance";
      } else if (containsAny(lower, ["寂しい", "ひとり", "会いたい"])) {
        memory.currentNeed = "connection";
      }

      if (containsAny(lower, ["仕事", "会社", "上司", "職場"])) {
        memory.unresolvedTopic = "work";
      } else if (containsAny(lower, ["家族", "娘", "息子", "子ども"])) {
        memory.unresolvedTopic = "family";
      } else if (containsAny(lower, ["体調", "病院", "不調"])) {
        memory.unresolvedTopic = "health";
      } else if (containsAny(lower, ["人間関係", "友達", "恋愛"])) {
        memory.unresolvedTopic = "relationship";
      }

      saveMemory();
    }

    function generateLocalReply(text) {
      const t = text.trim();
      const lower = t.toLowerCase();

      rememberUserInfo(t, lower);
      analyzeContext(t);

      const callName = maybeCallUserName();

      if (containsAny(lower, ["疲れた", "しんどい", "限界", "無理", "へとへと"])) {
        setFace("exhausted");
        memory.mood = "exhausted";
        memory.currentFeeling = "tired";
        memory.currentNeed = "empathy";
        memory.lastBotQuestion = "何で一番すり減った？";
        saveMemory();

        return pick([
          `${callName}かなり削られてる感じあるね…。\n今日はもう頑張った側だと思うよ。\n何で一番すり減った？`,
          `${callName}しんどい時って、気持ちも体も両方重くなるよね。\n今はどっちが強い？体？気持ち？`,
          `${callName}限界寄りっぽいね…。\nここではちゃんと弱音吐いていいよ。\n今日いちばんきつかった場面ってどこ？`
        ]);
      }

      setFace("normal");
      memory.mood = "normal";
      memory.lastBotQuestion = "もう少し詳しく話せそう？";
      saveMemory();

      return pick([
        `${callName}うん、ちゃんと聞いてるよ。\nもう少し詳しく話せそう？`,
        `${callName}なるほど…。\nその続き、もう少し聞いてもいい？`,
        `${callName}うん、大丈夫。\n今の気持ちをそのまま話してみて。`
      ]);
    }

    async function generateGPTReply(userText) {
      const lower = userText.toLowerCase();
      rememberUserInfo(userText, lower);
      analyzeContext(userText);

      const recentHistory = memory.chatHistory.slice(-12).map(item => ({
        role: item.role,
        content: item.content
      }));

      const systemPrompt = `
あなたは「${memory.characterName || "美咲"}」という、落ち着いた大人の女性です。
ユーザーに寄り添い、自然で人間らしい会話をしてください。

会話方針:
- 日本語で返答
- AIっぽい説明をしない
- オウム返しを避ける
- 相手の気持ちを先に受け止める
- やさしいけど不自然にベタベタしない
- カウンセリング風すぎず、自然な会話
- 短すぎず長すぎず
- 返答の最後に軽い問いかけ or 受け止めを入れる
- 「大丈夫？」ばかり使わない
- 「つらかったね」だけで終わらせない
- 必要なら感情を言語化して整理する
- 時々だけ ${memory.userName || "ユーザー"} の呼び名を自然に入れてよい
- 返答の文頭に必ず表情タグを1つだけ付ける

表情タグ:
[happy]
[healing]
[worried]
[sympathy]
[troubled]
[irritated]
[panic]
[exhausted]
[normal]
`;

      const messages = [
        { role: "system", content: systemPrompt },
        ...recentHistory,
        { role: "user", content: userText }
      ];

      const res = await fetch("https://api.openai.com/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${sessionSecrets.apiKey}`
        },
        body: JSON.stringify({
          model: "gpt-4o-mini",
          messages,
          temperature: 0.9
        })
      });

      if (!res.ok) {
        throw new Error("GPT API error");
      }

      const data = await res.json();
      const raw = data.choices?.[0]?.message?.content?.trim() || "うまく言葉が出なかったけど、ちゃんとここにいるよ。";
      return applyEmotionFromReply(raw);
    }

    function applyEmotionFromReply(text) {
      let mood = "normal";
      let cleaned = text;

      const tags = ["happy", "healing", "worried", "sympathy", "troubled", "irritated", "panic", "exhausted", "normal"];

      for (const tag of tags) {
        const pattern = new RegExp(`^\\[${tag}\\]\\s*`, "i");
        if (pattern.test(cleaned)) {
          mood = tag;
          cleaned = cleaned.replace(pattern, "");
          break;
        }
      }

      memory.mood = mood;
      saveMemory();
      setFace(mood);

      return cleaned;
    }

    function getVoiceStyleByMood(mood) {
      switch (mood) {
        case "happy":
          return { rate: 0.97, pitch: 1.18 };
        case "healing":
          return { rate: 0.87, pitch: 1.12 };
        case "sympathy":
          return { rate: 0.86, pitch: 1.06 };
        case "exhausted":
          return { rate: 0.84, pitch: 1.02 };
        case "panic":
          return { rate: 0.91, pitch: 1.10 };
        case "irritated":
          return { rate: 0.90, pitch: 0.98 };
        case "troubled":
          return { rate: 0.88, pitch: 1.03 };
        default:
          return { rate: 0.92, pitch: 1.08 };
      }
    }

    async function speakText(text, isWelcome = false) {
      if (!voiceEnabled) return;

      const cleanText = text
        .replace(/\n/g, "。")
        .replace(/😊|♡|✨|😌|😢|🥺|😳|💦|💭/g, "")
        .replace(/…/g, "、")
        .trim();

      if (!cleanText) return;

      const engine = voiceEngineSelect.value || voiceEngine || "standard";

      if (
        engine === "eleven" &&
        elevenVoiceEnabled &&
        sessionSecrets.elevenApiKey
      ) {
        try {
          setStatus("Eleven音声で話してるよ…");
          startSpeakingAnimation();

          const autoVoiceId = getAutoVoiceIdByMood();
          const currentVoiceId = voiceIdInput.value.trim() || sessionSecrets.voiceId || autoVoiceId;

          const res = await fetch(`https://api.elevenlabs.io/v1/text-to-speech/${currentVoiceId}`, {
            method: "POST",
            headers: {
              "xi-api-key": sessionSecrets.elevenApiKey,
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              text: cleanText,
              model_id: "eleven_multilingual_v2",
              voice_settings: {
                stability: 0.55,
                similarity_boost: 0.78
              }
            })
          });

          if (!res.ok) throw new Error("ElevenLabs error");

          const blob = await res.blob();
          const audioUrl = URL.createObjectURL(blob);
          const audio = new Audio(audioUrl);

          audio.onended = () => {
            stopSpeakingAnimation();
            setStatus("準備OK");
            URL.revokeObjectURL(audioUrl);
          };

          audio.onerror = () => {
            stopSpeakingAnimation();
            setStatus("Eleven音声エラー → 標準音声へ");
            URL.revokeObjectURL(audioUrl);
            fallbackSpeech(cleanText, isWelcome);
          };

          await audio.play();
          return;

        } catch (e) {
          console.error("Eleven音声失敗", e);
          stopSpeakingAnimation();
          setStatus("Eleven音声失敗 → 標準音声へ");
          fallbackSpeech(cleanText, isWelcome);
          return;
        }
      }

      fallbackSpeech(cleanText, isWelcome);
    }

    function fallbackSpeech(cleanText, isWelcome = false) {
      if (!("speechSynthesis" in window)) {
        setStatus("この環境では音声非対応");
        return;
      }

      try {
        const synth = window.speechSynthesis;
        synth.cancel();

        const delay = isWelcome ? 600 : 220;

        setTimeout(() => {
          try {
            const utterance = new SpeechSynthesisUtterance(cleanText);
            utterance.lang = "ja-JP";

            const voiceStyle = getVoiceStyleByMood(memory.mood);
            utterance.rate = voiceStyle.rate;
            utterance.pitch = voiceStyle.pitch;
            utterance.volume = 1.0;

            const voices = synth.getVoices();
            let preferredVoice =
              voices.find(v => v.lang && v.lang.includes("ja") && v.name.includes("Google")) ||
              voices.find(v => v.lang && v.lang.includes("ja"));

            if (preferredVoice) utterance.voice = preferredVoice;

            utterance.onstart = () => {
              startSpeakingAnimation();
              setStatus("話してるよ…");
            };

            utterance.onend = () => {
              stopSpeakingAnimation();
              setStatus("準備OK");
            };

            utterance.onerror = () => {
              stopSpeakingAnimation();
              setStatus("音声再生できませんでした");
            };

            synth.speak(utterance);
          } catch (err) {
            stopSpeakingAnimation();
            setStatus("音声エラー");
          }
        }, delay);

      } catch (e) {
        stopSpeakingAnimation();
        setStatus("音声エラー");
      }
    }

    function speakShortWakeReply(text) {
      return new Promise((resolve) => {
        if (!voiceEnabled || !("speechSynthesis" in window)) {
          resolve();
          return;
        }

        try {
          const synth = window.speechSynthesis;
          synth.cancel();

          const utterance = new SpeechSynthesisUtterance(text);
          utterance.lang = "ja-JP";
          utterance.rate = 1.0;
          utterance.pitch = 1.12;
          utterance.volume = 1.0;

          const voices = synth.getVoices();
          let preferredVoice =
            voices.find(v => v.lang && v.lang.includes("ja") && v.name.includes("Google")) ||
            voices.find(v => v.lang && v.lang.includes("ja"));

          if (preferredVoice) utterance.voice = preferredVoice;

          utterance.onstart = () => {
            startSpeakingAnimation();
            setStatus(text);
          };

          utterance.onend = () => {
            stopSpeakingAnimation();
            resolve();
          };

          utterance.onerror = () => {
            stopSpeakingAnimation();
            resolve();
          };

          synth.speak(utterance);
        } catch (e) {
          resolve();
        }
      });
    }

    function stopVoiceInput() {
      try {
        if (recognition) recognition.stop();
      } catch (e) {}
      isListening = false;
      micBtn.classList.remove("listening");
      setStatus("マイク停止");
    }

    function startVoiceInput() {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

      if (!SpeechRecognition) {
        alert("この環境ではマイク入力が使えません。\n\nおすすめ:\n・Chromeで開く\n・GitHub Pagesで開く\n・HTTPSで開く");
        return;
      }

      if (isListening) {
        stopVoiceInput();
        return;
      }

      stopWakeWordListening();

      try {
        recognition = new SpeechRecognition();
        recognition.lang = "ja-JP";
        recognition.interimResults = false;
        recognition.continuous = false;
        recognition.maxAlternatives = 1;

        isListening = true;
        micBtn.classList.add("listening");

        if (justWokeUp) {
          setStatus("🎤 どうぞ、話して");
        } else {
          setStatus("🎤 聞き取り中…話してください");
        }

        recognition.onresult = (event) => {
          const transcript = event.results[0][0].transcript || "";
          userInput.value = transcript.trim();
          setStatus("音声入力OK → 送信中");
          justWokeUp = false;
          setTimeout(() => sendMessage(), 350);
        };

        recognition.onerror = (event) => {
          if (event.error === "not-allowed") {
            setStatus("マイク許可が必要です");
            alert("マイクが拒否されています。\n\nChromeの設定でこのページのマイクを許可してください。");
          } else if (event.error === "no-speech") {
            setStatus("声が聞こえなかったみたい");
          } else {
            setStatus("マイク入力失敗");
          }

          justWokeUp = false;
          isListening = false;
          micBtn.classList.remove("listening");
        };

        recognition.onend = () => {
          isListening = false;
          micBtn.classList.remove("listening");
          if (statusBar.textContent.includes("聞き取り中") || statusBar.textContent.includes("どうぞ")) {
            setStatus("準備OK");
          }
          justWokeUp = false;
        };

        recognition.start();
      } catch (e) {
        justWokeUp = false;
        isListening = false;
        micBtn.classList.remove("listening");
        setStatus("マイク起動失敗");
      }
    }

