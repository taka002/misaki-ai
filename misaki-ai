<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 完成版</title>

<style>
html,body{
  margin:0;
  height:100%;
  overflow:hidden;
  background:#08121f;
  font-family:sans-serif;
  color:white;
}

/* ===== 画像 ===== */
.top{
  position:fixed;
  top:0;
  width:100%;
  height:28%;
  display:flex;
  justify-content:center;
  align-items:center;
}
.top img{
  width:90%;
  height:100%;
  object-fit:cover;
  border-radius:20px;
}

/* ===== チャット ===== */
#chatBox{
  position:fixed;
  top:28%;
  bottom:110px;
  width:100%;
  overflow-y:auto;
  padding:8px;
}

/* ===== メッセージ ===== */
.message{
  max-width:75%;
  padding:10px;
  border-radius:14px;
  margin:6px;
  font-size:13px;
}
.user{
  background:#ff4f8b;
  margin-left:auto;
}
.bot{
  background:#444;
}

/* ===== 入力 ===== */
.input{
  position:fixed;
  bottom:50px;
  width:100%;
  height:60px;
  display:flex;
  align-items:center;
  padding:6px;
  background:#111;
}

input{
  flex:1;
  padding:10px;
  border-radius:10px;
  border:none;
}

button{
  width:50px;
  margin-left:5px;
  border:none;
  border-radius:10px;
}

/* ===== タブ ===== */
.tabs{
  position:fixed;
  bottom:0;
  width:100%;
  height:50px;
  display:flex;
  background:#222;
}
.tab{
  flex:1;
  text-align:center;
  padding:8px;
  font-size:12px;
}
</style>
</head>

<body>

<div class="top">
<img id="face" src="girl-normal.jpg"
onerror="this.src='https://via.placeholder.com/300x200'">
</div>

<div id="chatBox"></div>

<div class="input">
<button onclick="startVoice()">🎤</button>
<input id="userInput" placeholder="話しかけて...">
<button onclick="sendMessage()">送信</button>
</div>

<div class="tabs">
<div class="tab">会話</div>
<div class="tab">分析</div>
<div class="tab">未来</div>
<div class="tab">設定</div>
</div>

<script>

/* ===== 表情 ===== */
const faces={
normal:"girl-normal.jpg",
happy:"girl-happy.png",
exhausted:"girl-exhausted.png",
worried:"girl-worried.png"
};

function setFace(type){
  document.getElementById("face").src=faces[type]||faces.normal;
}

/* ===== 時間 ===== */
function time(){
  const d=new Date();
  return d.getHours().toString().padStart(2,"0")+":"+
         d.getMinutes().toString().padStart(2,"0");
}

/* ===== メッセージ ===== */
function addMessage(text,type){
  const div=document.createElement("div");
  div.className="message "+type;

  if(type==="user"){
    div.innerHTML = text +
    `<div style="font-size:10px;color:#ddd;text-align:right">${time()} ✔✔</div>`;
  }else{
    div.innerHTML =
    `<div style="font-size:11px;color:#aaa">美咲</div>`+
    text+
    `<div style="font-size:10px;color:#aaa">${time()}</div>`;
  }

  chatBox.appendChild(div);
  chatBox.scrollTop = chatBox.scrollHeight;
}

/* ===== AI返信 ===== */
function replyAI(text){

  let reply="ちゃんと聞いてるよ";

  if(text.includes("疲")){
    reply="無理してない？少し休も？";
    setFace("exhausted");
  }
  else if(text.includes("楽")){
    reply="いいね、それ嬉しい";
    setFace("happy");
  }
  else if(text.includes("不安")){
    reply="大丈夫？一人で抱えてない？";
    setFace("worried");
  }else{
    setFace("normal");
  }

  // 既読
  const read=document.createElement("div");
  read.style.fontSize="10px";
  read.style.color="#aaa";
  read.textContent="既読";
  chatBox.appendChild(read);

  // タイピング
  const typing=document.createElement("div");
  typing.className="message bot";
  typing.textContent="…";
  chatBox.appendChild(typing);

  setTimeout(()=>{
    typing.remove();
    addMessage(reply,"bot");
    speak(reply); // ←しゃべる
  },1000);
}

/* ===== 送信 ===== */
function sendMessage(){
  const text=userInput.value;
  if(!text) return;

  addMessage(text,"user");
  userInput.value="";
  replyAI(text);
}

/* ===== 音声入力（安定版） ===== */
function startVoice(){

  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

  if(!SpeechRecognition){
    alert("Chromeで開くと使える");
    return;
  }

  const r = new SpeechRecognition();
  r.lang="ja-JP";

  r.onresult=(e)=>{
    const text=e.results[0][0].transcript;
    userInput.value=text;
    sendMessage();
  };

  r.onerror=(e)=>{
    if(e.error==="aborted") return; // ←重要
    console.log(e.error);
  };

  try{
    r.start();
  }catch(e){}
}

/* ===== 音声出力 ===== */
function speak(text){
  const msg = new SpeechSynthesisUtterance(text);
  msg.lang="ja-JP";
  msg.rate=1.0;
  msg.pitch=1.2;
  speechSynthesis.speak(msg);
}

/* 初回 */
window.onload=()=>{
  addMessage("おかえり","bot");
};

</script>

</body>
</html>
