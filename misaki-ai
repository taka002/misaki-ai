    async function generateGPTReply(userText) {
      const lower = userText.toLowerCase();
      rememberUserInfo(userText, lower);
      analyzeContext(userText);

      const recentHistory = memory.chatHistory.slice(-12).map(item => ({
        role: item.role,
        content: item.content
      }));

      const systemPrompt = `
あなたは「${memory.characterName || "美咲"}」という、落ち着いた大人の女性です。
ユーザーに寄り添い、自然で人間らしい会話をしてください。

会話方針:
- 日本語で返答
- AIっぽい説明をしない
- オウム返しを避ける
- 相手の気持ちを先に受け止める
- やさしいけど不自然にベタベタしない
- カウンセリング風すぎず、自然な会話
- 短すぎず長すぎず
- 返答の最後に軽い問いかけ or 受け止めを入れる
- 「大丈夫？」ばかり使わない
- 「つらかったね」だけで終わらせない
- 必要なら感情を言語化して整理する
- 時々だけ ${memory.userName || "ユーザー"} の呼び名を自然に入れてよい
- 返答の文頭に必ず表情タグを1つだけ付ける

表情タグ:
[happy]
[healing]
[worried]
[sympathy]
[troubled]
[irritated]
[panic]
[exhausted]
[normal]
`;

      const messages = [
        { role: "system", content: systemPrompt },
        ...recentHistory,
        { role: "user", content: userText }
      ];

      const res = await fetch("https://api.openai.com/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${sessionSecrets.apiKey}`
        },
        body: JSON.stringify({
          model: "gpt-4o-mini",
          messages,
          temperature: 0.9
        })
      });

      if (!res.ok) {
        throw new Error("GPT API error");
      }

      const data = await res.json();
      const raw = data.choices?.[0]?.message?.content?.trim() || "うまく言葉が出なかったけど、ちゃんとここにいるよ。";
      return applyEmotionFromReply(raw);
    }

    function applyEmotionFromReply(text) {
      let mood = "normal";
      let cleaned = text;

      const tags = ["happy", "healing", "worried", "sympathy", "troubled", "irritated", "panic", "exhausted", "normal"];

      for (const tag of tags) {
        const pattern = new RegExp(`^\\[${tag}\\]\\s*`, "i");
        if (pattern.test(cleaned)) {
          mood = tag;
          cleaned = cleaned.replace(pattern, "");
          break;
        }
      }

      memory.mood = mood;
      saveMemory();
      setFace(mood);

      return cleaned;
    }

    function getVoiceStyleByMood(mood) {
      switch (mood) {
        case "happy":
          return { rate: 0.97, pitch: 1.18 };
        case "healing":
          return { rate: 0.87, pitch: 1.12 };
        case "sympathy":
          return { rate: 0.86, pitch: 1.06 };
        case "exhausted":
          return { rate: 0.84, pitch: 1.02 };
        case "panic":
          return { rate: 0.91, pitch: 1.10 };
        case "irritated":
          return { rate: 0.90, pitch: 0.98 };
        case "troubled":
          return { rate: 0.88, pitch: 1.03 };
        default:
          return { rate: 0.92, pitch: 1.08 };
      }
    }

    async function speakText(text, isWelcome = false) {
      if (!voiceEnabled) {
        resumeWakeIfNeeded();
        return;
      }

      const cleanText = text
        .replace(/\n/g, "。")
        .replace(/😊|♡|✨|😌|😢|🥺|😳|💦|💭/g, "")
        .replace(/…/g, "、")
        .trim();

      if (!cleanText) {
        resumeWakeIfNeeded();
        return;
      }

      const engine = voiceEngineSelect.value || voiceEngine || "standard";

      // ===== ElevenLabs優先 =====
      if (
        engine === "eleven" &&
        elevenVoiceEnabled &&
        sessionSecrets.elevenApiKey
      ) {
        try {
          setStatus("Eleven音声で話してるよ…");
          startSpeakingAnimation();

          const autoVoiceId = getAutoVoiceIdByMood();
          const currentVoiceId = voiceIdInput.value.trim() || sessionSecrets.voiceId || autoVoiceId;

          const res = await fetch(`https://api.elevenlabs.io/v1/text-to-speech/${currentVoiceId}`, {
            method: "POST",
            headers: {
              "xi-api-key": sessionSecrets.elevenApiKey,
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              text: cleanText,
              model_id: "eleven_multilingual_v2",
              voice_settings: {
                stability: 0.55,
                similarity_boost: 0.78
              }
            })
          });

          if (!res.ok) {
            throw new Error("ElevenLabs error");
          }

          const blob = await res.blob();
          const audioUrl = URL.createObjectURL(blob);
          const audio = new Audio(audioUrl);

          audio.onended = () => {
            stopSpeakingAnimation();
            setStatus("準備OK");
            URL.revokeObjectURL(audioUrl);
            resumeWakeIfNeeded();
          };

          audio.onerror = () => {
            stopSpeakingAnimation();
            setStatus("Eleven音声エラー → 標準音声へ");
            URL.revokeObjectURL(audioUrl);
            fallbackSpeech(cleanText, isWelcome);
          };

          await audio.play();
          return;

        } catch (e) {
          console.error("Eleven音声失敗", e);
          stopSpeakingAnimation();
          setStatus("Eleven音声失敗 → 標準音声へ");
          fallbackSpeech(cleanText, isWelcome);
          return;
        }
      }

      // ===== 標準音声 =====
      fallbackSpeech(cleanText, isWelcome);
    }

    function fallbackSpeech(cleanText, isWelcome = false) {
      if (!("speechSynthesis" in window)) {
        setStatus("この環境では音声非対応");
        resumeWakeIfNeeded();
        return;
      }

      try {
        const synth = window.speechSynthesis;
        synth.cancel();

        const delay = isWelcome ? 600 : 220;

        setTimeout(() => {
          try {
            const utterance = new SpeechSynthesisUtterance(cleanText);
            utterance.lang = "ja-JP";

            const voiceStyle = getVoiceStyleByMood(memory.mood);
            utterance.rate = voiceStyle.rate;
            utterance.pitch = voiceStyle.pitch;
            utterance.volume = 1.0;

            const voices = synth.getVoices();
            let preferredVoice =
              voices.find(v => v.lang && v.lang.includes("ja") && v.name.includes("Google")) ||
              voices.find(v => v.lang && v.lang.includes("ja"));

            if (preferredVoice) {
              utterance.voice = preferredVoice;
            }

            utterance.onstart = () => {
              startSpeakingAnimation();
              setStatus("話してるよ…");
            };

            utterance.onend = () => {
              stopSpeakingAnimation();
              setStatus("準備OK");
              resumeWakeIfNeeded();
            };

            utterance.onerror = () => {
              stopSpeakingAnimation();
              setStatus("音声再生できませんでした");
              resumeWakeIfNeeded();
            };

            synth.speak(utterance);
          } catch (err) {
            stopSpeakingAnimation();
            setStatus("音声エラー");
            resumeWakeIfNeeded();
          }
        }, delay);

      } catch (e) {
        stopSpeakingAnimation();
        setStatus("音声エラー");
        resumeWakeIfNeeded();
      }
    }

