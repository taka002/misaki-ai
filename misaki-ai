<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 修復版</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:#08121f;
  color:white;
}

.top img{
  width:90%;
  margin:10px;
  border-radius:20px;
}

#chatBox{
  height:50vh;
  overflow:auto;
  padding:10px;
}

.message{
  padding:10px;
  margin:5px;
  border-radius:10px;
  max-width:70%;
}

.user{
  background:#ff4f8b;
  margin-left:auto;
}

.bot{
  background:#444;
}

.input{
  display:flex;
  padding:10px;
  background:#111;
}

input{
  flex:1;
  padding:10px;
}

button{
  width:60px;
}
</style>
</head>

<body>

<div class="top">
<img src="girl-normal.jpg" onerror="this.src='https://via.placeholder.com/300'">
</div>

<div id="chatBox"></div>

<div class="input">
<input id="userInput">
<button onclick="sendMessage()">送信</button>
</div>

<script>

const chatBox = document.getElementById("chatBox");
const userInput = document.getElementById("userInput");

function addMessage(text,type){
  const div=document.createElement("div");
  div.className="message "+type;
  div.textContent=text;
  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

function speak(text){
  try{
    const msg=new SpeechSynthesisUtterance(text);
    msg.lang="ja-JP";
    speechSynthesis.speak(msg);
  }catch(e){}
}

function replyAI(text){

  let reply="ちゃんと聞いてるよ";

  if(text.includes("こんにちは")){
    reply="こんにちは、来てくれて嬉しい";
  }

  setTimeout(()=>{
    addMessage(reply,"bot");
    speak(reply);
  },500);
}

function sendMessage(){

  try{
    const text=userInput.value;
    if(!text) return;

    addMessage(text,"user");
    userInput.value="";

    replyAI(text);

  }catch(e){
    alert("エラー出てる："+e);
  }
}

window.onload=()=>{
  addMessage("おかえり","bot");
};

</script>

</body>
</html>
