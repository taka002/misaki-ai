<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>メンタルサポートAI</title>

  <style>
    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      min-height: 100%;
      font-family: "Hiragino Sans", "Yu Gothic", sans-serif;
      color: #fff;
      background:
        radial-gradient(circle at 20% 20%, rgba(255, 0, 128, 0.10), transparent 28%),
        radial-gradient(circle at 80% 25%, rgba(0, 180, 255, 0.10), transparent 26%),
        radial-gradient(circle at 50% 80%, rgba(255, 255, 255, 0.05), transparent 20%),
        linear-gradient(180deg, #0d1330 0%, #050b20 100%);
      overflow-x: hidden;
    }

    body {
      padding: 18px 16px 28px;
    }

    .app {
      max-width: 430px;
      margin: 0 auto;
    }

    /* ===== フレーム固定 ===== */
    .card-frame {
      position: relative;
      width: 100%;
      border-radius: 34px;
      padding: 10px;
      background: linear-gradient(145deg, rgba(255,255,255,0.10), rgba(255,255,255,0.03));
      box-shadow:
        0 10px 30px rgba(0,0,0,0.35),
        inset 0 0 0 1px rgba(255,255,255,0.05);
      overflow: hidden;
      margin-top: 8px;
    }

    .avatar-box {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 28px;
      overflow: hidden;
      background: #111827;
    }

    .avatar-box img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .settings-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 118px;
      height: 118px;
      border-radius: 999px;
      border: none;
      font-size: 52px;
      color: white;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.55), rgba(255,255,255,0.22));
      backdrop-filter: blur(10px);
      box-shadow:
        inset 0 0 20px rgba(255,255,255,0.18),
        0 12px 24px rgba(0,0,0,0.18);
      cursor: pointer;
      z-index: 5;
    }

    .bubble-wrap {
      margin-top: 26px;
      display: flex;
      justify-content: flex-start;
    }

    .bubble {
      max-width: 86%;
      background: linear-gradient(180deg, rgba(37,47,78,0.92), rgba(22,28,55,0.92));
      border-radius: 28px;
      padding: 28px 30px;
      font-size: 28px;
      line-height: 1.8;
      box-shadow:
        0 12px 26px rgba(0,0,0,0.28),
        inset 0 0 0 1px rgba(255,255,255,0.03);
      white-space: pre-wrap;
      word-break: break-word;
    }

    .status {
      margin: 22px 4px 10px;
      font-size: 24px;
      color: rgba(255,255,255,0.92);
      min-height: 36px;
    }

    .bottom-bar {
      position: sticky;
      bottom: 0;
      z-index: 20;
      padding-top: 14px;
      background: linear-gradient(180deg, rgba(5,11,32,0), rgba(5,11,32,0.9) 28%, rgba(5,11,32,1) 100%);
      backdrop-filter: blur(4px);
    }

    .controls {
      display: grid;
      grid-template-columns: 78px 1fr 160px;
      gap: 16px;
      align-items: center;
      padding: 10px 0 4px;
    }

    .text-input {
      width: 100%;
      height: 78px;
      border: none;
      border-radius: 28px;
      padding: 0 18px;
      font-size: 22px;
      background: rgba(255,255,255,0.92);
      color: #111827;
      outline: none;
      box-shadow: inset 0 2px 8px rgba(0,0,0,0.08);
    }

    .mic-btn {
      height: 118px;
      border: none;
      border-radius: 28px;
      font-size: 54px;
      background: linear-gradient(145deg, rgba(255,255,255,0.12), rgba(255,255,255,0.05));
      color: white;
      box-shadow:
        0 14px 28px rgba(0,0,0,0.28),
        inset 0 0 0 1px rgba(255,255,255,0.04);
      cursor: pointer;
    }

    .send-btn {
      height: 118px;
      border: none;
      border-radius: 28px;
      font-size: 28px;
      font-weight: 700;
      color: white;
      background: linear-gradient(145deg, #ff76b7, #ff4fa1);
      box-shadow:
        0 16px 34px rgba(255, 72, 148, 0.32),
        inset 0 0 0 1px rgba(255,255,255,0.16);
      cursor: pointer;
    }

    .mic-active {
      box-shadow:
        0 0 0 4px rgba(0,255,180,0.18),
        0 0 22px rgba(0,255,180,0.35),
        inset 0 0 0 1px rgba(255,255,255,0.08);
    }

    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 18px;
      z-index: 50;
    }

    .modal.show {
      display: flex;
    }

    .modal-card {
      width: 100%;
      max-width: 430px;
      max-height: 88vh;
      overflow-y: auto;
      border-radius: 34px;
      padding: 28px 22px 30px;
      background: linear-gradient(180deg, #2b2143 0%, #241c3a 100%);
      box-shadow: 0 20px 40px rgba(0,0,0,0.35);
    }

    .modal-title {
      font-size: 32px;
      font-weight: 800;
      color: #f5cbe4;
      margin-bottom: 24px;
    }

    .field {
      margin-bottom: 20px;
    }

    .field label {
      display: block;
      font-size: 18px;
      margin-bottom: 8px;
      color: rgba(255,255,255,0.95);
    }

    .field input, .field textarea {
      width: 100%;
      border: none;
      border-radius: 22px;
      padding: 18px 18px;
      font-size: 18px;
      background: rgba(255,255,255,0.92);
      color: #111827;
      outline: none;
    }

    .switch-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      background: rgba(255,255,255,0.06);
      padding: 14px 16px;
      border-radius: 20px;
      margin-bottom: 14px;
    }

    .switch-row span {
      font-size: 17px;
      color: white;
    }

    .switch-row input[type="checkbox"] {
      transform: scale(1.4);
    }

    .save-btn {
      width: 100%;
      border: none;
      border-radius: 22px;
      padding: 18px;
      font-size: 20px;
      font-weight: 700;
      color: white;
      background: linear-gradient(145deg, #ff76b7, #ff4fa1);
      margin-top: 10px;
      cursor: pointer;
    }

    .hint {
      margin-top: 8px;
      font-size: 14px;
      line-height: 1.7;
      color: rgba(255,255,255,0.72);
    }

    @media (max-width: 430px) {
      .settings-btn {
        width: 108px;
        height: 108px;
        font-size: 48px;
      }

      .bubble {
        font-size: 26px;
        padding: 24px 26px;
      }

      .controls {
        grid-template-columns: 62px 1fr 138px;
        gap: 12px;
      }

      .text-input {
        height: 74px;
        font-size: 20px;
      }

      .mic-btn, .send-btn {
        height: 108px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="card-frame">
      <div class="avatar-box">
        <img id="avatarImage" alt="キャラ画像">
        <button class="settings-btn" id="openSettings">⚙️</button>
      </div>
    </div>

    <div class="bubble-wrap">
      <div class="bubble" id="replyBubble">うだったよね。
今日は昨日よりきつい感じある？</div>
    </div>

    <div class="status" id="statusText">待機OFF</div>

    <div class="bottom-bar">
      <div class="controls">
        <input id="userInput" class="text-input" type="text" placeholder="">
        <button id="micBtn" class="mic-btn">🎤</button>
        <button id="sendBtn" class="send-btn">送信</button>
      </div>
    </div>
  </div>

  <!-- 設定 -->
  <div class="modal" id="settingsModal">
    <div class="modal-card">
      <div class="modal-title">設定</div>

      <div class="field">
        <label>あなたの呼び名（時々呼ぶ）</label>
        <input id="userNameInput" type="text" placeholder="だいすけ">
      </div>

      <div class="field">
        <label>キャラ名</label>
        <input id="charNameInput" type="text" placeholder="美咲">
      </div>

      <div class="field">
        <label>OpenAI APIキー</label>
        <input id="apiKeyInput" type="password" placeholder="sk-..." autocomplete="off">
        <div class="hint">GPTを使う時だけ必要。使わないなら空でもOK。</div>
      </div>

      <div class="field">
        <label>ElevenLabs APIキー</label>
        <input id="elevenApiKeyInput" type="password" placeholder="ElevenLabs APIキー" autocomplete="off">
      </div>

      <div class="field">
        <label>Voice ID</label>
        <input id="voiceIdInput" type="text" placeholder="例: 21m00Tcm4TlvDq8ikWAM">
      </div>

      <div class="field">
        <label>ウェイクワード</label>
        <input id="wakeWordInput" type="text" placeholder="みさき">
      </div>

      <div class="switch-row">
        <span>ウェイクワード起動</span>
        <input id="wakeEnabledInput" type="checkbox" checked>
      </div>

      <div class="switch-row">
        <span>名前を呼んだら自動でマイクON</span>
        <input id="autoMicOnWakeInput" type="checkbox" checked>
      </div>

      <div class="switch-row">
        <span>スマホ音声で返答（ブラウザ音声）</span>
        <input id="browserTtsEnabledInput" type="checkbox" checked>
      </div>

      <div class="switch-row">
        <span>ElevenLabs音声を使う</span>
        <input id="elevenEnabledInput" type="checkbox">
      </div>

      <div class="switch-row">
        <span>会話履歴を保持</span>
        <input id="historyEnabledInput" type="checkbox" checked>
      </div>

      <div class="field">
        <label>キャラ画像URL（ここを入れたら固定）</label>
        <input id="avatarUrlInput" type="text" placeholder="https://...">
        <div class="hint">一度保存した画像URLは保持されます。勝手に変わりません。</div>
      </div>

      <button class="save-btn" id="saveSettings">保存して閉じる</button>
    </div>
  </div>

  <script>
    // =========================
    // DOM
    // =========================
    const avatarImage = document.getElementById("avatarImage");
    const replyBubble = document.getElementById("replyBubble");
    const statusText = document.getElementById("statusText");
    const userInput = document.getElementById("userInput");
    const micBtn = document.getElementById("micBtn");
    const sendBtn = document.getElementById("sendBtn");

    const settingsModal = document.getElementById("settingsModal");
    const openSettings = document.getElementById("openSettings");
    const saveSettingsBtn = document.getElementById("saveSettings");

    const userNameInput = document.getElementById("userNameInput");
    const charNameInput = document.getElementById("charNameInput");
    const apiKeyInput = document.getElementById("apiKeyInput");
    const elevenApiKeyInput = document.getElementById("elevenApiKeyInput");
    const voiceIdInput = document.getElementById("voiceIdInput");
    const wakeWordInput = document.getElementById("wakeWordInput");
    const wakeEnabledInput = document.getElementById("wakeEnabledInput");
    const autoMicOnWakeInput = document.getElementById("autoMicOnWakeInput");
    const browserTtsEnabledInput = document.getElementById("browserTtsEnabledInput");
    const elevenEnabledInput = document.getElementById("elevenEnabledInput");
    const historyEnabledInput = document.getElementById("historyEnabledInput");
    const avatarUrlInput = document.getElementById("avatarUrlInput");

    // =========================
    // 固定保存キー（これを変えない）
    // =========================
    const SETTINGS_KEY = "mental_ai_settings_v2_stable";
    const HISTORY_KEY = "mental_ai_history_v2_stable";

    // =========================
    // 初期設定
    // =========================
    const DEFAULT_AVATAR =
      "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=1200&auto=format&fit=crop";

    const DEFAULT_SETTINGS = {
      userName: "だいすけ",
      charName: "美咲",
      apiKey: "",
      elevenApiKey: "",
      voiceId: "",
      wakeWord: "みさき",
      wakeEnabled: true,
      autoMicOnWake: true,
      browserTtsEnabled: true,
      elevenEnabled: false,
      historyEnabled: true,
      avatarUrl: DEFAULT_AVATAR
    };

    // =========================
    // 状態
    // =========================
    let chatHistory = [];
    let wakeRecognition = null;
    let talkRecognition = null;

    let wakeListening = false;
    let talkListening = false;
    let wakeModeOn = false;
    let isSpeaking = false;
    let elevenAudio = null;

    // =========================
    // 保存/読込
    // =========================
    function getSettings() {
      const raw = localStorage.getItem(SETTINGS_KEY);
      if (!raw) return { ...DEFAULT_SETTINGS };

      try {
        return { ...DEFAULT_SETTINGS, ...JSON.parse(raw) };
      } catch {
        return { ...DEFAULT_SETTINGS };
      }
    }

    function saveSettings(data) {
      localStorage.setItem(SETTINGS_KEY, JSON.stringify(data));
    }

    function loadHistory() {
      const s = getSettings();
      if (!s.historyEnabled) {
        chatHistory = [];
        return;
      }

      const raw = localStorage.getItem(HISTORY_KEY);
      if (!raw) {
        chatHistory = [];
        return;
      }

      try {
        chatHistory = JSON.parse(raw);
      } catch {
        chatHistory = [];
      }
    }

    function saveHistory() {
      const s = getSettings();
      if (!s.historyEnabled) return;
      localStorage.setItem(HISTORY_KEY, JSON.stringify(chatHistory));
    }

    function applySettingsToUI() {
      const s = getSettings();

      userNameInput.value = s.userName;
      charNameInput.value = s.charName;
      apiKeyInput.value = s.apiKey;
      elevenApiKeyInput.value = s.elevenApiKey;
      voiceIdInput.value = s.voiceId;
      wakeWordInput.value = s.wakeWord;
      wakeEnabledInput.checked = s.wakeEnabled;
      autoMicOnWakeInput.checked = s.autoMicOnWake;
      browserTtsEnabledInput.checked = s.browserTtsEnabled;
      elevenEnabledInput.checked = s.elevenEnabled;
      historyEnabledInput.checked = s.historyEnabled;
      avatarUrlInput.value = s.avatarUrl;

      // 画像は「保存済みURLだけ」を使う
      avatarImage.src = s.avatarUrl || DEFAULT_AVATAR;
    }

    // =========================
    // ステータス
    // =========================
    function setStatus(text) {
      statusText.textContent = text;
    }

    function refreshStatus() {
      const s = getSettings();

      if (talkListening) {
        setStatus("聞いてるよ…");
      } else if (isSpeaking) {
        setStatus(`${s.charName}が話してるよ…`);
      } else if (wakeModeOn && s.wakeEnabled) {
        setStatus(`「${s.wakeWord}」を待ってるよ…`);
      } else {
        setStatus("待機OFF");
      }
    }

    // =========================
    // 音声認識
    // =========================
    function getSpeechRecognition() {
      return window.SpeechRecognition || window.webkitSpeechRecognition || null;
    }

    function makeRecognition({ continuous = false, onResult, onEnd }) {
      const SR = getSpeechRecognition();
      if (!SR) {
        alert("このスマホ/ブラウザは音声認識に未対応です。Chrome推奨です。");
        return null;
      }

      const rec = new SR();
      rec.lang = "ja-JP";
      rec.interimResults = false;
      rec.continuous = continuous;

      rec.onresult = (event) => {
        const text = Array.from(event.results)
          .map(r => r[0].transcript)
          .join("")
          .trim();

        if (text && onResult) onResult(text);
      };

      rec.onerror = (e) => {
        console.log("Speech error:", e);
      };

      rec.onend = () => {
        if (onEnd) onEnd();
      };

      return rec;
    }

    // =========================
    // 読み上げ停止
    // =========================
    function stopAllSpeech() {
      try {
        speechSynthesis.cancel();
      } catch (e) {}

      if (elevenAudio) {
        try {
          elevenAudio.pause();
          elevenAudio.currentTime = 0;
        } catch (e) {}
      }

      isSpeaking = false;
      refreshStatus();
    }

    // =========================
    // ElevenLabs / ブラウザ読み上げ
    // =========================
    async function speakText(text) {
      const s = getSettings();
      stopAllSpeech();

      if (s.elevenEnabled && s.elevenApiKey && s.voiceId) {
        await speakWithEleven(text, s.elevenApiKey, s.voiceId);
        return;
      }

      if (!s.browserTtsEnabled) return;

      const uttr = new SpeechSynthesisUtterance(text);
      uttr.lang = "ja-JP";
      uttr.rate = 1.0;
      uttr.pitch = 1.0;

      uttr.onstart = () => {
        isSpeaking = true;
        refreshStatus();
      };

      uttr.onend = () => {
        isSpeaking = false;
        refreshStatus();
        resumeWakeIfNeeded();
      };

      speechSynthesis.speak(uttr);
    }

    async function speakWithEleven(text, apiKey, voiceId) {
      try {
        isSpeaking = true;
        refreshStatus();

        const res = await fetch(`https://api.elevenlabs.io/v1/text-to-speech/${voiceId}`, {
          method: "POST",
          headers: {
            "xi-api-key": apiKey,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            text,
            model_id: "eleven_multilingual_v2",
            voice_settings: {
              stability: 0.4,
              similarity_boost: 0.8
            }
          })
        });

        if (!res.ok) throw new Error("ElevenLabs失敗");

        const blob = await res.blob();
        const url = URL.createObjectURL(blob);

        elevenAudio = new Audio(url);
        elevenAudio.onended = () => {
          isSpeaking = false;
          refreshStatus();
          resumeWakeIfNeeded();
        };

        await elevenAudio.play();
      } catch (e) {
        console.error(e);
        isSpeaking = false;
        refreshStatus();
        resumeWakeIfNeeded();
      }
    }

    // =========================
    // 手動会話マイク
    // =========================
    function stopTalkMic() {
      if (talkRecognition) {
        try { talkRecognition.stop(); } catch (e) {}
        talkRecognition = null;
      }

      talkListening = false;
      micBtn.classList.remove("mic-active");
      refreshStatus();
    }

    function startTalkMic() {
      stopTalkMic();
      stopWakeMic();

      talkRecognition = makeRecognition({
        continuous: false,
        onResult: async (text) => {
          userInput.value = text;
          stopTalkMic();
          await sendMessage(text);
        },
        onEnd: () => {
          talkListening = false;
          micBtn.classList.remove("mic-active");
          refreshStatus();
        }
      });

      if (!talkRecognition) return;

      try {
        talkRecognition.start();
        talkListening = true;
        micBtn.classList.add("mic-active");
        setStatus("聞いてるよ…");
      } catch (e) {
        console.log("会話マイク開始失敗", e);
      }
    }

    // =========================
    // ウェイクワード待機
    // =========================
    function normalizeJaText(text) {
      return (text || "")
        .replace(/[　\s]/g, "")
        .toLowerCase();
    }

    function stopWakeMic() {
      if (wakeRecognition) {
        try { wakeRecognition.stop(); } catch (e) {}
        wakeRecognition = null;
      }

      wakeListening = false;
    }

    function handleWakeDetected(text) {
      const s = getSettings();
      const heard = normalizeJaText(text);
      const wake = normalizeJaText(s.wakeWord);

      console.log("Wake heard:", heard, " / target:", wake);

      if (!wake) return;

      if (heard.includes(wake)) {
        replyBubble.textContent = `${s.userName}、呼んだ？`;
        setStatus(`「${s.wakeWord}」に反応したよ`);

        if (s.autoMicOnWake) {
          stopWakeMic();

          setTimeout(() => {
            startTalkMic();
          }, 700);
        }
      }
    }

    function startWakeMic() {
      const s = getSettings();

      stopWakeMic();

      if (!wakeModeOn || !s.wakeEnabled) {
        refreshStatus();
        return;
      }

      wakeRecognition = makeRecognition({
        continuous: true,
        onResult: (text) => {
          handleWakeDetected(text);
        },
        onEnd: () => {
          wakeListening = false;

          // 途中で勝手に止まっても再待機
          if (wakeModeOn && getSettings().wakeEnabled && !talkListening && !isSpeaking) {
            setTimeout(() => {
              startWakeMic();
            }, 900);
          }
        }
      });

      if (!wakeRecognition) return;

      try {
        wakeRecognition.start();
        wakeListening = true;
        setStatus(`「${s.wakeWord}」を待ってるよ…`);
      } catch (e) {
        console.log("Wake start failed", e);
      }
    }

    function resumeWakeIfNeeded() {
      const s = getSettings();
      if (wakeModeOn && s.wakeEnabled && !talkListening && !isSpeaking) {
        setTimeout(() => {
          startWakeMic();
        }, 1000);
      }
    }

    // =========================
    // GPT応答
    // =========================
    async function getAIReply(userText) {
      const s = getSettings();

      if (!s.apiKey) {
        return `${s.userName}、それ話してくれてありがとう。今いちばん強いのはどんな感じ？`;
      }

      const systemPrompt = `
あなたは優しく自然に会話する日本語の女性AIです。
名前は「${s.charName}」です。
ユーザー名は「${s.userName}」です。

ルール:
- 人間っぽく自然に返す
- 優しい
- 少し寄り添う
- AIっぽい固さを出さない
- 日本語のみ
`;

      const messages = [
        { role: "system", content: systemPrompt },
        ...chatHistory,
        { role: "user", content: userText }
      ];

      const res = await fetch("https://api.openai.com/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${s.apiKey}`
        },
        body: JSON.stringify({
          model: "gpt-4o-mini",
          messages,
          temperature: 0.8
        })
      });

      if (!res.ok) {
        const errText = await res.text();
        console.error(errText);
        throw new Error("OpenAI API error");
      }

      const data = await res.json();
      return data.choices?.[0]?.message?.content?.trim() || "うまく返せなかった…";
    }

    async function sendMessage(textArg = null) {
      const text = (textArg ?? userInput.value).trim();
      if (!text) return;

      const s = getSettings();

      userInput.value = "";
      stopAllSpeech();
      stopWakeMic();
      stopTalkMic();

      setStatus("考えてるよ…");

      try {
        const reply = await getAIReply(text);
        replyBubble.textContent = reply;

        if (s.historyEnabled) {
          chatHistory.push({ role: "user", content: text });
          chatHistory.push({ role: "assistant", content: reply });

          if (chatHistory.length > 20) {
            chatHistory = chatHistory.slice(-20);
          }

          saveHistory();
        }

        await speakText(reply);
      } catch (e) {
        console.error(e);
        replyBubble.textContent = "ごめん、うまく返せなかった。もう一回話してみて。";
        resumeWakeIfNeeded();
      }
    }

    // =========================
    // ボタン
    // =========================
    function toggleWakeMode() {
      const s = getSettings();

      if (!s.wakeEnabled) {
        alert("設定で『ウェイクワード起動』をONにしてください。");
        return;
      }

      if (wakeModeOn) {
        wakeModeOn = false;
        stopWakeMic();
        stopTalkMic();
        micBtn.classList.remove("mic-active");
        setStatus("待機OFF");
      } else {
        wakeModeOn = true;
        micBtn.classList.add("mic-active");
        startWakeMic();
      }
    }

    micBtn.addEventListener("click", toggleWakeMode);

    sendBtn.addEventListener("click", () => {
      sendMessage();
    });

    userInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") sendMessage();
    });

    // =========================
    // 設定モーダル
    // =========================
    openSettings.addEventListener("click", () => {
      applySettingsToUI();
      settingsModal.classList.add("show");
    });

    settingsModal.addEventListener("click", (e) => {
      if (e.target === settingsModal) {
        settingsModal.classList.remove("show");
      }
    });

    saveSettingsBtn.addEventListener("click", () => {
      const current = getSettings();

      // 画像URLは空なら「前の保存値を維持」
      const nextAvatarUrl = avatarUrlInput.value.trim() || current.avatarUrl || DEFAULT_AVATAR;

      const newSettings = {
        userName: userNameInput.value.trim() || "だいすけ",
        charName: charNameInput.value.trim() || "美咲",
        apiKey: apiKeyInput.value.trim(),
        elevenApiKey: elevenApiKeyInput.value.trim(),
        voiceId: voiceIdInput.value.trim(),
        wakeWord: wakeWordInput.value.trim() || "みさき",
        wakeEnabled: wakeEnabledInput.checked,
        autoMicOnWake: autoMicOnWakeInput.checked,
        browserTtsEnabled: browserTtsEnabledInput.checked,
        elevenEnabled: elevenEnabledInput.checked,
        historyEnabled: historyEnabledInput.checked,
        avatarUrl: nextAvatarUrl
      };

      saveSettings(newSettings);

      if (!newSettings.historyEnabled) {
        localStorage.removeItem(HISTORY_KEY);
        chatHistory = [];
      }

      avatarImage.src = newSettings.avatarUrl;
      settingsModal.classList.remove("show");

      // ウェイク中なら再起動
      if (wakeModeOn) {
        stopWakeMic();
        stopTalkMic();
        setTimeout(() => {
          startWakeMic();
        }, 700);
      }

      refreshStatus();
    });

    // =========================
    // 起動
    // =========================
    window.addEventListener("load", () => {
      applySettingsToUI();
      loadHistory();

      // 起動時に勝手に見た目を変えない
      const s = getSettings();
      avatarImage.src = s.avatarUrl || DEFAULT_AVATAR;

      // 初期メッセージも固定
      if (!replyBubble.textContent.trim()) {
        replyBubble.textContent = "こんにちは。今日はどんな感じ？";
      }

      wakeModeOn = false;
      stopWakeMic();
      stopTalkMic();
      micBtn.classList.remove("mic-active");
      setStatus("待機OFF");
    });
  </script>
</body>
</html>
