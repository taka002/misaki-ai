<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>美咲AI</title>

  <style>
    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: "Hiragino Sans", "Yu Gothic", sans-serif;
      background: radial-gradient(circle at top, #1a2148 0%, #090d1f 72%);
      color: #fff;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: stretch;
    }

    .app {
      width: 100%;
      max-width: 480px;
      height: 100vh;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 14px;
    }

    .glass {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      backdrop-filter: blur(12px);
      box-shadow: 0 8px 28px rgba(0,0,0,0.25);
      border-radius: 28px;
    }

    .avatar-card {
      position: relative;
      padding: 10px;
    }

    .avatar-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 28px;
      border: 4px solid rgba(255,255,255,0.08);
      background: #111827;
      position: relative;
    }

    .avatar-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .settings-btn {
      position: absolute;
      top: 16px;
      right: 16px;
      width: 84px;
      height: 84px;
      border-radius: 50%;
      border: none;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.55), rgba(255,255,255,0.14));
      color: white;
      font-size: 34px;
      cursor: pointer;
      z-index: 10;
      box-shadow: 0 10px 28px rgba(0,0,0,0.25);
    }

    .main-bubble {
      min-height: 160px;
      padding: 26px 24px;
      font-size: 20px;
      line-height: 1.9;
      white-space: pre-wrap;
    }

    .status {
      min-height: 24px;
      font-size: 16px;
      opacity: 0.92;
      padding: 0 8px;
    }

    .history {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 4px 2px;
    }

    .msg {
      max-width: 88%;
      padding: 14px 16px;
      border-radius: 18px;
      font-size: 16px;
      line-height: 1.7;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .msg.user {
      align-self: flex-end;
      background: rgba(255, 96, 168, 0.22);
      border: 1px solid rgba(255,96,168,0.35);
    }

    .msg.ai {
      align-self: flex-start;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .bottom-bar {
      display: grid;
      grid-template-columns: 72px 1fr 112px;
      gap: 12px;
      align-items: center;
      padding-bottom: env(safe-area-inset-bottom);
    }

    .icon-btn, .send-btn {
      height: 72px;
      border: none;
      border-radius: 24px;
      color: white;
      cursor: pointer;
      box-shadow: 0 10px 26px rgba(0,0,0,0.25);
    }

    .icon-btn {
      width: 72px;
      background: rgba(255,255,255,0.14);
      font-size: 30px;
    }

    .send-btn {
      background: linear-gradient(135deg, #ff6fb2, #ff4d9d);
      font-size: 18px;
      font-weight: bold;
    }

    .text-input {
      width: 100%;
      height: 72px;
      border-radius: 24px;
      border: none;
      outline: none;
      padding: 0 20px;
      font-size: 20px;
      background: rgba(255,255,255,0.95);
      color: #111827;
    }

    /* モーダル */
    .modal-bg {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 18px;
      background: rgba(0,0,0,0.45);
      z-index: 999;
    }

    .modal {
      width: 100%;
      max-width: 430px;
      max-height: 88vh;
      overflow-y: auto;
      background: #251d41;
      border-radius: 28px;
      padding: 24px 20px 28px;
      box-shadow: 0 16px 50px rgba(0,0,0,0.45);
    }

    .modal h2 {
      margin: 0 0 18px;
      font-size: 28px;
      color: #ffd1e9;
    }

    .field {
      margin-bottom: 18px;
    }

    .field label {
      display: block;
      font-size: 16px;
      margin-bottom: 8px;
      opacity: 0.95;
    }

    .field input {
      width: 100%;
      height: 58px;
      border: none;
      outline: none;
      border-radius: 18px;
      padding: 0 18px;
      font-size: 18px;
      background: rgba(255,255,255,0.95);
      color: #111827;
    }

    .toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 16px;
      margin-bottom: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.08);
    }

    .toggle span {
      font-size: 16px;
      line-height: 1.5;
    }

    .toggle input {
      width: 22px;
      height: 22px;
      transform: scale(1.15);
    }

    .row-btns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .mini-btn {
      height: 52px;
      border: none;
      border-radius: 18px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
    }

    .save-btn {
      background: linear-gradient(135deg, #ff6fb2, #ff4d9d);
      color: white;
    }

    .sub-btn {
      background: rgba(255,255,255,0.12);
      color: white;
    }

    .note {
      margin-top: 12px;
      font-size: 13px;
      line-height: 1.7;
      opacity: 0.82;
    }

    @media (max-width: 420px) {
      .main-bubble {
        font-size: 18px;
        min-height: 145px;
      }

      .settings-btn {
        width: 78px;
        height: 78px;
      }

      .text-input {
        font-size: 18px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="glass avatar-card">
      <button class="settings-btn" onclick="openSettings()">⚙️</button>
      <div class="avatar-wrap">
        <img id="avatar" src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=900&q=80" alt="avatar">
      </div>
    </div>

    <div class="glass main-bubble" id="mainBubble">こんにちは。今日はどんな感じ？</div>
    <div class="status" id="statusText">名前を待ってるよ…</div>

    <div class="history" id="historyBox"></div>

    <div class="bottom-bar">
      <button class="icon-btn" onclick="toggleMic()">🎤</button>
      <input class="text-input" id="userInput" placeholder="話しかけてね" />
      <button class="send-btn" onclick="sendMessage()">送信</button>
    </div>
  </div>

  <!-- 設定モーダル -->
  <div class="modal-bg" id="settingsModal">
    <div class="modal">
      <h2>設定</h2>

      <div class="field">
        <label>あなたの呼び名（時々呼ぶ）</label>
        <input id="userName" placeholder="だいすけ" />
      </div>

      <div class="field">
        <label>キャラ名（ウェイクワード）</label>
        <input id="charName" placeholder="美咲" />
      </div>

      <div class="field">
        <label>OpenAI APIキー（保存しない）</label>
        <input id="openaiKey" type="password" placeholder="sk-..." />
      </div>

      <div class="field">
        <label>ElevenLabs APIキー（保存しない）</label>
        <input id="elevenKey" type="password" placeholder="保存しない" />
      </div>

      <div class="field">
        <label>Voice ID（保存する）</label>
        <input id="voiceId" placeholder="例: EXAVITQu4vr4xnSDxMaL" />
      </div>

      <div class="toggle">
        <span>ウェイクワード起動（名前で反応）</span>
        <input type="checkbox" id="wakeEnabled" />
      </div>

      <div class="toggle">
        <span>名前反応後、自動でマイクON</span>
        <input type="checkbox" id="autoMicEnabled" />
      </div>

      <div class="toggle">
        <span>スマホ音声で返答（ブラウザ音声）</span>
        <input type="checkbox" id="browserVoiceEnabled" />
      </div>

      <div class="toggle">
        <span>ElevenLabs音声を使う</span>
        <input type="checkbox" id="elevenEnabled" />
      </div>

      <div class="row-btns">
        <button class="mini-btn save-btn" onclick="saveSettings()">保存</button>
        <button class="mini-btn sub-btn" onclick="clearHistory()">履歴削除</button>
      </div>

      <div class="row-btns">
        <button class="mini-btn sub-btn" onclick="startWakeWord()">名前待機開始</button>
        <button class="mini-btn sub-btn" onclick="closeSettings()">閉じる</button>
      </div>

      <div class="note">
        ※ OpenAIキー / Elevenキーは保存しません。<br>
        ※ 会話履歴・名前・Voice ID・ON/OFF設定だけ保存します。
      </div>
    </div>
  </div>

  <script>
    // =========================
    // 保存キー（APIキー以外）
    // =========================
    const LS_KEYS = {
      history: "misaki_history",
      userName: "misaki_userName",
      charName: "misaki_charName",
      voiceId: "misaki_voiceId",
      wakeEnabled: "misaki_wakeEnabled",
      autoMicEnabled: "misaki_autoMicEnabled",
      browserVoiceEnabled: "misaki_browserVoiceEnabled",
      elevenEnabled: "misaki_elevenEnabled"
    };

    // =========================
    // DOM
    // =========================
    const historyBox = document.getElementById("historyBox");
    const mainBubble = document.getElementById("mainBubble");
    const statusText = document.getElementById("statusText");
    const userInput = document.getElementById("userInput");

    const userNameInput = document.getElementById("userName");
    const charNameInput = document.getElementById("charName");
    const openaiKeyInput = document.getElementById("openaiKey");
    const elevenKeyInput = document.getElementById("elevenKey");
    const voiceIdInput = document.getElementById("voiceId");

    const wakeEnabledInput = document.getElementById("wakeEnabled");
    const autoMicEnabledInput = document.getElementById("autoMicEnabled");
    const browserVoiceEnabledInput = document.getElementById("browserVoiceEnabled");
    const elevenEnabledInput = document.getElementById("elevenEnabled");

    // =========================
    // 状態
    // =========================
    let conversationHistory = JSON.parse(localStorage.getItem(LS_KEYS.history) || "[]");
    let micRecognition = null;
    let wakeRecognition = null;
    let isMicListening = false;
    let wakeCooldown = false;

    // =========================
    // 初期化
    // =========================
    function loadSettings() {
      userNameInput.value = localStorage.getItem(LS_KEYS.userName) || "だいすけ";
      charNameInput.value = localStorage.getItem(LS_KEYS.charName) || "美咲";
      voiceIdInput.value = localStorage.getItem(LS_KEYS.voiceId) || "";

      wakeEnabledInput.checked = localStorage.getItem(LS_KEYS.wakeEnabled) !== "false";
      autoMicEnabledInput.checked = localStorage.getItem(LS_KEYS.autoMicEnabled) !== "false";
      browserVoiceEnabledInput.checked = localStorage.getItem(LS_KEYS.browserVoiceEnabled) !== "false";
      elevenEnabledInput.checked = localStorage.getItem(LS_KEYS.elevenEnabled) === "true";
    }

    function saveSettings() {
      localStorage.setItem(LS_KEYS.userName, userNameInput.value.trim() || "だいすけ");
      localStorage.setItem(LS_KEYS.charName, charNameInput.value.trim() || "美咲");
      localStorage.setItem(LS_KEYS.voiceId, voiceIdInput.value.trim());
      localStorage.setItem(LS_KEYS.wakeEnabled, wakeEnabledInput.checked);
      localStorage.setItem(LS_KEYS.autoMicEnabled, autoMicEnabledInput.checked);
      localStorage.setItem(LS_KEYS.browserVoiceEnabled, browserVoiceEnabledInput.checked);
      localStorage.setItem(LS_KEYS.elevenEnabled, elevenEnabledInput.checked);

      setStatus("設定を保存したよ");
      closeSettings();

      if (wakeEnabledInput.checked) {
        startWakeWord();
      } else {
        stopWakeWord();
        setStatus("待機中");
      }
    }

    function renderHistory() {
      historyBox.innerHTML = "";
      conversationHistory.forEach(item => {
        const div = document.createElement("div");
        div.className = "msg " + item.role;
        div.textContent = item.text;
        historyBox.appendChild(div);
      });
      historyBox.scrollTop = historyBox.scrollHeight;
    }

    function saveHistory() {
      localStorage.setItem(LS_KEYS.history, JSON.stringify(conversationHistory));
    }

    function addMessage(role, text) {
      conversationHistory.push({ role, text });
      saveHistory();
      renderHistory();

      if (role === "ai") {
        mainBubble.textContent = text;
      }
    }

    function clearHistory() {
      if (!confirm("会話履歴を消す？")) return;
      conversationHistory = [];
      saveHistory();
      renderHistory();
      mainBubble.textContent = "履歴を消したよ。";
      setStatus("履歴を削除しました");
    }

    function setStatus(text) {
      statusText.textContent = text;
    }

    // =========================
    // モーダル
    // =========================
    function openSettings() {
      document.getElementById("settingsModal").style.display = "flex";
    }

    function closeSettings() {
      document.getElementById("settingsModal").style.display = "none";
    }

    // =========================
    // 音声出力
    // =========================
    function speakText(text) {
      const useEleven = elevenEnabledInput.checked;
      const useBrowserVoice = browserVoiceEnabledInput.checked;

      if (useEleven) {
        elevenSpeak(text);
        return;
      }

      if (!useBrowserVoice) return;

      try {
        speechSynthesis.cancel();
        const utter = new SpeechSynthesisUtterance(text);
        utter.lang = "ja-JP";
        utter.rate = 1.0;
        utter.pitch = 1.0;
        speechSynthesis.speak(utter);
      } catch (e) {
        console.error("ブラウザ音声エラー", e);
      }
    }

    async function elevenSpeak(text) {
      const apiKey = elevenKeyInput.value.trim();
      const voiceId = voiceIdInput.value.trim();

      if (!apiKey || !voiceId) {
        setStatus("ElevenのAPIキーかVoice IDが足りないよ");
        return;
      }

      try {
        const res = await fetch(`https://api.elevenlabs.io/v1/text-to-speech/${voiceId}`, {
          method: "POST",
          headers: {
            "xi-api-key": apiKey,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            text,
            model_id: "eleven_multilingual_v2"
          })
        });

        if (!res.ok) {
          const err = await res.text();
          console.error(err);
          setStatus("Eleven音声エラー");
          return;
        }

        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const audio = new Audio(url);
        audio.play().catch(err => {
          console.error(err);
          setStatus("音声再生できなかった");
        });
      } catch (e) {
        console.error(e);
        setStatus("Eleven接続エラー");
      }
    }

    // =========================
    // OpenAI送信
    // =========================
    async function sendMessage() {
      const text = userInput.value.trim();
      if (!text) return;

      const apiKey = openaiKeyInput.value.trim();
      if (!apiKey) {
        alert("OpenAI APIキーを設定してね");
        return;
      }

      addMessage("user", text);
      userInput.value = "";
      setStatus("考え中...");

      const userName = userNameInput.value.trim() || "だいすけ";
      const charName = charNameInput.value.trim() || "美咲";

      const systemPrompt = `
あなたは「${charName}」という、やさしく寄り添う会話AIです。
相手の名前は「${userName}」です。
自然な会話で、AIっぽすぎず、人に話しかけるように返答してください。
短すぎず、でも読みやすく。
必要なら少し気づかいを入れてください。
`;

      const messages = [
        { role: "system", content: systemPrompt },
        ...conversationHistory.map(item => ({
          role: item.role === "ai" ? "assistant" : "user",
          content: item.text
        }))
      ];

      try {
        const res = await fetch("https://api.openai.com/v1/chat/completions", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": `Bearer ${apiKey}`
          },
          body: JSON.stringify({
            model: "gpt-4o-mini",
            messages,
            temperature: 0.85
          })
        });

        const data = await res.json();

        if (!res.ok) {
          console.error(data);
          setStatus("OpenAIエラー");
          alert("OpenAIエラーが出ました。APIキーや利用状況を確認してね。");
          return;
        }

        const reply = data.choices?.[0]?.message?.content || "うまく返せなかった...";
        addMessage("ai", reply);
        speakText(reply);
        setStatus("待機中");
      } catch (e) {
        console.error(e);
        setStatus("通信エラー");
      }
    }

    // =========================
    // 手動マイク
    // =========================
    function toggleMic() {
      if (isMicListening) {
        stopMic();
      } else {
        startMic();
      }
    }

    function startMic() {
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SpeechRecognition) {
        alert("このスマホ・ブラウザでは音声入力に対応していません");
        return;
      }

      try {
        if (micRecognition) {
          micRecognition.stop();
          micRecognition = null;
        }

        micRecognition = new SpeechRecognition();
        micRecognition.lang = "ja-JP";
        micRecognition.interimResults = false;
        micRecognition.maxAlternatives = 1;

        micRecognition.onstart = () => {
          isMicListening = true;
          setStatus("聞いてるよ...");
        };

        micRecognition.onresult = (event) => {
          const transcript = event.results[0][0].transcript;
          userInput.value = transcript;
          setStatus("聞き取ったよ");
          sendMessage();
        };

        micRecognition.onerror = (event) => {
          console.error("mic error:", event.error);
          isMicListening = false;
          setStatus("マイクエラー: " + event.error);
        };

        micRecognition.onend = () => {
          isMicListening = false;
          setStatus("待機中");
        };

        micRecognition.start();
      } catch (e) {
        console.error(e);
        setStatus("マイク開始できなかった");
      }
    }

    function stopMic() {
      try {
        if (micRecognition) micRecognition.stop();
      } catch (e) {
        console.error(e);
      }
      isMicListening = false;
      setStatus("待機中");
    }

    // =========================
    // ウェイクワード
    // =========================
    function getWakeWords() {
      const charName = (charNameInput.value.trim() || "美咲").toLowerCase();
      return [
        charName,
        "ねえ" + charName,
        charName + "ちゃん",
        charName + "さん"
      ];
    }

    function triggerWakeAction() {
      if (wakeCooldown) return;
      wakeCooldown = true;

      const reply = "うん、呼んだ？";
      mainBubble.textContent = reply;
      addMessage("ai", reply);
      speakText(reply);
      setStatus("反応したよ");

      if (autoMicEnabledInput.checked) {
        setTimeout(() => {
          startMic();
        }, 900);
      }

      setTimeout(() => {
        wakeCooldown = false;
      }, 4000);
    }

    function startWakeWord() {
      stopWakeWord();

      if (!wakeEnabledInput.checked) {
        setStatus("名前起動OFF");
        return;
      }

      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SpeechRecognition) {
        setStatus("名前起動はこの端末で非対応");
        return;
      }

      try {
        wakeRecognition = new SpeechRecognition();
        wakeRecognition.lang = "ja-JP";
        wakeRecognition.continuous = true;
        wakeRecognition.interimResults = true;
        wakeRecognition.maxAlternatives = 1;

        wakeRecognition.onstart = () => {
          setStatus("名前を待ってるよ...");
        };

        wakeRecognition.onresult = (event) => {
          let transcript = "";
          for (let i = event.resultIndex; i < event.results.length; i++) {
            transcript += event.results[i][0].transcript;
          }

          const heard = transcript.toLowerCase();
          const wakeWords = getWakeWords();
          const hit = wakeWords.some(word => heard.includes(word));

          if (hit) {
            console.log("Wake word hit:", heard);
            triggerWakeAction();
          }
        };

        wakeRecognition.onerror = (event) => {
          console.error("wake error:", event.error);
          setStatus("名前待機エラー: " + event.error);
        };

        wakeRecognition.onend = () => {
          if (wakeEnabledInput.checked) {
            setTimeout(() => {
              startWakeWord();
            }, 1200);
          }
        };

        wakeRecognition.start();
      } catch (e) {
        console.error(e);
        setStatus("名前待機を開始できなかった");
      }
    }

    function stopWakeWord() {
      try {
        if (wakeRecognition) {
          wakeRecognition.onend = null;
          wakeRecognition.stop();
          wakeRecognition = null;
        }
      } catch (e) {
        console.error(e);
      }
    }

    // =========================
    // Enter送信
    // =========================
    userInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        sendMessage();
      }
    });

    // =========================
    // 初期ロード
    // =========================
    loadSettings();
    renderHistory();

    if (wakeEnabledInput.checked) {
      setTimeout(() => {
        startWakeWord();
      }, 1200);
    } else {
      setStatus("待機中");
    }

    // ブラウザ音声許可のきっかけ
    document.body.addEventListener("click", () => {
      try {
        const u = new SpeechSynthesisUtterance("");
        speechSynthesis.speak(u);
      } catch(e) {}
    }, { once: true });
  </script>
</body>
</html>
