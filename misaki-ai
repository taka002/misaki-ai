        ]);
      }

      return "";
    }

    function shapeReplyByPersonality(text) {
      const p = memory.personalityProfile;
      let result = text;

      if (p.warmth !== "gentle" && !result.startsWith("うん") && !result.startsWith("そっか") && !result.startsWith("なるほど")) {
        result = getWarmthPrefix() + result;
      }

      if (p.preferredLength === "short") {
        const parts = result.split("\n").filter(Boolean);
        result = parts.slice(0, 3).join("\n");
      }

      return result;
    }

    function finalReply(baseLines, questionLines = [], mood = "normal", feeling = "") {
      const callName = maybeCallUserName();
      const continuation = buildSoftContinuation(memory.lastMessage || "");
      const body = pick(baseLines);

      setFace(mood);
      memory.mood = mood;
      if (feeling) memory.currentFeeling = feeling;
      saveMemory();

      let tail = getNaturalTail();

      if (questionLines.length && Math.random() < 0.42 && memory.conversationMode !== "just_listen") {
        tail = avoidRepeatedQuestion(questionLines);
      }

      let result = `${callName}${continuation}${body}\n${tail}`;
      result = shapeReplyByPersonality(result);
      updateSummary(memory.lastMessage || "", result);
      return result;
    }

