<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 完成版</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:#09111f;
  color:white;
}

/* ===== 全体 ===== */
.app{
  height:100vh;
  display:flex;
  flex-direction:column;
}

/* ===== 上（時間だけ裏で使うので非表示） ===== */

/* ===== キャラ（ここが改善ポイント） ===== */
.top{
  height:90px; /* ← 小さく */
  padding-top:12px; /* ← 下げる */
  display:flex;
  justify-content:center;
}

.top img{
  width:90%;
  height:100%;
  object-fit:cover;
  border-radius:16px;
}

/* ===== メイン ===== */
.main{
  flex:1;
  display:flex;
  flex-direction:column;
  min-height:0;
}

/* ===== チャット ===== */
#chatBox{
  flex:1;
  overflow-y:auto;
  padding:10px;
}

/* ===== メッセージ ===== */
.message{
  max-width:80%;
  padding:12px;
  border-radius:16px;
  margin:6px 0;
  position:relative;
  line-height:1.6;
}

.user{
  background:#ff4f8b;
  margin-left:auto;
}

.bot{
  background:#444;
}

.time{
  font-size:10px;
  opacity:0.6;
  margin-top:4px;
}

/* ===== 入力 ===== */
.input{
  display:flex;
  gap:6px;
  padding:8px;
  background:#111;
}

input{
  flex:1;
  padding:12px;
  border-radius:10px;
  border:none;
}

button{
  padding:12px;
  border-radius:10px;
  border:none;
}

/* ===== タブ ===== */
.tabs{
  display:flex;
  background:#222;
}

.tab{
  flex:1;
  text-align:center;
  padding:12px;
}

.panel{
  display:none;
  flex:1;
}

.panel.active{
  display:flex;
  flex-direction:column;
}

/* ===== 分析・未来 ===== */
.card{
  padding:15px;
}
</style>
</head>

<body>

<div class="app">

<!-- キャラ（下がってる） -->
<div class="top">
<img id="mainGirl" src="girl-normal.jpg">
</div>

<!-- メイン -->
<div class="main">

<!-- 会話 -->
<div id="chatPanel" class="panel active">
  <div id="chatBox"></div>

  <div class="input">
    <input id="userInput">
    <button onclick="sendMessage()">送信</button>
  </div>
</div>

<!-- 分析 -->
<div id="analysisPanel" class="panel">
  <div class="card" id="analysisContent">分析まだ</div>
</div>

<!-- 未来 -->
<div id="futurePanel" class="panel">
  <div class="card" id="futureContent">未来まだ</div>
</div>

</div>

<!-- タブ -->
<div class="tabs">
  <div class="tab" onclick="switchTab('chat')">会話</div>
  <div class="tab" onclick="switchTab('analysis')">分析</div>
  <div class="tab" onclick="switchTab('future')">未来</div>
</div>

</div>

<script>

/* ===== 状態 ===== */
let memory={
  chatHistory:[],
  lastReply:""
};

/* ===== タブ ===== */
function switchTab(tab){
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));

  if(tab==="chat") chatPanel.classList.add("active");
  if(tab==="analysis") analysisPanel.classList.add("active");
  if(tab==="future") futurePanel.classList.add("active");
}

/* ===== 時間 ===== */
function getTime(){
  const d=new Date();
  return d.getHours()+":"+String(d.getMinutes()).padStart(2,"0");
}

/* ===== メッセージ追加 ===== */
function addMessage(text,type){

  const div=document.createElement("div");
  div.className="message "+type;

  div.innerHTML=`
    ${text}
    <div class="time">${getTime()}</div>
  `;

  chatBox.appendChild(div);
  chatBox.scrollTop=chatBox.scrollHeight;
}

/* ===== 送信 ===== */
function sendMessage(){
  const text=userInput.value;
  if(!text) return;

  addMessage(text,"user");
  memory.chatHistory.push(text);

  const reply=generateReply(text);

  setTimeout(()=>{
    addMessage(reply,"bot");
  },400);

  userInput.value="";
}

/* ===== 表情 ===== */
function setFace(type){
  mainGirl.src="girl-"+type+".png";
}

/* ===== AI返信（人格強化） ===== */
function generateReply(text){

  const t=text.toLowerCase();

  function contains(arr){
    return arr.some(w=>t.includes(w));
  }

  let reply="";

  if(contains(["疲れ","しんど","無理","限界"])){
    setFace("exhausted");
    reply="ちょっと無理してる感じあるね…今日は少し力抜けそう？";
  }

  else if(contains(["不安","怖い","心配"])){
    setFace("worried");
    reply="それ気になるよね…どこが一番引っかかってる？";
  }

  else if(contains(["寂しい","つらい"])){
    setFace("sympathy");
    reply="そっか…それはしんどいね。今ひとりで抱えてる感じ？";
  }

  else if(contains(["イライラ","むかつく"])){
    setFace("irritated");
    reply="それはイラッとするね…何が一番嫌だった？";
  }

  else if(contains(["楽しい","嬉しい"])){
    setFace("happy");
    reply="いいね、それ。どの瞬間が一番よかった？";
  }

  else{
    setFace("normal");
    reply="ちゃんと聞いてるよ。もう少し教えてくれる？";
  }

  /* 同じ返答防止 */
  if(reply===memory.lastReply){
    reply+=" 少し違う言い方すると、どう感じてる？";
  }

  memory.lastReply=reply;

  return reply;
}

/* ===== 分析 ===== */
function analyze(){
  const text=memory.chatHistory.join("");

  let fatigue = text.includes("疲") ? "高い" : "普通";

  analysisContent.innerHTML="疲労："+fatigue;
}

/* ===== 未来 ===== */
function future(){
  futureContent.innerHTML=`
    A：休む → 回復
    <br>
    B：続ける → 悪化
  `;
}

</script>

</body>
</html>
