    async function sendMessage() {
      const text = userInput.value.trim();
      if (!text) return;

      stopWakeListening();

      if (window.speechSynthesis) {
        window.speechSynthesis.cancel();
      }
      stopSpeakingAnimation();

      addMessage(text, "user");
      saveChat("user", text);
      userInput.value = "";

      const typingMsg = addMessage("…入力中", "bot", "typing");

      try {
