<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 完全版</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:#001522;
  color:white;
}

/* 上部 */
.header{
  text-align:center;
  padding:10px;
}
.header img{
  width:100%;
  max-height:200px;
  object-fit:cover;
  border-radius:20px;
}

/* チャット */
.chat{
  height:55vh;
  overflow-y:auto;
  padding:10px;
}

/* 吹き出し */
.msg{
  max-width:70%;
  padding:12px;
  margin:8px;
  border-radius:20px;
  position:relative;
}
.user{
  background:#ff4f7a;
  margin-left:auto;
}
.ai{
  background:#444;
}

/* 時刻 */
.time{
  font-size:10px;
  opacity:0.7;
  position:absolute;
  right:10px;
  bottom:-15px;
}

/* 入力 */
.inputArea{
  position:fixed;
  bottom:60px;
  width:100%;
  display:flex;
}
input{
  flex:1;
  padding:10px;
  font-size:16px;
}
button{
  padding:10px;
}

/* タブ */
.tabs{
  position:fixed;
  bottom:0;
  width:100%;
  display:flex;
  background:#222;
}
.tab{
  flex:1;
  text-align:center;
  padding:10px;
}

/* 設定モーダル */
.modal{
  display:none;
  position:fixed;
  top:10%;
  left:10%;
  width:80%;
  background:#222;
  padding:20px;
  border-radius:10px;
}
.modal input, select{
  width:100%;
  margin:5px 0;
}
</style>
</head>

<body>

<div class="header">
<img id="face" src="girl-normal.jpg">
</div>

<div id="chat" class="chat"></div>

<div class="inputArea">
<button onclick="startVoice()">🎤</button>
<input id="text" placeholder="話しかけて...">
<button onclick="send()">送信</button>
</div>

<div class="tabs">
<div class="tab">会話</div>
<div class="tab">分析</div>
<div class="tab">未来</div>
<div class="tab" onclick="openSettings()">設定</div>
</div>

<!-- 設定 -->
<div id="modal" class="modal">
<h3>設定</h3>

<input id="name" placeholder="名前">
<select id="aiType">
<option value="gpt">ChatGPT</option>
<option value="gemini">Gemini</option>
<option value="local">ローカル</option>
</select>

<input id="openaiKey" placeholder="ChatGPT APIキー">
<input id="geminiKey" placeholder="Gemini APIキー">
<input id="elevenKey" placeholder="ElevenLabs APIキー">
<input id="voiceId" placeholder="Voice ID">

<select id="voiceType">
<option value="browser">スマホ音声</option>
<option value="eleven">AI音声</option>
</select>

<button onclick="saveSettings()">保存</button>
<button onclick="closeSettings()">閉じる</button>
</div>

<script>

/* ===== 初期 ===== */
window.onload = ()=>{
  loadSettings();
  greet();
}

/* ===== 設定 ===== */
function saveSettings(){
  localStorage.setItem("name", name.value);
  localStorage.setItem("aiType", aiType.value);
  localStorage.setItem("openaiKey", openaiKey.value);
  localStorage.setItem("geminiKey", geminiKey.value);
  localStorage.setItem("elevenKey", elevenKey.value);
  localStorage.setItem("voiceId", voiceId.value);
  localStorage.setItem("voiceType", voiceType.value);
  alert("保存OK");
}

function loadSettings(){
  name.value = localStorage.getItem("name") || "";
  aiType.value = localStorage.getItem("aiType") || "local";
  openaiKey.value = localStorage.getItem("openaiKey") || "";
  geminiKey.value = localStorage.getItem("geminiKey") || "";
  elevenKey.value = localStorage.getItem("elevenKey") || "";
  voiceId.value = localStorage.getItem("voiceId") || "";
  voiceType.value = localStorage.getItem("voiceType") || "browser";
}

/* ===== UI ===== */
function openSettings(){ modal.style.display="block"; }
function closeSettings(){ modal.style.display="none"; }

/* ===== メッセージ ===== */
function addMsg(text, type){
  const div = document.createElement("div");
  div.className = "msg " + type;
  div.innerText = text;

  const time = document.createElement("div");
  time.className="time";
  time.innerText = new Date().toLocaleTimeString();
  div.appendChild(time);

  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
}

/* ===== 送信 ===== */
async function send(){
  const text = document.getElementById("text").value;
  if(!text) return;

  addMsg(text,"user");
  document.getElementById("text").value="";

  let reply="...";

  const type = localStorage.getItem("aiType");

  if(type==="gpt"){
    reply = await sendGPT(text);
  }else if(type==="gemini"){
    reply = await sendGemini(text);
  }else{
    reply = "ちゃんと聞いてるよ";
  }

  addMsg(reply,"ai");
  speak(reply);
}

/* ===== GPT ===== */
async function sendGPT(text){
  const key = localStorage.getItem("openaiKey");

  const res = await fetch("https://api.openai.com/v1/chat/completions",{
    method:"POST",
    headers:{
      "Content-Type":"application/json",
      "Authorization":"Bearer "+key
    },
    body:JSON.stringify({
      model:"gpt-4o-mini",
      messages:[
        {role:"system",content:"優しい女性として会話して"},
        {role:"user",content:text}
      ]
    })
  });

  const data = await res.json();
  return data.choices?.[0]?.message?.content || "エラー";
}

/* ===== Gemini ===== */
async function sendGemini(text){
  const key = localStorage.getItem("geminiKey");

  const res = await fetch(
    "https://generativelanguage.googleapis.com/v1/models/gemini-pro:generateContent?key="+key,
  {
    method:"POST",
    headers:{ "Content-Type":"application/json"},
    body:JSON.stringify({
      contents:[{parts:[{text:text}]}]
    })
  });

  const data = await res.json();
  return data.candidates?.[0]?.content?.parts?.[0]?.text || "エラー";
}

/* ===== 音声 ===== */
function speak(text){
  const type = localStorage.getItem("voiceType");

  if(type==="browser"){
    const uttr = new SpeechSynthesisUtterance(text);
    speechSynthesis.speak(uttr);
  }else{
    speakEleven(text);
  }
}

async function speakEleven(text){
  const key = localStorage.getItem("elevenKey");
  const voice = localStorage.getItem("voiceId");

  const res = await fetch(
    `https://api.elevenlabs.io/v1/text-to-speech/${voice}`,
    {
      method:"POST",
      headers:{
        "xi-api-key":key,
        "Content-Type":"application/json"
      },
      body:JSON.stringify({
        text:text,
        model_id:"eleven_multilingual_v2"
      })
    }
  );

  const blob = await res.blob();
  const url = URL.createObjectURL(blob);
  new Audio(url).play();
}

/* ===== 音声入力 ===== */
function startVoice(){
  const rec = new webkitSpeechRecognition();
  rec.lang="ja-JP";
  rec.onresult = e=>{
    text.value = e.results[0][0].transcript;
  };
  rec.start();
}

/* ===== 起動時あいさつ ===== */
function greet(){
  const name = localStorage.getItem("name") || "";
  const hour = new Date().getHours();

  let msg="こんにちは";

  if(hour<5) msg="まだ起きてるの？";
  else if(hour<11) msg="おはよう";
  else if(hour<18) msg="こんにちは";
  else msg="こんばんは";

  if(name) msg = name + "、" + msg;

  addMsg(msg,"ai");
  speak(msg);
}
</script>

</body>
</html>
