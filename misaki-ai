<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>美咲AI 安定版</title>

<style>
body{
  margin:0;
  background:#08121f;
  font-family:sans-serif;
  color:white;
}

/* ===== 全体 ===== */
.app{
  display:flex;
  flex-direction:column;
  height:100vh;
}

/* ===== 画像（固定） ===== */
.top{
  flex-shrink:0;
  height:25vh;
  display:flex;
  justify-content:center;
  align-items:center;
}
.top img{
  width:92%;
  height:100%;
  object-fit:cover;
  border-radius:20px;
}

/* ===== チャット（ここだけスクロール） ===== */
#chatBox{
  flex:1;
  overflow-y:auto;
  padding:10px;
}

/* ===== メッセージ ===== */
.message{
  max-width:75%;
  padding:10px;
  border-radius:15px;
  margin:6px;
  font-size:13px;
}

.user{
  background:#ff4f8b;
  margin-left:auto;
}

.bot{
  background:#444;
}

/* ===== 入力エリア（固定） ===== */
.input{
  flex-shrink:0;
  display:flex;
  align-items:center;
  padding:8px;
  background:#111;
}

input{
  flex:1;
  padding:12px;
  border-radius:12px;
  border:none;
  font-size:14px;
}

button{
  margin-left:6px;
  padding:12px;
  border:none;
  border-radius:12px;
  font-size:14px;
}

/* ===== スタンプパネル ===== */
#stampPanel{
  display:none;
  flex-wrap:wrap;
  gap:10px;
  padding:10px;
  background:#222;
}

/* ===== タブ（固定） ===== */
.tabs{
  flex-shrink:0;
  display:flex;
  background:#222;
}

.tab{
  flex:1;
  text-align:center;
  padding:10px;
}
</style>
</head>

<body>

<div class="app">

<!-- 画像 -->
<div class="top">
<img src="girl-normal.jpg">
</div>

<!-- チャット -->
<div id="chatBox"></div>

<!-- スタンプ -->
<div id="stampPanel"></div>

<!-- 入力 -->
<div class="input">
<button onclick="toggleStamp()">😊</button>
<button onclick="startVoice()">🎤</button>
<input id="userInput" placeholder="話しかけて...">
<button onclick="sendMessage()">送信</button>
</div>

<!-- タブ -->
<div class="tabs">
<div class="tab">会話</div>
<div class="tab">分析</div>
<div class="tab">未来</div>
<div class="tab">設定</div>
</div>

</div>

<script>

/* ===== メッセージ ===== */

function addMessage(text,type){

  const div=document.createElement("div");
  div.className="message "+type;

  div.textContent=text;

  chatBox.appendChild(div);
  chatBox.scrollTop = chatBox.scrollHeight;
}

/* ===== 送信 ===== */

function sendMessage(){

  const text=userInput.value;
  if(!text) return;

  addMessage(text,"user");
  userInput.value="";

  setTimeout(()=>{
    addMessage("ちゃんと聞いてるよ","bot");
  },800);
}

/* ===== スタンプ ===== */

const stamps=["😊","😢","😡","😴","😍","😭","😆"];

function toggleStamp(){

  const panel=document.getElementById("stampPanel");

  panel.style.display = panel.style.display==="flex" ? "none" : "flex";

  panel.innerHTML="";

  stamps.forEach(s=>{
    const btn=document.createElement("button");
    btn.textContent=s;

    btn.onclick=()=>{
      addMessage(s,"user");
      panel.style.display="none";
    };

    panel.appendChild(btn);
  });
}

/* ===== 音声入力 ===== */

function startVoice(){

  try{
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const recog = new SpeechRecognition();

    recog.lang="ja-JP";

    recog.onresult=(e)=>{
      userInput.value = e.results[0][0].transcript;
      sendMessage();
    };

    recog.start();

  }catch{
    alert("音声入力できません");
  }
}

</script>

</body>
</html>
