        "急がなくていいから、引っかかってるところからで大丈夫だよ。",
        "話せるところからでいいよ。",
        "今いちばん重たいところだけでも大丈夫だよ。"
      ];

      if (silence >= 2) {
        return pick([
          "無理に話さなくて大丈夫だよ。",
          "今はここにいるだけでもいいよ。",
          "返事を急がなくて大丈夫。"
        ]);
      }

      if (mode === "just_listen") {
        return pick(noQuestionTails);
      }

      if (mode === "deep_talk") {
        if (Math.random() < 0.45) return pick(noQuestionTails);
        return pick(deepButSoftTails);
      }

      if (Math.random() < 0.58) {
        return pick(noQuestionTails);
      }

      return pick(softQuestionTails);
    }

    function getWarmthPrefix() {
      const p = memory.personalityProfile;

      if (p.warmth === "warm") {
        return pick([
          "うん、大丈夫だよ。\n",
          "そっか…ちゃんと聞いてるよ。\n",
          "うん、ここでは無理しなくていいよ。\n"
